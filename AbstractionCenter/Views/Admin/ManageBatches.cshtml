@model AbstractionCenter.Models.Entities.Course
@{
    ViewData["Title"] = "إدارة دفعات: " + Model.Title;
}

<style>
    .premium-form-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 15px 35px -10px rgba(11, 17, 32, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.15);
        margin-bottom: 40px;
    }

    .form-header-icon {
        width: 60px;
        height: 60px;
        background: rgba(212, 175, 55, 0.1);
        color: #d4af37;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 20px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 800;
            color: #0b1120;
        }

    .form-control {
        width: 100%;
        padding: 14px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 14px;
        font-family: inherit;
        font-size: 1rem;
        background: #f8fafc;
        transition: 0.3s;
    }

        .form-control:focus {
            outline: none;
            border-color: #d4af37;
            background: white;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        }

    .btn-submit {
        background: linear-gradient(135deg, #0b1120, #1e293b);
        color: #d4af37;
        border: none;
        padding: 16px 35px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.1rem;
        cursor: pointer;
        box-shadow: 0 10px 25px -5px rgba(11, 17, 32, 0.4);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: 0.3s;
        margin-top: 10px;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px -5px rgba(11, 17, 32, 0.6);
            color: white;
        }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .modern-data-table {
        width: 100%;
        border-collapse: collapse;
        white-space: nowrap;
    }

        .modern-data-table th {
            text-align: right;
            padding: 18px 20px;
            background: #f8fafc;
            color: #0b1120;
            font-size: 0.95rem;
            font-weight: 800;
            border-bottom: 2px solid #e2e8f0;
        }

        .modern-data-table td {
            padding: 18px 20px;
            color: #1e293b;
            font-weight: 600;
            font-size: 1rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

    .badge-open {
        background: rgba(16, 185, 129, 0.1);
        color: #059669;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
    }

    .badge-closed {
        background: rgba(239, 68, 68, 0.1);
        color: #dc2626;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
    }

    .btn-edit-batch {
        background: #0b1120;
        color: #d4af37;
        padding: 8px 15px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 800;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: 0.3s;
        border: none;
        cursor: pointer;
    }

        .btn-edit-batch:hover {
            background: #d4af37;
            color: #0b1120;
        }

    .btn-delete-batch {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        padding: 8px 15px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 800;
        border: 1px solid rgba(239, 68, 68, 0.2);
        cursor: pointer;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-delete-batch:hover {
            background: #ef4444;
            color: white;
        }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }

    /* === Media Queries للموبايل والشاشات الصغيرة === */
    @@media (max-width: 768px) {
        .premium-form-card {
            padding: 30px 20px;
            border-radius: 20px;
        }

        .form-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .btn-submit {
            width: 100%;
            justify-content: center;
            font-size: 1.05rem;
        }

        .form-header-icon {
            width: 50px;
            height: 50px;
            font-size: 1.4rem;
            margin-bottom: 15px;
        }

        .page-header h2 {
            font-size: 1.5rem !important;
        }

        h3 {
            font-size: 1.4rem !important;
        }

        .modern-data-table th, .modern-data-table td {
            padding: 12px 15px;
            font-size: 0.9rem;
        }
    }
</style>

<div>
    <div class="page-header">
        <h2 style="color: #0b1120; font-weight: 900; margin: 0;"><i class="fa-solid fa-layer-group" style="color: #d4af37;"></i> إدارة دفعات: @Model.Title</h2>
        <a href="/Admin/ManageCourses" style="color: #64748b; font-weight: bold; text-decoration: none; display: flex; align-items: center; gap: 8px;">
            <i class="fa-solid fa-arrow-right"></i> عودة للدورات
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: rgba(16, 185, 129, 0.1); color: #059669; padding: 15px 25px; border-radius: 16px; margin-bottom: 25px; font-weight: 800; border: 1px solid #10b981; display: flex; align-items: center; gap: 10px;">
            <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background: rgba(239, 68, 68, 0.1); color: #dc2626; padding: 15px 25px; border-radius: 16px; margin-bottom: 25px; font-weight: 800; border: 1px solid #ef4444; display: flex; align-items: center; gap: 10px;">
            <i class="fa-solid fa-triangle-exclamation"></i> @TempData["ErrorMessage"]
        </div>
    }

    <!-- نموذج إضافة دفعة جديدة -->
    <div class="premium-form-card">
        <div class="form-header-icon"><i class="fa-solid fa-calendar-plus"></i></div>
        <h3 style="color: #0b1120; font-weight: 900; margin-bottom: 25px;">فتح دفعة جديدة وتعيين محاضر</h3>

        <form asp-action="CreateBatch" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CourseId" value="@Model.Id" />

            <div class="form-grid">
                <div class="form-group">
                    <label>اسم الدفعة (يظهر للطلاب)</label>
                    <input type="text" name="BatchName" class="form-control" placeholder="مثال: الدفعة الأولى - 2025" required />
                </div>
                <div class="form-group">
                    <label>تاريخ البدء المتوقع</label>
                    <input type="date" name="StartDate" class="form-control" required />
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label>المحاضر المسؤول عن هذه الدفعة</label>
                    <select name="InstructorId" class="form-control" required>
                        <option value="">-- اختر محاضراً من هيئة التدريس --</option>
                        @if (ViewBag.Instructors != null)
                        {
                            foreach (var inst in ViewBag.Instructors)
                            {
                                <option value="@inst.Id">@inst.FullName - (@inst.Specialization)</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>حالة الدفعة</label>
                    <select name="Status" class="form-control">
                        <option value="0">مفتوحة للتسجيل</option>
                        <option value="1">قيد التنفيذ</option>
                        <option value="2">مكتملة</option>
                        <option value="3">مغلقة</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn-submit">حفظ وإطلاق الدفعة <i class="fa-solid fa-rocket"></i></button>
        </form>
    </div>

    <!-- قائمة الدفعات الحالية -->
    <div class="premium-form-card">
        <h3 style="color: #0b1120; font-weight: 900; margin-bottom: 25px; display: flex; align-items: center; gap: 10px;">
            <i class="fa-solid fa-users-viewfinder" style="color: #d4af37;"></i> الدفعات المسجلة لهذا المسار
        </h3>

        <div class="table-responsive">
            <table class="modern-data-table">
                <thead>
                    <tr>
                        <th>اسم الدفعة</th>
                        <th>المحاضر</th>
                        <th>تاريخ البدء</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Batches != null && Model.Batches.Any())
                    {
                        foreach (var batch in Model.Batches.OrderByDescending(b => b.StartDate))
                        {
                            <tr>
                                <td style="font-weight: 900; color: #0b1120;">@batch.BatchName</td>
                                <td><i class="fa-solid fa-chalkboard-user" style="color: #64748b; margin-left: 5px;"></i> @(batch.Instructor?.FullName ?? "غير محدد")</td>
                                <td style="font-family: monospace; font-size: 1.1rem; color: #475569;">@batch.StartDate.ToString("yyyy/MM/dd")</td>
                                <td>
                                    @if (batch.Status == AbstractionCenter.Models.Entities.BatchStatus.OpenForRegistration)
                                    {
                                        <span class="badge-open"><i class="fa-solid fa-door-open"></i> مفتوحة للتسجيل</span>
                                    }
                                    else
                                    {
                                        <span class="badge-closed"><i class="fa-solid fa-lock"></i> مغلقة / قيد التنفيذ</span>
                                    }
                                </td>
                                <td>
                                    <div style="display: flex; gap: 10px;">
                                        <a href="/Admin/EditBatch/@batch.Id" class="btn-edit-batch" title="تعديل">
                                            <i class="fa-solid fa-pen-to-square"></i> تعديل
                                        </a>
                                        <form asp-action="DeleteBatch" method="post" style="margin: 0;" onsubmit="return confirm('هل أنت متأكد من حذف هذه الدفعة نهائياً؟');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@batch.Id" />
                                            <button type="submit" class="btn-delete-batch" title="حذف">
                                                <i class="fa-solid fa-trash-can"></i> حذف
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 40px; color: #64748b;">لا توجد دفعات تم إنشاؤها لهذه الدورة بعد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
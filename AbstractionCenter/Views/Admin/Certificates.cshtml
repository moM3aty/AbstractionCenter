@model IEnumerable<AbstractionCenter.Models.Entities.Certificate>
@{
    ViewData["Title"] = "إدارة واعتماد الشهادات";
}

<style>
    .table-card {
        background: var(--card-bg);
        border-radius: var(--radius-box);
        padding: 30px;
        box-shadow: var(--shadow-card);
    }

    .modern-table {
        width: 100%;
        border-collapse: collapse;
    }

        .modern-table th {
            text-align: right;
            padding: 15px;
            color: var(--text-muted);
            font-size: 0.85rem;
            border-bottom: 1px solid var(--border-color);
        }

        .modern-table td {
            padding: 15px;
            color: var(--text-main);
            font-weight: 600;
            font-size: 0.95rem;
            border-bottom: 1px solid #f8fafc;
        }

    .badge {
        padding: 6px 12px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: bold;
    }

    .badge-pending {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
    }

    .badge-approved {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .serial-number {
        background: #f1f5f9;
        padding: 5px 10px;
        border-radius: 6px;
        font-family: monospace;
        letter-spacing: 1px;
        color: #475569;
    }
</style>

<div class="table-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h3 style="color: var(--text-main); margin: 0;"><i class="fa-solid fa-certificate" style="color: var(--sidebar-active-bg);"></i> السجل العام للشهادات</h3>
        <button class="btn-add" style="background: var(--sidebar-active-bg); color: white; border: none; padding: 10px 20px; border-radius: 15px; cursor: pointer;"><i class="fa-solid fa-print"></i> طباعة السجل</button>
    </div>

    <table class="modern-table">
        <thead>
            <tr>
                <th>الرقم التسلسلي</th>
                <th>اسم الطالب</th>
                <th>الدورة / المسار</th>
                <th>تاريخ الإصدار</th>
                <th>الحالة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var cert in Model)
                {
                    <tr>
                        <td><span class="serial-number">@cert.UniqueSerialNumber</span></td>
                        <td>@(cert.Student?.FullName ?? cert.Student?.Email)</td>
                        <td style="color: var(--text-muted);">@(cert.Course?.Title)</td>
                        <td>@cert.IssueDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (cert.IsApproved)
                            {
                                <span class="badge badge-approved">معتمدة</span>
                            }
                            else
                            {
                                <span class="badge badge-pending">بانتظار الاعتماد</span>
                            }
                        </td>
                        <td>
                            @if (!cert.IsApproved)
                            {
                                <form asp-action="ApproveCertificate" method="post" style="display:inline;">
                                    <input type="hidden" name="certificateId" value="@cert.Id" />
                                    <button type="submit" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border: none; padding: 6px 15px; border-radius: 8px; font-weight: bold; cursor: pointer;">
                                        <i class="fa-solid fa-check"></i> اعتماد
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a href="/Home/VerifyCertificate?serialNumber=@cert.UniqueSerialNumber" target="_blank" style="color: var(--sidebar-active-bg); text-decoration: none; font-size: 0.9rem; background: rgba(67, 24, 255, 0.1); padding: 6px 15px; border-radius: 8px;"><i class="fa-solid fa-eye"></i> عرض</a>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" style="text-align: center; padding: 40px; color: var(--text-muted);">لا توجد شهادات مصدرة حالياً.</td></tr>
            }
        </tbody>
    </table>
</div>
@model IEnumerable<AbstractionCenter.Models.Entities.RegistrationRequest>
@{
    ViewData["Title"] = "طلبات الانضمام للدورات";
}

<style>
    .table-card {
        background: var(--card-bg);
        border-radius: var(--radius-box);
        padding: 30px;
        box-shadow: var(--shadow-card);
    }

    .modern-table {
        width: 100%;
        border-collapse: collapse;
    }

        .modern-table th {
            text-align: right;
            padding: 15px;
            color: var(--text-muted);
            font-size: 0.85rem;
            border-bottom: 1px solid var(--border-color);
        }

        .modern-table td {
            padding: 15px;
            color: var(--text-main);
            font-weight: 600;
            font-size: 0.95rem;
            border-bottom: 1px solid #f8fafc;
        }

    .badge {
        padding: 6px 12px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: bold;
    }

    .badge-pending {
        background: rgba(245, 158, 11, 0.1);
        color: #f59e0b;
    }

    .badge-approved {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }
</style>

<div class="table-card">
    <h3 style="color: var(--text-main); margin-bottom: 25px;"><i class="fa-solid fa-inbox" style="color: var(--sidebar-active-bg);"></i> صندوق الطلبات الواردة</h3>

    <table class="modern-table">
        <thead>
            <tr>
                <th>الطالب</th>
                <th>الدورة المطلوبة</th>
                <th>تاريخ الطلب</th>
                <th>الحالة</th>
                <th>القرار</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var request in Model)
                {
                    <tr>
                        <td>@(request.Student?.FullName ?? request.Student?.Email)</td>
                        <td style="color: var(--text-muted); font-weight: 500;">@(request.Course?.Title)</td>
                        <td style="color: var(--text-muted); font-weight: 500;">@request.RequestDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (request.Status == AbstractionCenter.Models.Entities.RequestStatus.Pending)
                            {
                                <span class="badge badge-pending">قيد المراجعة</span>
                            }
                            else
                            {
                                <span class="badge badge-approved">تمت الموافقة</span>
                            }
                        </td>
                        <td>
                            @if (request.Status == AbstractionCenter.Models.Entities.RequestStatus.Pending)
                            {
                                <form asp-action="ApproveRequest" method="post" style="display:inline;">
                                    <input type="hidden" name="requestId" value="@request.Id" />
                                    <button type="submit" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border: none; padding: 8px 15px; border-radius: 10px; font-weight: bold; cursor: pointer; font-family: inherit;">
                                        <i class="fa-solid fa-check"></i> قبول الطالب
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span style="color: var(--text-muted); font-size: 0.85rem;"><i class="fa-solid fa-lock"></i> تم القرار</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" style="text-align: center; padding: 40px; color: var(--text-muted);">لا توجد طلبات تسجيل حالياً.</td></tr>
            }
        </tbody>
    </table>
</div>
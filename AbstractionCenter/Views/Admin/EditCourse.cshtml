@model AbstractionCenter.Models.Entities.Course
@{
    ViewData["Title"] = "تعديل بيانات الدورة";
}

<style>
    .premium-form-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 50px;
        box-shadow: 0 15px 35px -10px rgba(11, 17, 32, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.15);
        max-width: 900px;
        margin: 0 auto;
    }

    .form-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .form-header-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(59, 130, 246, 0.05));
        color: #3b82f6;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 20px;
        border: 1px solid rgba(59, 130, 246, 0.3);
        transform: rotate(10deg);
    }

    .form-header h2 {
        color: #0b1120;
        font-size: 2rem;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .form-header p {
        color: #64748b;
        font-size: 1.1rem;
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-weight: 800;
            color: #0b1120;
            font-size: 1.05rem;
        }

    .form-control {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        font-family: inherit;
        font-size: 1rem;
        background: #f8fafc;
        transition: all 0.3s ease;
        color: #1e293b;
    }

        .form-control:focus {
            outline: none;
            border-color: #d4af37;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        }

    .btn-submit {
        background: linear-gradient(135deg, #0b1120, #1e293b);
        color: #d4af37;
        border: none;
        padding: 18px 40px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.15rem;
        cursor: pointer;
        box-shadow: 0 10px 25px -5px rgba(11, 17, 32, 0.4);
        transition: all 0.4s ease;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 30px;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px -5px rgba(11, 17, 32, 0.6);
            color: white;
        }

    .btn-cancel {
        display: block;
        text-align: center;
        margin-top: 20px;
        color: #64748b;
        font-weight: 700;
        transition: 0.3s;
        text-decoration: none;
    }

        .btn-cancel:hover {
            color: #ef4444;
        }

    .current-image-preview {
        margin-top: 15px;
        padding: 15px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 20px;
    }

        .current-image-preview img {
            width: 140px;
            height: 90px;
            object-fit: cover;
            border-radius: 12px;
            border: 2px solid rgba(212, 175, 55, 0.3);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

    /* === Media Queries للموبايل والشاشات الصغيرة === */
    @@media (max-width: 768px) {
        .premium-form-card {
            padding: 35px 20px;
            border-radius: 20px;
        }

        .form-header h2 {
            font-size: 1.7rem;
        }

        .form-header-icon {
            width: 70px;
            height: 70px;
            font-size: 2rem;
            margin-bottom: 15px;
        }

        .btn-submit {
            font-size: 1.1rem;
            padding: 16px 20px;
        }

        .current-image-preview {
            flex-direction: column;
            align-items: flex-start;
            text-align: center;
            gap: 15px;
        }

            .current-image-preview img {
                width: 100%;
                height: auto;
                max-height: 200px;
            }

            .current-image-preview div {
                width: 100%;
            }
    }
</style>

<div class="premium-form-card">
    <div class="form-header">
        <div class="form-header-icon"><i class="fa-solid fa-pen-nib" style="transform: rotate(-10deg);"></i></div>
        <h2>تعديل المسار التدريبي</h2>
        <p>أنت تقوم حالياً بتحديث بيانات: <strong style="color: #d4af37;">@Model.Title</strong></p>
    </div>

    <form asp-action="EditCourse" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label>اسم الدورة / المسار</label>
            <input asp-for="Title" class="form-control" required />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>وصف الدورة (الكتالوج)</label>
            <textarea asp-for="Description" class="form-control" rows="5" required></textarea>
        </div>

        <div class="form-group">
            <label>تحديث صورة الغلاف</label>
            <div style="position: relative;">
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" style="padding-left: 45px;" />
                <i class="fa-solid fa-image" style="position: absolute; left: 18px; top: 18px; color: #d4af37; font-size: 1.2rem; pointer-events: none;"></i>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="current-image-preview">
                    <img src="@Model.ImageUrl" alt="Current Cover" />
                    <div>
                        <strong style="display: block; color: #0b1120; font-size: 1rem; margin-bottom: 5px;">الغلاف الحالي</strong>
                        <span style="color: #64748b; font-size: 0.9rem;">اترك حقل الصورة فارغاً للاحتفاظ بهذه الصورة.</span>
                    </div>
                </div>
            }
        </div>

        <div>
            <button type="submit" class="btn-submit">حفظ التعديلات <i class="fa-solid fa-floppy-disk"></i></button>
            <a href="/Admin/ManageCourses" class="btn-cancel">إلغاء والعودة للقائمة</a>
        </div>
    </form>
</div>
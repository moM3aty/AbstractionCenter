@model AbstractionCenter.Models.Entities.Course
@{
    ViewData["Title"] = "إنشاء دورة تدريبية (مسار عام)";
}

<style>
    .premium-form-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 50px;
        box-shadow: 0 15px 35px -10px rgba(11, 17, 32, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.15);
        max-width: 900px;
        margin: 0 auto;
    }

    .form-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .form-header-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, rgba(212, 175, 55, 0.15), rgba(212, 175, 55, 0.05));
        color: #d4af37;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 20px;
        border: 1px solid rgba(212, 175, 55, 0.3);
        transform: rotate(10deg);
    }

    .form-header h2 {
        color: #0b1120;
        font-size: 2rem;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .form-header p {
        color: #64748b;
        font-size: 1.1rem;
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-weight: 800;
            color: #0b1120;
            font-size: 1.05rem;
        }

    .form-control {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        font-family: inherit;
        font-size: 1rem;
        background: #f8fafc;
        transition: all 0.3s ease;
        color: #1e293b;
    }

        .form-control:focus {
            outline: none;
            border-color: #d4af37;
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        }

    .btn-submit {
        background: linear-gradient(135deg, #d4af37, #fef08a);
        color: #0b1120;
        border: none;
        padding: 18px 40px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.15rem;
        cursor: pointer;
        box-shadow: 0 10px 25px -5px rgba(212, 175, 55, 0.4);
        transition: all 0.4s ease;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px -5px rgba(212, 175, 55, 0.6);
            background: linear-gradient(135deg, #b48a25, #d4af37);
            color: white;
        }

    .btn-cancel {
        display: block;
        text-align: center;
        margin-top: 20px;
        color: #64748b;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            color: #ef4444;
        }

    /* === Media Queries للموبايل === */
    @media (max-width: 768px) {
        .premium-form-card

    {
        padding: 30px 20px;
    }

    .form-header h2 {
        font-size: 1.6rem;
    }

    .form-header-icon {
        width: 60px;
        height: 60px;
        font-size: 1.8rem;
    }

    .btn-submit {
        padding: 15px;
        font-size: 1.05rem;
    }

    }
</style>

<div class="premium-form-card">
    <div class="form-header">
        <div class="form-header-icon"><i class="fa-solid fa-layer-group" style="transform: rotate(-10deg);"></i></div>
        <h2>إعداد مسار تدريبي عام</h2>
        <p>قم بإنشاء الكتالوج الأساسي للدورة (ستتمكن لاحقاً من إضافة الدفعات وتعيين المحاضرين لها).</p>
    </div>

    <form asp-action="CreateCourse" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>اسم الدورة / المسار <span style="color: #ef4444;">*</span></label>
            <input asp-for="Title" class="form-control" placeholder="مثال: دبلومة البرمجة المتقدمة" required />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>وصف الدورة (يظهر في الموقع للطلاب) <span style="color: #ef4444;">*</span></label>
            <textarea asp-for="Description" class="form-control" rows="5" placeholder="اكتب نبذة عن الدورة ومخرجاتها..." required></textarea>
        </div>

        <div class="form-group">
            <label>صورة غلاف الدورة</label>
            <div style="position: relative;">
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" style="padding-left: 45px;" />
                <i class="fa-solid fa-cloud-arrow-up" style="position: absolute; left: 18px; top: 18px; color: #d4af37; font-size: 1.2rem; pointer-events: none;"></i>
            </div>
        </div>

        <div style="margin-top: 50px;">
            <button type="submit" class="btn-submit">حفظ وإنشاء الدورة <i class="fa-solid fa-rocket"></i></button>
            <a href="/Admin/ManageCourses" class="btn-cancel">إلغاء والعودة للقائمة</a>
        </div>
    </form>
</div>
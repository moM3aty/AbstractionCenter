@{
    ViewData["Title"] = "لوحة القيادة الملكية";
}

<style>
    /* --- Dashboard Specific Styles --- */
    .welcome-banner {
        background: linear-gradient(135deg, #0b1120 0%, #1e293b 100%);
        border-radius: 24px;
        padding: 50px 60px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        box-shadow: 0 20px 40px -10px rgba(11, 17, 32, 0.4);
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(212, 175, 55, 0.15);
    }

        /* Decorative circles in banner */
        .welcome-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(212, 175, 55, 0.2) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .welcome-banner::after {
            content: '';
            position: absolute;
            bottom: -50%;
            left: -10%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

    .welcome-content {
        position: relative;
        z-index: 10;
    }

        .welcome-content h1 {
            font-size: 2.8rem;
            font-weight: 900;
            margin-bottom: 15px;
            letter-spacing: -0.5px;
            color: white;
        }

            .welcome-content h1 span {
                background: linear-gradient(to left, #d4af37, #fef08a);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        .welcome-content p {
            font-size: 1.15rem;
            color: #cbd5e1;
            margin: 0;
            max-width: 550px;
            line-height: 1.7;
        }

    .welcome-icon {
        position: relative;
        z-index: 10;
        width: 130px;
        height: 130px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4.5rem;
        color: #d4af37;
        backdrop-filter: blur(10px);
        transform: rotate(-10deg);
        box-shadow: 0 15px 35px rgba(0,0,0,0.3);
    }

    /* --- Stats Grid --- */
    .stats-premium-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 30px;
        margin-bottom: 50px;
    }

    .stat-premium-card {
        background: white;
        border-radius: 24px;
        padding: 30px;
        display: flex;
        align-items: center;
        gap: 25px;
        box-shadow: 0 10px 30px -10px rgba(11, 17, 32, 0.08);
        border: 1px solid #e2e8f0;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        overflow: hidden;
    }

        /* Hover side-line effect */
        .stat-premium-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 4px;
            height: 100%;
            background: #d4af37;
            transform: scaleY(0);
            transition: transform 0.4s ease;
            transform-origin: bottom;
        }

        .stat-premium-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px -10px rgba(11, 17, 32, 0.15);
            border-color: rgba(212, 175, 55, 0.3);
        }

            .stat-premium-card:hover::before {
                transform: scaleY(1);
            }

    .stat-icon-wrapper {
        width: 75px;
        height: 75px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        transition: transform 0.4s ease;
    }

    .stat-premium-card:hover .stat-icon-wrapper {
        transform: scale(1.1) rotate(5deg);
    }

    .stat-info h4 {
        color: #64748b;
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .stat-info h2 {
        color: #0b1120;
        font-size: 2.6rem;
        font-weight: 900;
        margin: 0;
        line-height: 1;
    }

    /* Specific Icon Colors */
    .icon-students {
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
    }

    .icon-courses {
        background: rgba(212, 175, 55, 0.1);
        color: #d4af37;
    }

    .icon-certs {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .icon-staff {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    /* --- Quick Actions --- */
    .section-title {
        color: #0b1120;
        font-size: 1.6rem;
        font-weight: 900;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .section-title i {
            color: #d4af37;
        }

    .actions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 20px;
        margin-bottom: 50px;
    }

    .action-btn {
        background: white;
        border: 1px solid #e2e8f0;
        padding: 30px 20px;
        border-radius: 20px;
        text-align: center;
        font-weight: 800;
        font-size: 1.15rem;
        color: #1e293b;
        transition: all 0.4s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
        text-decoration: none;
    }

        .action-btn i {
            font-size: 2.5rem;
            color: #d4af37;
            transition: transform 0.4s ease;
        }

        .action-btn:hover {
            background: linear-gradient(135deg, #0b1120, #1e293b);
            color: white;
            border-color: #0b1120;
            transform: translateY(-8px);
            box-shadow: 0 15px 30px -5px rgba(11, 17, 32, 0.3);
        }

            .action-btn:hover i {
                transform: scale(1.15);
                color: #fef08a;
            }

    /* --- Table Styles (لجدول الإحصائيات) --- */
    .premium-table-card {
        background: white;
        border-radius: 24px;
        padding: 30px;
        box-shadow: 0 10px 30px -10px rgba(11, 17, 32, 0.08);
        border: 1px solid #e2e8f0;
    }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .modern-data-table {
        width: 100%;
        border-collapse: collapse;
        white-space: nowrap;
    }

        .modern-data-table th {
            text-align: right;
            padding: 18px 20px;
            background: #f8fafc;
            color: #0b1120;
            font-size: 0.95rem;
            font-weight: 800;
            border-bottom: 2px solid #e2e8f0;
        }

        .modern-data-table td {
            padding: 18px 20px;
            color: #1e293b;
            font-weight: 600;
            font-size: 1rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .modern-data-table tbody tr:hover td {
            background: #fcfcfd;
        }

    .status-open {
        background: rgba(16, 185, 129, 0.1);
        color: #059669;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: bold;
    }

    .status-progress {
        background: rgba(59, 130, 246, 0.1);
        color: #2563eb;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: bold;
    }

    /* === Media Queries للموبايل === */
    @@media (max-width: 768px) {
        .welcome-banner {
            flex-direction: column;
            text-align: center;
            padding: 40px 25px;
            gap: 25px;
        }

        .welcome-content h1 {
            font-size: 2.2rem;
        }

        .welcome-content p {
            font-size: 1rem;
        }

        .welcome-icon {
            transform: none;
            width: 90px;
            height: 90px;
            font-size: 3rem;
            margin: 0 auto;
        }

        .stats-premium-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .stat-premium-card {
            padding: 25px;
        }

        .actions-grid {
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 15px;
        }

        .action-btn {
            padding: 20px 15px;
            font-size: 1rem;
            gap: 12px;
        }

            .action-btn i {
                font-size: 2rem;
            }

        .premium-table-card {
            padding: 20px 15px;
        }
    }
</style>

<div>
    <!-- Royal Welcome Banner -->
    <div class="welcome-banner">
        <div class="welcome-content">
            <h1>مرحباً بك في <span>مركز القيادة</span></h1>
            <p>بوابتك الذكية لإدارة منصة أبستراكشن. تابع أداء المنصة، أدر الدورات، وراجع طلبات الطلاب والمحاضرين من مكان واحد بكل سهولة واحترافية.</p>
        </div>
        <div class="welcome-icon">
            <i class="fa-solid fa-chess-queen"></i>
        </div>
    </div>

    <!-- Premium Stats Grid -->
    <div class="stats-premium-grid">
        <div class="stat-premium-card">
            <div class="stat-icon-wrapper icon-students">
                <i class="fa-solid fa-users"></i>
            </div>
            <div class="stat-info">
                <h4>إجمالي الطلاب</h4>
                <h2>@ViewBag.TotalStudents</h2>
            </div>
        </div>

        <div class="stat-premium-card">
            <div class="stat-icon-wrapper icon-courses">
                <i class="fa-solid fa-layer-group"></i>
            </div>
            <div class="stat-info">
                <h4>الدورات النشطة</h4>
                <h2>@ViewBag.TotalCourses</h2>
            </div>
        </div>

        <div class="stat-premium-card">
            <div class="stat-icon-wrapper icon-certs">
                <i class="fa-solid fa-certificate"></i>
            </div>
            <div class="stat-info">
                <h4>طلبات شهادات</h4>
                <h2>@ViewBag.PendingCertificates</h2>
            </div>
        </div>

        <div class="stat-premium-card">
            <div class="stat-icon-wrapper icon-staff">
                <i class="fa-solid fa-user-tie"></i>
            </div>
            <div class="stat-info">
                <h4>هيئة التدريس</h4>
                <h2>@ViewBag.ActiveInstructors</h2>
            </div>
        </div>
    </div>

    <!-- Quick Actions Section -->
    <h3 class="section-title"><i class="fa-solid fa-bolt"></i> الوصول السريع</h3>
    <div class="actions-grid">
        <a href="/Admin/CreateCourse" class="action-btn">
            <i class="fa-solid fa-folder-plus"></i>
            إضافة دورة جديدة
        </a>
        <a href="/Admin/RegistrationRequests" class="action-btn">
            <i class="fa-solid fa-inbox"></i>
            مراجعة طلبات التسجيل
        </a>
        <a href="/Admin/InstructorApplications" class="action-btn">
            <i class="fa-solid fa-chalkboard-user"></i>
            طلبات المحاضرين
        </a>
        <a href="/Admin/Certificates" class="action-btn">
            <i class="fa-solid fa-award"></i>
            اعتماد الشهادات
        </a>
        <a href="/SiteSettings/Index" class="action-btn">
            <i class="fa-solid fa-palette"></i>
            تخصيص الواجهة
        </a>
    </div>

    <!-- إحصائيات الدفعات الحالية -->
    <h3 class="section-title"><i class="fa-solid fa-chart-column"></i> إحصائيات الإقبال على الدفعات النشطة</h3>
    <div class="premium-table-card">
        <div class="table-responsive">
            <table class="modern-data-table">
                <thead>
                    <tr>
                        <th>المسار التدريبي</th>
                        <th>اسم الدفعة</th>
                        <th>حالة الدفعة</th>
                        <th>عدد الطلاب المسجلين</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.OpenBatchesStats != null)
                    {
                        var batches = (IEnumerable<AbstractionCenter.Models.Entities.Batch>)ViewBag.OpenBatchesStats;
                        if (batches.Any())
                        {
                            foreach (var batch in batches)
                            {
                                <tr>
                                    <td><strong style="color: #0b1120;">@batch.Course?.Title</strong></td>
                                    <td><i class="fa-solid fa-layer-group" style="color: #64748b; margin-left: 5px;"></i> @batch.BatchName</td>
                                    <td>
                                        @if (batch.Status == AbstractionCenter.Models.Entities.BatchStatus.OpenForRegistration)
                                        {
                                            <span class="status-open"><i class="fa-solid fa-door-open"></i> مفتوحة للتسجيل</span>
                                        }
                                        else
                                        {
                                            <span class="status-progress"><i class="fa-solid fa-chalkboard-user"></i> قيد التنفيذ</span>
                                        }
                                    </td>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 10px;">
                                            <div style="width: 35px; height: 35px; background: rgba(212, 175, 55, 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #d4af37;">
                                                <i class="fa-solid fa-users"></i>
                                            </div>
                                            <span style="font-size: 1.1rem; font-weight: 900; color: #1e293b;">@(batch.EnrolledStudents?.Count ?? 0)</span>
                                            <span style="color: #64748b; font-size: 0.9rem;">طالب</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 40px; color: #64748b;">
                                    <i class="fa-solid fa-box-open" style="font-size: 3rem; opacity: 0.5; margin-bottom: 15px;"></i>
                                    <p>لا توجد دفعات مفتوحة للتسجيل أو قيد التنفيذ حالياً.</p>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
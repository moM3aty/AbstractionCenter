@model IEnumerable<AbstractionCenter.Models.Entities.Course>
@{
    ViewData["Title"] = "إدارة الدورات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-wrapper { padding: 120px 0 60px; min-height: 70vh; }
    .admin-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        margin-top: 20px;
    }
    .admin-table th, .admin-table td {
        padding: 15px 20px;
        text-align: right;
        border-bottom: 1px solid #e2e8f0;
    }
    .admin-table th { background: var(--primary-color); color: white; }
    .admin-table tr:hover { background: #f8fafc; }
    .badge {
        padding: 5px 10px;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: bold;
    }
    .badge-open { background: rgba(16, 185, 129, 0.1); color: #10b981; }
    .badge-closed { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
</style>

<div class="container admin-wrapper">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <div>
            <h2 style="color: var(--primary-color);"><i class="fa-solid fa-layer-group"></i> إدارة الدورات والمسارات</h2>
            <p style="color: #64748b;">تحكم في الدورات المتاحة على المنصة.</p>
        </div>
        <a href="/Admin/CreateCourse" class="btn btn-primary"><i class="fa-solid fa-plus"></i> إضافة دورة جديدة</a>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>اسم الدورة</th>
                <th>مسجل الدورة</th>
                <th>تاريخ البدء</th>
                <th>الحالة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null && Model.Any())
            {
                foreach (var course in Model)
                {
                    <tr>
                        <td>#@course.Id</td>
                        <td style="font-weight: 600;">@course.Title</td>
                        <td>@course.RegistrarName <br><small style="color: #64748b;"><i class="fa-brands fa-whatsapp"></i> @course.RegistrarWhatsApp</small></td>
                        <td>@course.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if(course.Status == AbstractionCenter.Models.Entities.CourseStatus.OpenForRegistration)
                            {
                                <span class="badge badge-open">مفتوحة</span>
                            }
                            else
                            {
                                <span class="badge badge-closed">مغلقة / قيد التنفيذ</span>
                            }
                        </td>
                        <td>
                            <a href="#" class="btn btn-outline" style="padding: 5px 15px; font-size: 0.85rem;"><i class="fa-solid fa-pen"></i> تعديل</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" style="text-align: center; padding: 30px; color: #64748b;">لا توجد دورات مسجلة حالياً.</td>
                }
        </tbody>
    </table>
</div>
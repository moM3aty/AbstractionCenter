@model IEnumerable<AbstractionCenter.Models.Entities.Course>
@{
    ViewData["Title"] = "إدارة الدورات والمسارات";
}

<style>
    .premium-table-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 35px;
        box-shadow: 0 15px 35px -10px rgba(11, 17, 32, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.15);
    }

    .toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 35px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .toolbar-title {
        color: #0b1120;
        margin: 0;
        font-size: 1.6rem;
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .toolbar-title i {
            color: #d4af37;
        }

    .btn-add {
        background: linear-gradient(135deg, #d4af37, #fef08a);
        color: #0b1120;
        border: none;
        padding: 14px 35px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.05rem;
        cursor: pointer;
        box-shadow: 0 10px 20px -5px rgba(212, 175, 55, 0.4);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.4s ease;
    }

        .btn-add:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px -5px rgba(212, 175, 55, 0.6);
        }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .modern-data-table {
        width: 100%;
        border-collapse: collapse;
        white-space: nowrap;
    }

        .modern-data-table th {
            text-align: right;
            padding: 18px 20px;
            background: #f8fafc;
            color: #0b1120 !important;
            font-size: 0.95rem;
            font-weight: 800 !important;
            border-bottom: 2px solid #e2e8f0;
        }

        .modern-data-table td {
            padding: 18px 20px;
            color: #1e293b;
            font-weight: 600;
            font-size: 1rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
            transition: background 0.3s;
        }

        .modern-data-table tbody tr:hover td {
            background: #fcfcfd;
        }

    .btn-edit {
        background: #0b1120;
        color: #d4af37;
        padding: 10px 15px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 800;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid transparent;
    }

        .btn-edit:hover {
            background: #d4af37;
            color: #0b1120;
            border-color: #d4af37;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
        }

    .btn-batches {
        background: rgba(59, 130, 246, 0.1);
        color: #2563eb;
        padding: 10px 15px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 800;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

        .btn-batches:hover {
            background: #2563eb;
            color: white;
            transform: translateY(-2px);
        }

    .btn-delete {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        padding: 10px 15px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 800;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid rgba(239, 68, 68, 0.2);
        cursor: pointer;
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
            transform: translateY(-2px);
        }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
    }

        .empty-state i {
            font-size: 4rem;
            color: #cbd5e1;
            margin-bottom: 20px;
        }

        .empty-state h3 {
            color: #0b1120;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .empty-state p {
            color: #64748b;
        }
</style>

<div class="premium-table-card">
    <div class="toolbar">
        <h3 class="toolbar-title"><i class="fa-solid fa-layer-group"></i> الكتالوج العام للدورات</h3>
        <a href="/Admin/CreateCourse" class="btn-add"><i class="fa-solid fa-plus"></i> إنشاء دورة جديدة</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: rgba(16, 185, 129, 0.1); color: #059669; padding: 15px 25px; border-radius: 12px; margin-bottom: 20px; font-weight: bold; border: 1px solid #10b981;">
            <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background: rgba(239, 68, 68, 0.1); color: #dc2626; padding: 15px 25px; border-radius: 12px; margin-bottom: 20px; font-weight: bold; border: 1px solid #ef4444;">
            <i class="fa-solid fa-triangle-exclamation"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="table-responsive">
        <table class="modern-data-table">
            <thead>
                <tr>
                    <th>معلومات الدورة</th>
                    <th>تاريخ الإنشاء</th>
                    <th>عدد الدفعات</th>
                    <th>إجراءات الإدارة</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var course in Model)
                    {
                        <tr>
                            <td>
                                <div style="font-size: 1.15rem; font-weight: 900; color: #0b1120;">@course.Title</div>
                                <div style="font-size: 0.85rem; color: #64748b; margin-top: 4px;"><i class="fa-solid fa-hashtag" style="color: #d4af37;"></i> رقم المرجع: @course.Id</div>
                            </td>
                            <td style="color: #475569; font-weight: 700;">
                                <i class="fa-regular fa-calendar-days" style="color: #d4af37; margin-left: 5px;"></i> @course.CreatedAt.ToString("dd MMMM yyyy")
                            </td>
                            <td>
                                <span style="background: rgba(212, 175, 55, 0.1); color: #b48a25; padding: 6px 12px; border-radius: 8px; font-weight: 900; border: 1px solid rgba(212, 175, 55, 0.3);">
                                    @(course.Batches?.Count ?? 0) دفعة
                                </span>
                            </td>
                            <td>
                                <div style="display: flex; gap: 10px;">
                                    <a href="/Admin/ManageBatches?courseId=@course.Id" class="btn-batches"><i class="fa-solid fa-users-rectangle"></i> إدارة الدفعات</a>
                                    <a href="/Admin/EditCourse/@course.Id" class="btn-edit"><i class="fa-solid fa-pen-to-square"></i> تعديل الدورة</a>
                                    <form asp-action="DeleteCourse" method="post" style="margin: 0;" onsubmit="return confirm('هل أنت متأكد من رغبتك في حذف هذه الدورة بالكامل؟');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@course.Id" />
                                        <button type="submit" class="btn-delete"><i class="fa-solid fa-trash-can"></i> حذف</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <i class="fa-solid fa-box-open"></i>
                                <h3>لا توجد دورات مسجلة حالياً</h3>
                                <p>قم بإضافة أول دورة تدريبية لتبدأ في فتح الدفعات للطلاب.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
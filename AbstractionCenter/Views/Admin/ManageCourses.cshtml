@model IEnumerable<AbstractionCenter.Models.Entities.Course>
@{
    ViewData["Title"] = "إدارة الدورات والمسارات";
}

<style>
    .table-card {
        background: var(--card-bg);
        border-radius: var(--radius-box);
        padding: 30px;
        box-shadow: var(--shadow-card);
    }

    .toolbar {
        display: flex;
        justify-content: space-between;
        margin-bottom: 25px;
    }

    .btn-add {
        background: var(--sidebar-active-bg);
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 30px;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 10px 20px rgba(67, 24, 255, 0.2);
        text-decoration: none;
        display: inline-block;
    }

    .modern-table {
        width: 100%;
        border-collapse: collapse;
    }

        .modern-table th {
            text-align: right;
            padding: 15px;
            color: var(--text-muted);
            font-size: 0.85rem;
            border-bottom: 1px solid var(--border-color);
        }

        .modern-table td {
            padding: 15px;
            color: var(--text-main);
            font-weight: 600;
            font-size: 0.95rem;
            border-bottom: 1px solid #f8fafc;
        }

    .badge {
        padding: 6px 12px;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: bold;
    }

    .badge-open {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .badge-closed {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }
</style>

<div class="table-card">
    <div class="toolbar">
        <h3 style="color: var(--text-main); margin: 0;">الدورات المتاحة حالياً</h3>
        <a href="/Admin/CreateCourse" class="btn-add"><i class="fa-solid fa-plus"></i> إضافة دورة جديدة</a>
    </div>

    <table class="modern-table">
        <thead>
            <tr>
                <th>اسم الدورة</th>
                <th>مسجل الدورة</th>
                <th>تاريخ البدء</th>
                <th>الحالة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var course in Model)
                {
                    <tr>
                        <td>
                            <div style="font-size: 1.05rem;">@course.Title</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted); font-weight: normal;">ID: #@course.Id</div>
                        </td>
                        <td>
                            @course.RegistrarName <br>
                            <span style="color: var(--text-muted); font-size: 0.85rem; font-weight: normal;"><i class="fa-brands fa-whatsapp"></i> @course.RegistrarWhatsApp</span>
                        </td>
                        <td style="color: var(--text-muted); font-weight: 500;">@course.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (course.Status == AbstractionCenter.Models.Entities.CourseStatus.OpenForRegistration)
                            {
                                <span class="badge badge-open">مفتوحة</span>
                            }
                            else
                            {
                                <span class="badge badge-closed">مغلقة / قيد التنفيذ</span>
                            }
                        </td>
                        <td>
                            <a href="#" style="color: var(--sidebar-active-bg); background: rgba(67, 24, 255, 0.1); padding: 8px 15px; border-radius: 10px; font-size: 0.85rem; transition: 0.3s;"><i class="fa-solid fa-pen"></i> تعديل</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" style="text-align: center; padding: 40px; color: var(--text-muted);">لا توجد دورات مسجلة حالياً.</td></tr>
            }
        </tbody>
    </table>
</div>
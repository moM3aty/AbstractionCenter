@model AbstractionCenter.Models.Entities.InstructorApplication
@{
    ViewData["Title"] = "انضم كمدرب / محاضر";
}

<style>
    .join-hero {
        background: linear-gradient(135deg, var(--primary-color), #1e293b);
        padding: 160px 0 100px;
        text-align: center;
        color: white;
        position: relative;
    }

    .join-form-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 60px;
        box-shadow: var(--shadow-premium);
        max-width: 900px;
        margin: -60px auto 100px;
        position: relative;
        z-index: 10;
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-top: 6px solid var(--secondary-color);
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-weight: 800;
            color: var(--primary-color);
            font-size: 1.05rem;
        }

    .form-control {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        font-family: inherit;
        font-size: 1rem;
        background: #f8fafc;
        transition: 0.3s;
        color: var(--primary-color);
    }

        .form-control:focus {
            outline: none;
            border-color: var(--secondary-color);
            background: white;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        }

    .file-upload-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

        .file-upload-wrapper i {
            position: absolute;
            left: 20px;
            color: var(--secondary-color);
            font-size: 1.2rem;
            pointer-events: none;
        }

        .file-upload-wrapper input {
            padding-left: 50px;
        }

    .btn-submit-join {
        background: linear-gradient(135deg, var(--secondary-color), #fef08a);
        color: var(--primary-color);
        border: none;
        padding: 20px;
        width: 100%;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.2rem;
        cursor: pointer;
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.3);
        transition: all 0.4s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 30px;
    }

        .btn-submit-join:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(212, 175, 55, 0.5);
        }

    @@media (max-width: 768px) {
        .join-form-card

    {
        padding: 40px 20px;
    }

    }
</style>

<section class="join-hero">
    <div class="container">
        <h1 style="font-size: 3.5rem; font-weight: 900; margin-bottom: 20px;">انضم إلى <span style="color: var(--secondary-color);">نخبة الخبراء</span></h1>
        <p style="color: #cbd5e1; font-size: 1.2rem; max-width: 700px; margin: 0 auto;">شارك معرفتك وخبراتك مع آلاف الطلاب، وكن جزءاً من قصة نجاحهم في مسيرتهم المهنية.</p>
    </div>
</section>

<div class="container">
    <div class="join-form-card">
        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background: rgba(16, 185, 129, 0.1); color: #059669; padding: 25px; border-radius: 16px; margin-bottom: 35px; font-weight: 900; text-align: center; border: 2px solid rgba(16, 185, 129, 0.3); font-size: 1.1rem;">
                <i class="fa-solid fa-circle-check" style="font-size: 2rem; display: block; margin-bottom: 10px;"></i>
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="JoinAsInstructor" method="post" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
                <div class="form-group">
                    <label>الاسم بالكامل</label>
                    <input asp-for="FullName" class="form-control" placeholder="أدخل اسمك الرباعي..." required />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>البريد الإلكتروني</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" required />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
                <div class="form-group">
                    <label>رقم الهاتف / الواتساب</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="مثال: 01000000000" required />
                </div>
                <div class="form-group">
                    <label>التخصص الدقيق</label>
                    <input asp-for="Specialization" class="form-control" placeholder="مثال: هندسة البرمجيات، إدارة أعمال..." required />
                </div>
            </div>

            <div class="form-group">
                <label>الصورة الشخصية (تظهر للطلاب)</label>
                <div class="file-upload-wrapper">
                    <input asp-for="ProfilePictureFile" type="file" class="form-control" accept="image/*" required />
                    <i class="fa-solid fa-image"></i>
                </div>
            </div>

            <div class="form-group">
                <label>السيرة الذاتية (CV) بصيغة PDF</label>
                <div class="file-upload-wrapper">
                    <input asp-for="CVFile" type="file" class="form-control" accept=".pdf" required />
                    <i class="fa-solid fa-file-pdf"></i>
                </div>
            </div>

            <button type="submit" class="btn-submit-join">
                إرسال الطلب الآن <i class="fa-solid fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>
@using Microsoft.AspNetCore.Localization
@model AbstractionCenter.Models.Entities.InstructorApplication
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isRtl = requestCulture?.RequestCulture.UICulture.Name == "ar" || requestCulture?.RequestCulture.UICulture.Name == null;
    ViewData["Title"] = isRtl ? "انضم كمدرب / محاضر" : "Join as an Instructor";
}

<style>
    .join-hero {
        background: linear-gradient(135deg, var(--primary-color), #1e293b);
        padding: 160px 0 100px;
        text-align: center;
        color: white;
        position: relative;
    }

    .join-form-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 60px;
        box-shadow: var(--shadow-premium);
        max-width: 900px;
        margin: -60px auto 100px;
        position: relative;
        z-index: 10;
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-top: 6px solid var(--secondary-color);
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-weight: 800;
            color: var(--primary-color);
            font-size: 1.05rem;
        }

    .form-control {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        font-family: inherit;
        font-size: 1rem;
        background: #f8fafc;
        transition: 0.3s;
        color: var(--primary-color);
    }

        .form-control:focus {
            outline: none;
            border-color: var(--secondary-color);
            background: white;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        }

    .file-upload-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

        .file-upload-wrapper i {
            position: absolute;
            @(isRtl ? "left" : "right") : 20px;
            color: var(--secondary-color);
            font-size: 1.2rem;
            pointer-events: none;
        }

        .file-upload-wrapper input {
            padding- @(isRtl ? "left" : "right") : 50px;
        }

    /* --- CAPTCHA Styles --- */
    .captcha-container {
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        padding: 20px;
        border-radius: 16px;
        margin-top: 30px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .captcha-box {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .captcha-canvas {
        background: white;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        letter-spacing: 5px;
        flex-shrink: 0; /* منع الانضغاط */
    }

    .btn-refresh-captcha {
        background: var(--primary-color);
        color: var(--secondary-color);
        border: none;
        width: 50px;
        height: 50px;
        border-radius: 10px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: 0.3s;
        flex-shrink: 0; /* منع الانضغاط */
    }

        .btn-refresh-captcha:hover {
            background: var(--secondary-color);
            color: var(--primary-color);
            transform: rotate(180deg);
        }

    .btn-submit-join {
        background: linear-gradient(135deg, var(--secondary-color), #fef08a);
        color: var(--primary-color);
        border: none;
        padding: 20px;
        width: 100%;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.2rem;
        cursor: pointer;
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.3);
        transition: all 0.4s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 30px;
    }

        .btn-submit-join:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(212, 175, 55, 0.5);
        }

    /* === Media Queries === */
    @@media (max-width: 768px) {
        .join-hero {
            padding: 120px 0 80px;
        }

            .join-hero h1 {
                font-size: 2.2rem !important;
            }

            .join-hero p {
                font-size: 1.1rem !important;
                padding: 0 15px;
            }

        .join-form-card {
            padding: 30px 20px;
            margin: -40px auto 60px;
        }

        .form-row {
            grid-template-columns: 1fr;
            gap: 0;
        }

        .btn-submit-join {
            font-size: 1.1rem;
            padding: 15px;
        }

        .captcha-box {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<section class="join-hero">
    <div class="container">
        <h1 style="font-size: 3.5rem; font-weight: 900; margin-bottom: 20px; color: #fff;">@(isRtl ? "انضم إلى" : "Join Our") <span style="color: var(--secondary-color);">@(isRtl ? "نخبة الخبراء" : "Elite Experts")</span></h1>
        <p style="color: #cbd5e1; font-size: 1.2rem; max-width: 700px; margin: 0 auto;">@(isRtl ? "شارك معرفتك وخبراتك مع آلاف الطلاب، وكن جزءاً من قصة نجاحهم في مسيرتهم المهنية." : "Share your knowledge and expertise with thousands of students, and be part of their career success story.")</p>
    </div>
</section>

<div class="container">
    <div class="join-form-card">
        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background: rgba(16, 185, 129, 0.1); color: #059669; padding: 25px; border-radius: 16px; margin-bottom: 35px; font-weight: 900; text-align: center; border: 2px solid rgba(16, 185, 129, 0.3); font-size: 1.1rem;">
                <i class="fa-solid fa-circle-check" style="font-size: 2rem; display: block; margin-bottom: 10px;"></i>
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="JoinAsInstructor" method="post" enctype="multipart/form-data" id="instructorForm">
            <div class="form-row">
                <div class="form-group">
                    <label>@(isRtl ? "الاسم بالكامل" : "Full Name")</label>
                    <input asp-for="FullName" class="form-control" placeholder="@(isRtl ? "أدخل اسمك الرباعي..." : "Enter your full name...")" required />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>@(isRtl ? "البريد الإلكتروني" : "Email Address")</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" required dir="ltr" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>@(isRtl ? "رقم الهاتف / الواتساب" : "Phone / WhatsApp Number")</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="01000000000" required dir="ltr" />
                </div>
                <div class="form-group">
                    <label>@(isRtl ? "التخصص الدقيق" : "Specialization")</label>
                    <input asp-for="Specialization" class="form-control" placeholder="@(isRtl ? "مثال: هندسة البرمجيات، إدارة أعمال..." : "e.g., Software Engineering, Business...")" required />
                </div>
            </div>

            <div class="form-group">
                <label>@(isRtl ? "الصورة الشخصية (تظهر للطلاب)" : "Profile Picture (Visible to students)")</label>
                <div class="file-upload-wrapper">
                    <input asp-for="ProfilePictureFile" type="file" class="form-control" accept="image/*" required />
                    <i class="fa-solid fa-image"></i>
                </div>
            </div>

            <div class="form-group">
                <label>@(isRtl ? "السيرة الذاتية (CV) بصيغة PDF" : "Resume (CV) in PDF Format")</label>
                <div class="file-upload-wrapper">
                    <input asp-for="CVFile" type="file" class="form-control" accept=".pdf" required />
                    <i class="fa-solid fa-file-pdf"></i>
                </div>
            </div>

            <!-- وحدة التحقق الأمني CAPTCHA -->
            <div class="captcha-container">
                <label style="font-weight: 800; color: var(--primary-color); margin: 0;">
                    <i class="fa-solid fa-shield-halved" style="color: var(--secondary-color);"></i> @(isRtl ? "تحقق أمني (للأمان)" : "Security Check")
                </label>
                <p style="font-size: 0.9rem; color: #64748b; margin: 0 0 10px 0;">@(isRtl ? "يرجى كتابة الحروف والأرقام الظاهرة في الصورة أدناه لتأكيد أنك لست روبوتاً." : "Please type the characters shown in the image below.")</p>

                <div class="captcha-box">
                    <canvas id="captchaCanvas" width="200" height="60" class="captcha-canvas"></canvas>
                    <button type="button" onclick="generateCaptcha()" class="btn-refresh-captcha" title="@(isRtl ? "تغيير الرمز" : "Refresh")">
                        <i class="fa-solid fa-arrows-rotate"></i>
                    </button>
                    <input type="text" id="captchaInput" class="form-control" placeholder="@(isRtl ? "أدخل الرمز هنا..." : "Enter code here...")" required style="max-width: 250px; text-transform: uppercase;" autocomplete="off" />
                </div>
                <span id="captchaError" style="display: none; color: #ef4444; font-weight: bold; font-size: 0.95rem;">
                    <i class="fa-solid fa-circle-exclamation"></i> @(isRtl ? "الرمز غير صحيح، يرجى المحاولة مرة أخرى." : "Incorrect code, please try again.")
                </span>
            </div>

            <button type="submit" class="btn-submit-join">
                @(isRtl ? "إرسال الطلب الآن" : "Submit Application Now") <i class="fa-solid fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let currentCaptchaCode = "";

        function generateCaptcha() {
            const canvas = document.getElementById('captchaCanvas');
            const ctx = canvas.getContext('2d');

            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            const chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
            currentCaptchaCode = "";
            for (let i = 0; i < 5; i++) {
                currentCaptchaCode += chars.charAt(Math.floor(Math.random() * chars.length));
            }

            for(let i = 0; i < 7; i++) {
                ctx.beginPath();
                ctx.moveTo(Math.random() * canvas.width, Math.random() * canvas.height);
                ctx.lineTo(Math.random() * canvas.width, Math.random() * canvas.height);
                ctx.strokeStyle = '#cbd5e1';
                ctx.lineWidth = 2;
                ctx.stroke();
            }

            ctx.font = 'bold 30px "Courier New", monospace';
            ctx.fillStyle = '#0b1120';
            ctx.textBaseline = 'middle';

            for (let i = 0; i < currentCaptchaCode.length; i++) {
                ctx.save();
                ctx.translate(30 + (i * 35), 30);
                ctx.rotate((Math.random() - 0.5) * 0.4);
                ctx.fillText(currentCaptchaCode[i], -10, 0);
                ctx.restore();
            }
        }

        document.addEventListener("DOMContentLoaded", generateCaptcha);

        document.getElementById('instructorForm').addEventListener('submit', function(e) {
            const inputVal = document.getElementById('captchaInput').value.toUpperCase();

            if (inputVal !== currentCaptchaCode) {
                e.preventDefault();
                document.getElementById('captchaError').style.display = 'block';
                document.getElementById('captchaInput').value = '';
                document.getElementById('captchaInput').focus();
                generateCaptcha();
            } else {
                document.getElementById('captchaError').style.display = 'none';
            }
        });
    </script>
}
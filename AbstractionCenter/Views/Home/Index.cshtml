@using Microsoft.AspNetCore.Localization
@model IEnumerable<AbstractionCenter.Models.Entities.ApplicationUser>
@inject AbstractionCenter.Data.ApplicationDbContext DbContext
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isRtl = requestCulture?.RequestCulture.UICulture.Name == "ar" || requestCulture?.RequestCulture.UICulture.Name == null;
    ViewData["Title"] = isRtl ? "الرئيسية" : "Home";

    var allSettings = DbContext.SiteSettings.ToList();
    var settingsDict = allSettings.ToDictionary(s => s.Key, s => s);
    string GetSetting(string key, string fallbackAr, string fallbackEn)
    {
        if (settingsDict.ContainsKey(key))
        {
            var setting = settingsDict[key];
            if (isRtl) return setting.Value;
            return !string.IsNullOrEmpty(setting.ValueEn) ? setting.ValueEn : setting.Value;
        }
        return isRtl ? fallbackAr : fallbackEn;
    }
}

<style>
    .hero-premium {
        padding: 160px 0 120px;
        min-height: 90vh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
        background-color: var(--primary-color);
    }

        .hero-premium::before {
            content: '';
            position: absolute;
            top: -150px;
            right: -100px;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            filter: blur(60px);
        }

        .hero-premium::after {
            content: '';
            position: absolute;
            bottom: -100px;
            left: -100px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            filter: blur(60px);
        }

    .hero-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 60px;
        align-items: center;
        position: relative;
        z-index: 10;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 20px;
        background: rgba(212, 175, 55, 0.1);
        color: var(--secondary-color);
        border-radius: 30px;
        font-weight: 800;
        margin-bottom: 25px;
        border: 1px solid rgba(212, 175, 55, 0.3);
        font-size: 0.95rem;
    }

    .hero-title {
        font-size: 4.5rem;
        font-weight: 900;
        line-height: 1.2;
        margin-bottom: 25px;
        color: white;
    }

        .hero-title span {
            background: linear-gradient(to left, var(--secondary-color), #fef08a);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-subtitle {
        font-size: 1.25rem;
        color: #cbd5e1;
        margin-bottom: 45px;
        line-height: 1.8;
        max-width: 90%;
    }

    .hero-buttons {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        justify-content: @(isRtl ? "flex-start" : "flex-start");
    }

    .hero-image-wrapper {
        position: relative;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        border: 1px solid rgba(212, 175, 55, 0.3);
        transform: perspective(1000px) rotateY( @(isRtl ? "-5deg" : "5deg") );
        transition: transform 0.5s ease;
    }

        .hero-image-wrapper:hover {
            transform: perspective(1000px) rotateY(0deg);
        }

        .hero-image-wrapper img {
            width: 100%;
            height: 600px;
            object-fit: cover;
            display: block;
        }

        .hero-image-wrapper .overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(11,17,32,0.8), transparent);
        }

    .features-section {
        padding: 120px 0;
        background: #f8fafc;
        position: relative;
    }

    .feature-card {
        background: white;
        padding: 50px 40px;
        border-radius: var(--radius-lg);
        text-align: center;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(11, 17, 32, 0.05);
        transition: all 0.4s ease;
    }

        .feature-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 25px 50px -12px rgba(11, 17, 32, 0.1);
            border-color: var(--secondary-color);
        }

    .feature-icon {
        width: 90px;
        height: 90px;
        background: rgba(212, 175, 55, 0.1);
        color: var(--secondary-color);
        border-radius: 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 30px;
        transform: rotate(10deg);
        transition: 0.4s;
    }

    .feature-card:hover .feature-icon {
        transform: rotate(0deg) scale(1.1);
        background: var(--secondary-color);
        color: var(--primary-color);
    }

    .feature-card h3 {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--primary-color);
        margin-bottom: 15px;
    }

    .feature-card p {
        color: #64748b;
        line-height: 1.7;
        font-size: 1.05rem;
    }

    /* --- Professional Expert Cards Styles --- */
    .team-section {
        padding: 120px 0;
        background: white;
        position: relative;
    }

    .expert-card {
        background: #ffffff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(11, 17, 32, 0.05);
        border: 1px solid #e2e8f0;
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
    }

        .expert-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 30px 60px -10px rgba(11, 17, 32, 0.15);
            border-color: var(--secondary-color);
        }

    .expert-img-box {
        position: relative;
        height: 350px;
        overflow: hidden;
        background: var(--primary-color);
    }

        .expert-img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
        }

    .expert-card:hover .expert-img-box img {
        transform: scale(1.08);
    }

    .expert-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(11,17,32,0.98) 0%, rgba(11,17,32,0.4) 50%, transparent 100%);
    }

    .expert-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255, 255, 255, 0.95);
        color: var(--primary-color);
        padding: 6px 16px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 0.8rem;
        backdrop-filter: blur(10px);
        z-index: 2;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .expert-badge i {
            color: var(--secondary-color);
        }

    .expert-info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 30px 25px;
        z-index: 10;
        text-align: center;
    }

    .expert-name {
        color: white;
        font-size: 1.5rem;
        font-weight: 900;
        margin-bottom: 5px;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }

    .expert-spec {
        color: var(--secondary-color);
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0;
    }

    .cta-section {
        padding: 80px 0;
        background: white;
    }

    .cta-card {
        background: linear-gradient(135deg, var(--primary-color), #1e293b);
        border-radius: 30px;
        overflow: hidden;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        box-shadow: 0 25px 50px -12px rgba(11, 17, 32, 0.3);
        border: 1px solid rgba(212, 175, 55, 0.2);
    }

    .cta-content {
        padding: 80px 60px;
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .cta-content h2 {
            font-size: 2.8rem;
            font-weight: 900;
            margin-bottom: 20px;
            color: var(--secondary-color);
        }

        .cta-content p {
            font-size: 1.2rem;
            color: #cbd5e1;
            margin-bottom: 35px;
            line-height: 1.8;
        }

    .cta-image {
        position: relative;
    }

        .cta-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.8;
        }

        .cta-image::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to @(isRtl ? "right" : "left"), #1e293b, transparent);
        }

    /* === Media Queries للموبايل === */
    @@media (max-width: 992px) {
        .hero-grid {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .hero-title {
            font-size: 3.5rem;
        }

        .hero-subtitle {
            max-width: 100%;
            margin: 0 auto 40px;
        }

        .hero-buttons {
            justify-content: center;
        }

        .hero-image-wrapper {
            transform: none;
        }

        .cta-card {
            grid-template-columns: 1fr;
        }

        .cta-image {
            display: none;
        }

        .cta-content {
            text-align: center;
            padding: 50px 30px;
        }
    }

    @@media (max-width: 768px) {
        .hero-premium {
            padding: 120px 0 60px;
        }

        .hero-title {
            font-size: 2.5rem;
        }

        .hero-subtitle {
            font-size: 1.1rem;
        }

        .hero-badge {
            font-size: 0.85rem;
            padding: 6px 15px;
        }

        .hero-image-wrapper img {
            height: 350px;
        }

        .features-section {
            padding: 60px 0;
        }

            .features-section h2 {
                font-size: 2rem !important;
            }

        .team-section {
            padding: 60px 0;
        }

            .team-section h2 {
                font-size: 2rem !important;
            }

        .cta-section {
            padding: 40px 0;
        }

        .cta-content h2 {
            font-size: 2rem;
        }
    }
</style>

<section class="hero-premium">
    <div class="container hero-grid">
        <div class="hero-text">
            <div class="hero-badge">
                <i class="fa-solid fa-crown"></i> @GetSetting("HeroBadge", "منصة الكفاءات العربية الأولى", "The Premier Capability Platform")
            </div>
            <h1 class="hero-title">
                @GetSetting("HeroTitle", "نصنع قادة المستقبل في", "We Build Future Leaders at") <br>
                <span>@GetSetting("SiteName", "أبستراكشن", "Abstraction")</span>
            </h1>
            <p class="hero-subtitle">
                @GetSetting("HeroSubtitle", "رؤية طموحة لتمكين الشباب بالمهارات التقنية والإدارية الحديثة. نجمع بين أصالة القيم وحداثة التكنولوجيا لنضعك على طريق النجاح.", "An ambitious vision to empower youth with modern technical and administrative skills. We combine authentic values with modern technology to put you on the path to success.")
            </p>
            <div class="hero-buttons">
                <a href="/Courses/Open" class="btn btn-primary" style="font-size: 1.15rem; padding: 18px 40px;">
                    @(isRtl ? "استكشف برامجنا" : "Explore Programs") <i class="fa-solid @(isRtl ? "fa-arrow-left" : "fa-arrow-right")"></i>
                </a>
                <a href="/Home/About" class="btn btn-outline" style="border-color: rgba(255,255,255,0.3); color: white; font-size: 1.15rem; padding: 18px 40px;">
                    @(isRtl ? "تعرف علينا" : "Learn About Us") <i class="fa-solid fa-play"></i>
                </a>
            </div>
        </div>

        <div class="hero-image-wrapper">
            <img src="@GetSetting("HeroImage", "https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1920&q=80", "https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1920&q=80")" alt="Hero" />
            <div class="overlay"></div>
        </div>
    </div>
</section>

<section class="features-section">
    <div class="container">
        <div style="text-align: center; margin-bottom: 70px; max-width: 800px; margin-left: auto; margin-right: auto;">
            <h2 style="font-size: 2.8rem; color: var(--primary-color); margin-bottom: 20px; font-weight: 900;">@GetSetting("FeaturesTitle", "لماذا نحن خيارك الأفضل؟", "Why Choose Us?")</h2>
            <p style="color: #64748b; font-size: 1.2rem; line-height: 1.8;">@GetSetting("FeaturesSubtitle", "نقدم تجربة تعليمية فريدة صُممت لتلبي احتياجات سوق العمل بمعايير جودة عالمية.", "We offer a unique educational experience designed to meet market needs with global quality standards.")</p>
        </div>

        <div class="grid-3">
            <div class="feature-card">
                <div class="feature-icon"><i class="fa-solid fa-laptop-code"></i></div>
                <h3>@GetSetting("F1_Title", "أصالة وابتكار", "Originality & Innovation")</h3>
                <p>@GetSetting("F1_Desc", "محتوى تدريبي متطور يُقدم بأحدث أساليب التكنولوجيا والذكاء الاصطناعي.", "Advanced training content delivered with the latest technology and AI methods.")</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;"><i class="fa-solid fa-user-tie"></i></div>
                <h3>@GetSetting("F2_Title", "نخبة الخبراء", "Elite Experts")</h3>
                <p>@GetSetting("F2_Desc", "تتلمذ على يد قامات مهنية تنقل لك خبراتها الحقيقية من سوق العمل.", "Learn from professional figures who transfer their real market experiences to you.")</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon" style="background: rgba(16, 185, 129, 0.1); color: #10b981;"><i class="fa-solid fa-certificate"></i></div>
                <h3>@GetSetting("F3_Title", "شهادات موثقة", "Certified Credentials")</h3>
                <p>@GetSetting("F3_Desc", "احصل على شهادات إتمام قابلة للتحقق الفوري تدعم سيرتك الذاتية.", "Earn verifiable completion certificates to boost your resume.")</p>
            </div>
        </div>
    </div>
</section>

<section class="team-section">
    <div class="container">
        <div style="text-align: center; margin-bottom: 60px; max-width: 800px; margin-left: auto; margin-right: auto;">
            <h2 style="font-size: 2.8rem; color: var(--primary-color); font-weight: 900; margin-bottom: 15px;">@(isRtl ? "نخبة الخبراء" : "Our Elite Experts")</h2>
            <div style="width: 60px; height: 4px; background: var(--secondary-color); margin: 0 auto 20px; border-radius: 2px;"></div>
            <p style="color: #64748b; font-size: 1.15rem; line-height: 1.8;">
                @(isRtl ? "يضم مركز ابستراكشن فريقًا من المدربين والمتخصصين ذوي الخبرة العميقة في مجالات أكاديمية وتقنية متعددة، لنقل خبراتهم الحقيقية إليك." : "Abstraction Center features a team of highly experienced trainers and specialists across various academic and technical fields, ready to transfer their real-world expertise to you.")
            </p>
        </div>

        <div class="grid-3">
            @if (Model != null && Model.Any())
            {
                foreach (var instructor in Model)
                {
                    <div class="expert-card" style="width:30%;">
                        <div class="expert-badge"><i class="fa-solid fa-star"></i> @(isRtl ? "خبير معتمد" : "Certified")</div>
                        <div class="expert-img-box">
                            @{
                                string safeName = !string.IsNullOrEmpty(instructor.FullName) ? instructor.FullName : "Expert";
                                string picUrl = string.IsNullOrEmpty(instructor.ProfilePicture)
                                ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(safeName)}&background=0b1120&color=d4af37&size=512&font-size=0.33"
                                : (instructor.ProfilePicture.StartsWith("http") ? instructor.ProfilePicture : "/" + instructor.ProfilePicture.TrimStart('/'));
                            }
                            <img src="@picUrl" alt="@instructor.FullName" onerror="this.onerror=null;this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(safeName)&background=0b1120&color=d4af37&size=512&font-size=0.33';" />
                            <div class="expert-overlay"></div>

                            <div class="expert-info">
                                <h3 class="expert-name">@(string.IsNullOrEmpty(instructor.FullName) ? "مدرب الأكاديمية" : instructor.FullName)</h3>
                                <p class="expert-spec">@(string.IsNullOrEmpty(instructor.Specialization) ? (isRtl ? "مدرب وأكاديمي" : "Academic Trainer") : instructor.Specialization)</p>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="grid-column: 1 / -1; text-align: center; color: #94a3b8; padding: 40px;">
                    <i class="fa-solid fa-users" style="font-size: 3rem; margin-bottom: 15px; opacity: 0.5;"></i>
                    <p>@(isRtl ? "سيتم عرض فريق المدربين قريباً." : "The training team will be displayed soon.")</p>
                </div>
            }
        </div>

        <div style="text-align: center; margin-top: 60px;">
            <a href="/Home/Staff" class="btn btn-outline" style="padding: 16px 45px; font-size: 1.15rem; border-width: 2px;">
                @(isRtl ? "تعرف على جميع الخبراء" : "Meet All Experts") <i class="fa-solid @(isRtl ? "fa-arrow-left" : "fa-arrow-right")" style="margin-@(isRtl ? "right" : "left"): 8px;"></i>
            </a>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <div class="cta-card">
            <div class="cta-content">
                <h2>@GetSetting("CTATitle", "جاهز للانطلاق نحو القمة؟", "Ready to Reach the Top?")</h2>
                <p>@GetSetting("CTASubtitle", "لا تضيع المزيد من الوقت. انضم إلى عائلتنا اليوم، وابدأ في بناء قدراتك لكي تكون الخيار الأول في سوق العمل التنافسي.", "Don't waste any more time. Join our family today and start building your capabilities to be the first choice in the competitive job market.")</p>
                <div>
                    <a href="/Courses/Open" class="btn" style="background: white; color: var(--primary-color); padding: 18px 45px; font-size: 1.2rem; font-weight: 900; border-radius: 50px;">
                        @(isRtl ? "تصفح الدورات المتاحة" : "Browse Available Courses") <i class="fa-solid fa-rocket" style="margin-@(isRtl ? "right" : "left"): 8px;"></i>
                    </a>
                </div>
            </div>
            <div class="cta-image">
                <img src="@GetSetting("CTAImage", "https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=800&q=80", "https://images.unsplash.com/photo-1519389950473-47ba0277781c?auto=format&fit=crop&w=800&q=80")" alt="Join Us" />
            </div>
        </div>
    </div>
</section>
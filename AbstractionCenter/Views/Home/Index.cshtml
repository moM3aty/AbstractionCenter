@{
    ViewData["Title"] = "الرئيسية";
}

<!-- Hero Section -->
<section class="hero">
    <div class="container hero-content">
        <h1>مستقبلك المهني يبدأ من <br>مركز ابستراكشن</h1>
        <p>المنصة التعليمية الأولى لبناء القدرات وتطوير المهارات. نقدم دورات تدريبية متقدمة على يد نخبة من الخبراء وهيئة التدريس الأكفاء، بتجربة تعليمية تجمع بين الجانب النظري والتطبيق العملي.</p>
        <div style="display: flex; gap: 20px; justify-content: center; margin-top: 30px;">
            <a href="/Courses/Open" class="btn btn-primary" style="padding: 15px 40px; font-size: 1.2rem;">تصفح الدورات</a>
            <a href="/Home/About" class="btn btn-outline" style="padding: 15px 40px; font-size: 1.2rem;">تعرف علينا</a>
        </div>
    </div>
</section>

<!-- Features Section -->
<section style="padding: 80px 0;">
    <div class="container">
        <div class="section-title">
            <h2>لماذا تختار ابستراكشن؟</h2>
            <p>مميزات تجعلنا خيارك الأول لتطوير مهاراتك</p>
        </div>

        <div class="grid-3">
            <!-- Feature 1 -->
            <div class="glass-card">
                <div class="card-icon">
                    <i class="fa-solid fa-chalkboard-user"></i>
                </div>
                <h3>هيئة تدريس متميزة</h3>
                <p>نخبة من الأكاديميين والخبراء في سوق العمل يقدمون لك خلاصة خبراتهم بأساليب حديثة.</p>
            </div>

            <!-- Feature 2 -->
            <div class="glass-card">
                <div class="card-icon">
                    <i class="fa-solid fa-laptop-code"></i>
                </div>
                <h3>منصة طلابية متكاملة</h3>
                <p>تابع تقدمك، ارفع واجباتك، وتواصل مع مسجل الدورة بسهولة تامة عبر منصتنا التفاعلية.</p>
            </div>

            <!-- Feature 3 -->
            <div class="glass-card">
                <div class="card-icon">
                    <i class="fa-solid fa-certificate"></i>
                </div>
                <h3>شهادات معتمدة</h3>
                <p>احصل على شهادة موثقة برقم تسلسلي يمكن التحقق منها إلكترونياً فور إتمامك للدورة.</p>
            </div>
        </div>
    </div>
</section>

<!-- Quick Stats / Banner Section -->
<section style="background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)); color: white; padding: 60px 0; border-radius: 30px; margin: 40px auto; max-width: 1200px; box-shadow: var(--shadow-premium);">
    <div class="container" style="display: flex; justify-content: space-around; flex-wrap: wrap; text-align: center;">
        <div style="margin: 20px;">
            <h2 style="font-size: 3rem; font-weight: 900; color: var(--accent-color);">+50</h2>
            <p style="font-size: 1.2rem;">دورة تدريبية</p>
        </div>
        <div style="margin: 20px;">
            <h2 style="font-size: 3rem; font-weight: 900; color: var(--accent-color);">+1000</h2>
            <p style="font-size: 1.2rem;">طالب مسجل</p>
        </div>
        <div style="margin: 20px;">
            <h2 style="font-size: 3rem; font-weight: 900; color: var(--accent-color);">+20</h2>
            <p style="font-size: 1.2rem;">مسار تخصصي</p>
        </div>
    </div>
</section>
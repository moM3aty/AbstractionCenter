@using Microsoft.AspNetCore.Localization
@inject AbstractionCenter.Data.ApplicationDbContext DbContext
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isRtl = requestCulture?.RequestCulture.UICulture.Name == "ar" || requestCulture?.RequestCulture.UICulture.Name == null;
    ViewData["Title"] = isRtl ? "المسارات التدريبية" : "Training Tracks";

    var allSettings = DbContext.SiteSettings.ToList();
    var settingsDict = allSettings.ToDictionary(s => s.Key, s => s);
    string GetSetting(string key, string fallbackAr, string fallbackEn)
    {
        if (settingsDict.ContainsKey(key))
        {
            var setting = settingsDict[key];
            if (isRtl) return setting.Value;
            return !string.IsNullOrEmpty(setting.ValueEn) ? setting.ValueEn : setting.Value;
        }
        return isRtl ? fallbackAr : fallbackEn;
    }
}

<style>
    .tracks-hero {
        background: linear-gradient(135deg, var(--primary-color), #1e293b);
        position: relative;
        padding: 160px 0 100px;
        text-align: center;
        color: white;
        overflow: hidden;
    }

        .tracks-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23d4af37\' fill-opacity=\'0.05\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
        }

    .track-icon-wrapper {
        width: 90px;
        height: 90px;
        background: rgba(212, 175, 55, 0.1);
        border: 1px solid rgba(212, 175, 55, 0.3);
        border-radius: 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: var(--secondary-color);
        margin: 0 auto 25px;
        transition: transform 0.4s ease, background 0.4s ease;
    }

    .glass-card:hover .track-icon-wrapper {
        transform: rotate(10deg) scale(1.1);
        background: var(--secondary-color);
        color: var(--primary-color);
    }
</style>

<section class="tracks-hero">
    <div class="container" style="position: relative; z-index: 10;">
        <h1 style="font-size: 3.5rem; color: white; margin-bottom: 20px; font-weight: 900;">@GetSetting("Tracks_HeroTitle", "المسارات التدريبية", "Training Tracks")</h1>
        <p style="color: #cbd5e1; font-size: 1.2rem; max-width: 700px; margin: 0 auto;">@GetSetting("Tracks_HeroSubtitle", "نقدم مجموعة متنوعة من المسارات التي تغطي أهم متطلبات سوق العمل الحالي والمستقبلي، مصممة بعناية فائقة.", "We offer a variety of tracks covering the most important requirements of the current and future job market, designed with great care.")</p>
    </div>
</section>

<section style="padding: 100px 0; background: #f8fafc;">
    <div class="container">
        <div class="grid-3">
            <div class="glass-card" style="text-align: center; padding: 50px 30px;">
                <div class="track-icon-wrapper">
                    <i class="@GetSetting("Track1_Icon", "fa-solid fa-code", "fa-solid fa-code")"></i>
                </div>
                <h3 style="color: var(--primary-color); font-weight: 900; font-size: 1.6rem; margin-bottom: 15px;">@GetSetting("Track1_Title", "هندسة البرمجيات والتقنية", "Software Engineering & Tech")</h3>
                <p style="color: #64748b; line-height: 1.8; font-size: 1.05rem;">@GetSetting("Track1_Desc", "تطوير الويب، الذكاء الاصطناعي، الأمن السيبراني، وبرمجة تطبيقات الهواتف الذكية بأحدث التقنيات.", "Web development, AI, cybersecurity, and mobile app programming with the latest technologies.")</p>
            </div>

            <div class="glass-card" style="text-align: center; padding: 50px 30px;">
                <div class="track-icon-wrapper">
                    <i class="@GetSetting("Track2_Icon", "fa-solid fa-chart-line", "fa-solid fa-chart-line")"></i>
                </div>
                <h3 style="color: var(--primary-color); font-weight: 900; font-size: 1.6rem; margin-bottom: 15px;">@GetSetting("Track2_Title", "الإدارة والأعمال", "Management & Business")</h3>
                <p style="color: #64748b; line-height: 1.8; font-size: 1.05rem;">@GetSetting("Track2_Desc", "التسويق الرقمي، إدارة المشاريع (PMP)، الموارد البشرية، وتحليل الأعمال وريادة المشاريع.", "Digital marketing, PMP, HR, business analysis, and entrepreneurship.")</p>
            </div>

            <div class="glass-card" style="text-align: center; padding: 50px 30px;">
                <div class="track-icon-wrapper">
                    <i class="@GetSetting("Track3_Icon", "fa-solid fa-language", "fa-solid fa-language")"></i>
                </div>
                <h3 style="color: var(--primary-color); font-weight: 900; font-size: 1.6rem; margin-bottom: 15px;">@GetSetting("Track3_Title", "اللغات والمهارات الناعمة", "Languages & Soft Skills")</h3>
                <p style="color: #64748b; line-height: 1.8; font-size: 1.05rem;">@GetSetting("Track3_Desc", "اللغة الإنجليزية المهنية، مهارات التواصل، القيادة، والتحضير لاجتياز المقابلات الشخصية بنجاح.", "Professional English, communication skills, leadership, and interview preparation.")</p>
            </div>
        </div>

        <div style="text-align: center; margin-top: 60px;">
            <a href="/Courses/Open" class="btn btn-primary" style="padding: 18px 40px; font-size: 1.15rem;">
                @(isRtl ? "تصفح جميع البرامج المتاحة للتسجيل" : "Browse all available programs") <i class="fa-solid @(isRtl ? "fa-arrow-left" : "fa-arrow-right")"></i>
            </a>
        </div>
    </div>
</section>
@model IEnumerable<AbstractionCenter.Models.Entities.ApplicationUser>
@{
    ViewData["Title"] = "هيئة التدريس";
}

<style>
    .staff-hero {
        background: linear-gradient(135deg, var(--primary-color), #1e293b);
        position: relative;
        padding: 160px 0 100px;
        text-align: center;
        color: white;
    }

    .staff-card {
        text-align: center;
        padding: 50px 30px;
        background: white;
        border-radius: var(--radius-lg);
        border: 1px solid #e2e8f0;
        box-shadow: var(--shadow-sm);
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }

        .staff-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 120px;
            background: linear-gradient(135deg, rgba(212,175,55,0.1), transparent);
            z-index: 0;
        }

        .staff-card:hover {
            transform: translateY(-10px);
            box-shadow: var(--shadow-premium);
            border-color: var(--secondary-color);
        }

    .staff-img {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background-color: #f1f5f9;
        margin: 0 auto 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: var(--primary-color);
        border: 4px solid var(--secondary-color);
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
        overflow: hidden;
        position: relative;
        z-index: 1;
    }

        .staff-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .staff-title {
        color: var(--secondary-color);
        font-weight: 800;
        font-size: 1.1rem;
        margin-bottom: 15px;
        position: relative;
        z-index: 1;
    }

    .staff-name {
        color: var(--primary-color);
        font-weight: 900;
        font-size: 1.6rem;
        position: relative;
        z-index: 1;
    }
</style>

<section class="staff-hero">
    <div class="container" style="position: relative; z-index: 10;">
        <div style="width: 80px; height: 80px; background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.2rem; color: var(--secondary-color); margin: 0 auto 20px;">
            <i class="fa-solid fa-user-tie"></i>
        </div>
        <h1 style="font-size: 3.5rem; font-weight: 900; margin-bottom: 20px;">نخبة من <span style="color: var(--secondary-color);">الخبراء</span></h1>
        <p style="color: #cbd5e1; font-size: 1.2rem; max-width: 700px; margin: 0 auto;">نفخر في ابستراكشن بنخبة من أفضل الخبراء الأكاديميين والمهنيين الذين ينقلون خبراتهم العملية لك لضمان أعلى جودة تعليمية.</p>
    </div>
</section>

<section style="padding: 100px 0; background: #f8fafc;">
    <div class="container">
        <div class="grid-3">
            @if (Model != null && Model.Any())
            {
                foreach (var instructor in Model)
                {
                    <div class="staff-card">
                        <div class="staff-img">
                            @if (!string.IsNullOrEmpty(instructor.ProfilePicture))
                            {
                                <img src="@instructor.ProfilePicture" alt="@instructor.FullName" />
                            }
                            else
                            {
                                <i class="fa-solid fa-user-tie"></i>
                            }
                        </div>
                        <h3 class="staff-name">@instructor.FullName</h3>
                        <div class="staff-title">@(string.IsNullOrEmpty(instructor.Specialization) ? "محاضر معتمد" : instructor.Specialization)</div>
                    </div>
                }
            }
            else
            {
                <div style="grid-column: 1/-1; text-align: center; padding: 60px; background: white; border-radius: var(--radius-lg); border: 1px dashed #e2e8f0;">
                    <i class="fa-solid fa-users-slash" style="font-size: 4rem; color: #cbd5e1; margin-bottom: 20px;"></i>
                    <h3 style="color: var(--primary-color); font-weight: 900; font-size: 1.5rem;">جاري تحديث قائمة هيئة التدريس...</h3>
                </div>
            }
        </div>
    </div>
</section>
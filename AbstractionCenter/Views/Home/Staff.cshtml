@model IEnumerable<AbstractionCenter.Models.Entities.ApplicationUser>
@{
    ViewData["Title"] = "هيئة التدريس";
}

<style>
    .staff-header {
        background: linear-gradient(135deg, var(--primary-color), #1e293b);
        position: relative;
        padding: 140px 0 80px;
        text-align: center;
        color: white;
    }

    .staff-card {
        text-align: center;
        padding: 50px 20px;
        border-top: 5px solid transparent;
        transition: all 0.4s;
    }

        .staff-card:hover {
            border-top-color: var(--secondary-color);
        }

    .staff-img {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background-color: #f1f5f9;
        margin: 0 auto 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: var(--primary-color);
        border: 4px solid var(--secondary-color);
        box-shadow: 0 10px 25px rgba(205, 164, 52, 0.3);
        overflow: hidden;
    }

        .staff-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .staff-title {
        color: var(--secondary-color);
        font-weight: 800;
        font-size: 1rem;
        margin-bottom: 15px;
    }
</style>



<!-- الهيدر كما هو موجود عندك -->
<section class="staff-header"> ... </section>

<section style="padding: 80px 0 100px; background: #f8fafc;">
    <div class="container">
        <div class="grid-3">
            @if (Model != null && Model.Any())
            {
                foreach (var instructor in Model)
                {
                    <div class="glass-card staff-card">
                        <div class="staff-img">
                            @if (!string.IsNullOrEmpty(instructor.ProfilePicture))
                            {
                                <img src="@instructor.ProfilePicture" alt="@instructor.FullName" />
                            }
                            else
                            {
                                <i class="fa-solid fa-user-tie"></i>
                            }
                        </div>
                        <h3 style="color: var(--primary-color); font-weight: 800; font-size: 1.5rem;">@instructor.FullName</h3>
                        <div class="staff-title">@(string.IsNullOrEmpty(instructor.Specialization) ? "محاضر معتمد" : instructor.Specialization)</div>
                    </div>
                }
            }
            else
            {
                <div style="grid-column: 1/-1; text-align: center; padding: 40px;">
                    <h3>جاري تحديث قائمة هيئة التدريس...</h3>
                </div>
            }
        </div>
    </div>
</section>
@inject AbstractionCenter.Data.ApplicationDbContext DbContext
@{
    ViewData["Title"] = "التحقق من الشهادة";
    var settings = DbContext.SiteSettings.ToDictionary(s => s.Key, s => s.Value);
    string GetSetting(string key, string fallback = "") => settings.ContainsKey(key) ? settings[key] : fallback;
}

<style>
    .verify-section {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--background-light), #e2e8f0);
        padding: 120px 20px 60px;
        position: relative;
        overflow: hidden;
    }

        .verify-section::before {
            content: '';
            position: absolute;
            top: -100px;
            left: -100px;
            width: 400px;
            height: 400px;
            background: rgba(205, 164, 52, 0.1);
            border-radius: 50%;
            filter: blur(60px);
        }

    .verify-box {
        background: white;
        padding: 50px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-premium);
        max-width: 650px;
        width: 100%;
        text-align: center;
        border-top: 5px solid var(--secondary-color);
        position: relative;
        z-index: 10;
    }

    .search-bar {
        display: flex;
        margin-top: 30px;
        margin-bottom: 20px;
    }

        .search-bar input {
            flex-grow: 1;
            padding: 18px 20px;
            border: 2px solid #e2e8f0;
            border-radius: 0 var(--radius-md) var(--radius-md) 0;
            font-size: 1.1rem;
            font-family: inherit;
            outline: none;
            transition: 0.3s;
        }

            .search-bar input:focus {
                border-color: var(--secondary-color);
                box-shadow: 0 0 0 4px rgba(205, 164, 52, 0.1);
            }

        .search-bar button {
            background: var(--primary-color);
            color: var(--secondary-color);
            border: none;
            padding: 0 30px;
            font-size: 1.1rem;
            border-radius: var(--radius-md) 0 0 var(--radius-md);
            cursor: pointer;
            font-family: inherit;
            font-weight: 900;
            transition: all 0.3s;
        }

            .search-bar button:hover {
                background: #1e293b;
                color: white;
            }

    .certificate-result {
        margin-top: 30px;
        padding: 30px;
        background: rgba(16, 185, 129, 0.05);
        border: 2px dashed #10b981;
        border-radius: var(--radius-md);
    }
</style>

<div class="verify-section">
    <div class="verify-box">
        <i class="fa-solid fa-shield-check" style="font-size: 4.5rem; color: var(--secondary-color); margin-bottom: 20px;"></i>
        <h1 style="color: var(--primary-color); font-size: 2.2rem; margin-bottom: 10px; font-weight: 900;">@GetSetting("Verify_HeroTitle", "التحقق من صحة الشهادة")</h1>
        <p style="color: #64748b; font-size: 1.1rem; line-height: 1.7;">@GetSetting("Verify_HeroSubtitle", "أدخل رقم الشهادة الفريد (Serial Number) للتحقق من موثوقيتها واعتمادها من مركز ابستراكشن.")</p>

        <form method="get" action="/Home/VerifyCertificate" class="search-bar">
            <input type="text" name="serialNumber" placeholder="مثال: A1B2C3D4E5" value="@ViewBag.SerialNumber" required />
            <button type="submit">تحقق الآن <i class="fa-solid fa-magnifying-glass" style="margin-right: 5px;"></i></button>
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.SerialNumber))
        {
            <!-- النتيجة الوهمية للتوضيح، سيتم ربطها بقاعدة البيانات لاحقاً -->
            <div class="certificate-result">
                <div style="width: 70px; height: 70px; background: #10b981; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 15px; box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);">
                    <i class="fa-solid fa-check"></i>
                </div>
                <h3 style="color: #10b981; margin-bottom: 15px; font-weight: 800;">شهادة معتمدة وموثقة</h3>
                <div style="text-align: right; color: var(--text-dark); line-height: 1.8; background: white; padding: 25px; border-radius: 12px; border: 1px solid #e2e8f0;">
                    <p><strong><i class="fa-solid fa-user-graduate" style="color: var(--secondary-color); width: 25px;"></i> اسم المتدرب:</strong> طالب مسجل</p>
                    <p><strong><i class="fa-solid fa-award" style="color: var(--secondary-color); width: 25px;"></i> اسم الدورة:</strong> الدورة المسجلة</p>
                    <p><strong><i class="fa-solid fa-barcode" style="color: var(--secondary-color); width: 25px;"></i> الرقم المرجعي:</strong> <span style="font-family: monospace; letter-spacing: 1px; color: var(--primary-color); font-weight: bold;">@ViewBag.SerialNumber</span></p>
                </div>
            </div>
        }
    </div>
</div>
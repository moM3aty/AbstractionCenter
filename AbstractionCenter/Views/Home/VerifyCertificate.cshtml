@inject AbstractionCenter.Data.ApplicationDbContext DbContext
@{
    ViewData["Title"] = "التحقق من الشهادة";
    var settings = DbContext.SiteSettings.ToDictionary(s => s.Key, s => s.Value);
    string GetSetting(string key, string fallback = "") => settings.ContainsKey(key) ? settings[key] : fallback;
}

<style>
    .verify-section {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--background-light), #e2e8f0);
        padding: 140px 20px 80px;
        position: relative;
        overflow: hidden;
    }

        .verify-section::before {
            content: '';
            position: absolute;
            top: -100px;
            left: -100px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            filter: blur(60px);
        }

        .verify-section::after {
            content: '';
            position: absolute;
            bottom: -100px;
            right: -100px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(11, 17, 32, 0.05) 0%, transparent 70%);
            border-radius: 50%;
            filter: blur(60px);
        }

    .verify-box {
        background: white;
        padding: 60px 50px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-premium);
        max-width: 700px;
        width: 100%;
        text-align: center;
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-top: 6px solid var(--secondary-color);
        position: relative;
        z-index: 10;
    }

    .search-bar {
        display: flex;
        margin-top: 40px;
        margin-bottom: 30px;
        box-shadow: 0 10px 25px rgba(11, 17, 32, 0.05);
        border-radius: 16px;
        overflow: hidden;
        border: 2px solid #e2e8f0;
        transition: 0.3s;
    }

        .search-bar:focus-within {
            border-color: var(--secondary-color);
            box-shadow: 0 10px 25px rgba(212, 175, 55, 0.15);
        }

        .search-bar input {
            flex-grow: 1;
            padding: 20px 25px;
            border: none;
            font-size: 1.15rem;
            font-family: inherit;
            outline: none;
            background: #f8fafc;
            color: var(--primary-color);
            font-weight: 600;
        }

        .search-bar button {
            background: var(--primary-color);
            color: var(--secondary-color);
            border: none;
            padding: 0 35px;
            font-size: 1.15rem;
            cursor: pointer;
            font-family: inherit;
            font-weight: 900;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .search-bar button:hover {
                background: #1e293b;
                color: white;
            }

    .certificate-result {
        margin-top: 40px;
        padding: 40px;
        background: rgba(16, 185, 129, 0.05);
        border: 2px dashed #10b981;
        border-radius: var(--radius-md);
        text-align: center;
    }
</style>

<div class="verify-section">
    <div class="verify-box">
        <i class="fa-solid fa-shield-check" style="font-size: 5rem; color: var(--secondary-color); margin-bottom: 25px;"></i>
        <h1 style="color: var(--primary-color); font-size: 2.5rem; margin-bottom: 15px; font-weight: 900;">@GetSetting("Verify_HeroTitle", "التحقق من صحة الشهادة")</h1>
        <p style="color: #64748b; font-size: 1.15rem; line-height: 1.8;">@GetSetting("Verify_HeroSubtitle", "أدخل رقم الشهادة الفريد (Serial Number) للتحقق من موثوقيتها واعتمادها من مركز ابستراكشن.")</p>

        <form method="get" action="/Home/VerifyCertificate" class="search-bar">
            <input type="text" name="serialNumber" placeholder="أدخل الرقم المرجعي للشهادة هنا..." value="@ViewBag.SerialNumber" required />
            <button type="submit">تحقق <i class="fa-solid fa-magnifying-glass"></i></button>
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.SerialNumber))
        {
            <div class="certificate-result">
                <div style="width: 80px; height: 80px; background: #10b981; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin: 0 auto 20px; box-shadow: 0 10px 25px rgba(16, 185, 129, 0.3);">
                    <i class="fa-solid fa-check"></i>
                </div>
                <h3 style="color: #10b981; margin-bottom: 20px; font-weight: 900; font-size: 1.6rem;">شهادة معتمدة وموثقة</h3>
                <div style="text-align: right; color: var(--primary-color); line-height: 2; background: white; padding: 30px; border-radius: 16px; border: 1px solid #e2e8f0; font-size: 1.1rem;">
                    <p style="margin-bottom: 10px;"><strong><i class="fa-solid fa-user-graduate" style="color: var(--secondary-color); width: 30px;"></i> اسم المتدرب:</strong> طالب مسجل (مثال توضيحي)</p>
                    <p style="margin-bottom: 10px;"><strong><i class="fa-solid fa-award" style="color: var(--secondary-color); width: 30px;"></i> المسار التدريبي:</strong> الدورة المسجلة (مثال توضيحي)</p>
                    <p style="margin: 0;"><strong><i class="fa-solid fa-barcode" style="color: var(--secondary-color); width: 30px;"></i> الرقم المرجعي:</strong> <span style="font-family: monospace; letter-spacing: 2px; color: var(--primary-color); font-weight: 900; background: #f8fafc; padding: 4px 10px; border-radius: 8px; border: 1px solid #e2e8f0;">@ViewBag.SerialNumber</span></p>
                </div>
            </div>
        }
    </div>
</div>
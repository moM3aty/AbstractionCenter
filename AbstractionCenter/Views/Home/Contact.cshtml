@inject AbstractionCenter.Data.ApplicationDbContext DbContext
@{
    ViewData["Title"] = "تواصل معنا";
    var allSettings = DbContext.SiteSettings.ToList();
    var settingsDict = allSettings.ToDictionary(s => s.Key, s => s.Value);

    // جلب كافة بيانات التواصل (بما فيها التي أضفتها أنت حديثاً)
    var contactInfo = allSettings.Where(s => s.Group == "Contact").ToList();

    string GetSetting(string key, string fallback = "") => settingsDict.ContainsKey(key) ? settingsDict[key] : fallback;
}

<section class="hero" style="min-height: 40vh; padding: 120px 0 50px; text-align: center; background: linear-gradient(135deg, var(--primary-color), #1e293b); color: white;">
    <div class="container hero-content">
        <div style="width: 80px; height: 80px; background: rgba(205, 164, 52, 0.1); border: 1px solid rgba(205, 164, 52, 0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.2rem; color: var(--secondary-color); margin: 0 auto 20px;">
            <i class="fa-solid fa-headset"></i>
        </div>
        <h1 style="font-size: 3.5rem; color: white; margin-bottom: 20px; font-weight: 900;">@GetSetting("Contact_HeroTitle", "تواصل معنا")</h1>
        <p style="color: #cbd5e1; font-size: 1.2rem; max-width: 600px; margin: 0 auto;">@GetSetting("Contact_HeroSubtitle")</p>
    </div>
</section>

<section style="padding: 80px 0 100px; background: #f8fafc;">
    <div class="container">

        <!-- عرض البطاقات ديناميكياً بناءً على ما أضفته في لوحة التحكم -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 50px;">
            @foreach (var info in contactInfo)
            {
                <div class="glass-card" style="text-align: center; padding: 40px 20px;">
                    @{
                        string icon = "fa-info-circle";
                        if (info.DisplayName.Contains("هاتف") || info.DisplayName.Contains("موبايل") || info.DisplayName.Contains("واتساب")) icon = "fa-phone-volume";
                        else if (info.DisplayName.Contains("بريد") || info.DisplayName.Contains("إيميل")) icon = "fa-envelope-open-text";
                        else if (info.DisplayName.Contains("عنوان") || info.DisplayName.Contains("موقع")) icon = "fa-map-location-dot";
                    }
                    <i class="fa-solid @icon" style="font-size: 2.5rem; color: var(--secondary-color); margin-bottom: 15px;"></i>
                    <h3 style="color: var(--primary-color); margin-bottom: 10px;">@info.DisplayName</h3>
                    <p style="color: #64748b; font-weight: bold; font-size: 1.1rem; direction: ltr;">@info.Value</p>
                </div>
            }
        </div>

        <div class="glass-card" style="max-width: 800px; margin: 0 auto; padding: 50px;">
            <h2 style="color: var(--primary-color); text-align: center; margin-bottom: 30px; font-weight: 800;">أرسل استفسارك مباشرة</h2>
            <form>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                    <div>
                        <label style="display: block; margin-bottom: 8px; font-weight: 700; color: var(--text-dark);">الاسم الكريم</label>
                        <input type="text" style="width: 100%; padding: 15px 20px; border: 2px solid #e2e8f0; border-radius: var(--radius-md); font-family: inherit; font-size: 1rem; background: #f8fafc;" placeholder="أدخل اسمك..." required>
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 8px; font-weight: 700; color: var(--text-dark);">البريد الإلكتروني</label>
                        <input type="email" style="width: 100%; padding: 15px 20px; border: 2px solid #e2e8f0; border-radius: var(--radius-md); font-family: inherit; font-size: 1rem; background: #f8fafc;" placeholder="name@example.com" required>
                    </div>
                </div>
                <div style="margin-bottom: 25px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 700; color: var(--text-dark);">رسالتك أو استفسارك</label>
                    <textarea rows="6" style="width: 100%; padding: 15px 20px; border: 2px solid #e2e8f0; border-radius: var(--radius-md); font-family: inherit; font-size: 1rem; background: #f8fafc; resize: vertical;" placeholder="كيف يمكننا مساعدتك؟" required></textarea>
                </div>
                <button type="button" class="btn btn-primary" style="width: 100%; font-size: 1.15rem; padding: 15px;">إرسال الرسالة <i class="fa-solid fa-paper-plane" style="margin-right: 8px;"></i></button>
            </form>
        </div>
    </div>
</section>
@using Microsoft.AspNetCore.Localization
@inject AbstractionCenter.Data.ApplicationDbContext DbContext
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isRtl = requestCulture?.RequestCulture.UICulture.Name == "ar" || requestCulture?.RequestCulture.UICulture.Name == null;
    ViewData["Title"] = isRtl ? "تواصل معنا" : "Contact Us";

    var allSettings = DbContext.SiteSettings.ToList();
    var settingsDict = allSettings.ToDictionary(s => s.Key, s => s);
    var contactInfo = allSettings.Where(s => s.Group == "Contact").ToList();
    string GetSetting(string key, string fallbackAr, string fallbackEn)
    {
        if (settingsDict.ContainsKey(key))
        {
            var setting = settingsDict[key];
            if (isRtl) return setting.Value;
            return !string.IsNullOrEmpty(setting.ValueEn) ? setting.ValueEn : setting.Value;
        }
        return isRtl ? fallbackAr : fallbackEn;
    }
}

<style>
    .contact-hero {
        background: linear-gradient(135deg, var(--primary-color), #1e293b);
        padding: 160px 0 100px;
        text-align: center;
        color: white;
        position: relative;
    }

    .contact-hero-icon {
        width: 80px;
        height: 80px;
        background: rgba(212,175,55,0.1);
        border: 1px solid rgba(212,175,55,0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        color: var(--secondary-color);
        margin: 0 auto 20px;
    }

    .contact-wrapper {
        padding: 80px 0 120px;
        background: #f8fafc;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 50px;
        align-items: start;
    }

    .info-cards {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .info-card {
        background: white;
        padding: 30px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 20px;
        transition: 0.3s;
    }

        .info-card:hover {
            transform: translateX( @(isRtl ? "-10px" : "10px") );
            border-color: var(--secondary-color);
            box-shadow: var(--shadow-md);
        }

    .info-icon {
        width: 60px;
        height: 60px;
        background: rgba(212,175,55,0.1);
        color: var(--secondary-color);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .form-card {
        background: white;
        padding: 50px;
        border-radius: 24px;
        box-shadow: var(--shadow-premium);
        border: 1px solid rgba(212,175,55,0.2);
        border-top: 5px solid var(--secondary-color);
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: block;
            font-weight: 800;
            color: var(--primary-color);
            margin-bottom: 10px;
        }

    .form-control {
        width: 100%;
        padding: 15px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 14px;
        background: #f8fafc;
        font-family: inherit;
        font-size: 1.05rem;
        transition: 0.3s;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--secondary-color);
            background: white;
            box-shadow: 0 0 0 4px rgba(212,175,55,0.1);
        }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    /* === Media Queries للموبايل === */
    @@media (max-width: 992px) {
        .contact-grid {
            grid-template-columns: 1fr;
        }

        .form-card {
            padding: 30px 20px;
        }
    }

    @@media (max-width: 768px) {
        .contact-hero {
            padding: 120px 0 60px;
        }

            .contact-hero h1 {
                font-size: 2.2rem !important;
            }

            .contact-hero p {
                font-size: 1.1rem !important;
                padding: 0 15px;
            }

        .contact-hero-icon {
            width: 70px;
            height: 70px;
            font-size: 1.8rem;
        }

        .contact-wrapper {
            padding: 60px 0;
        }

        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<section class="contact-hero">
    <div class="container" style="position: relative; z-index: 10;">
        <div class="contact-hero-icon">
            <i class="fa-solid fa-headset"></i>
        </div>
        <h1 style="font-size: 3.5rem; font-weight: 900; margin-bottom: 15px; color: #cbd5e1;">@GetSetting("Contact_HeroTitle", "يسعدنا تواصلك", "We'd Love to Hear From You")</h1>
        <p style="font-size: 1.2rem; color: #cbd5e1; max-width: 600px; margin: 0 auto;">@GetSetting("Contact_HeroSubtitle", "نحن هنا للإجابة على جميع استفساراتك ومساعدتك في اتخاذ الخطوة القادمة.", "We are here to answer all your inquiries and help you take the next step.")</p>
    </div>
</section>

<section class="contact-wrapper">
    <div class="container contact-grid">
        <div class="info-cards">
            @foreach (var info in contactInfo.Where(c => !c.Key.Contains("Hero")))
            {
                <div class="info-card">
                    @{
                        string icon = "fa-info-circle";
                        if (info.DisplayName.Contains("هاتف") || info.DisplayName.Contains("رقم") || info.DisplayName.ToLower().Contains("phone")) icon = "fa-phone-volume";
                        else if (info.DisplayName.Contains("بريد") || info.DisplayName.ToLower().Contains("email")) icon = "fa-envelope-open-text";
                        else if (info.DisplayName.Contains("عنوان") || info.DisplayName.Contains("موقع") || info.DisplayName.ToLower().Contains("address")) icon = "fa-map-location-dot";
                    }
                    <div class="info-icon"><i class="fa-solid @icon"></i></div>
                    <div>
                        <h3 style="color: var(--primary-color); font-size: 1.1rem; margin-bottom: 5px; font-weight: 800;">
                            @(isRtl? info.DisplayName: (info.DisplayName.Contains("هاتف") ? "Phone Number" : info.DisplayName.Contains("بريد") ? "Email" : "Address"))
                        </h3>
                        <p style="color: #64748b; font-weight: 700; margin: 0; direction: ltr; text-align: @(isRtl ? "right" : "left");">
                            @(isRtl? info.Value: (!string.IsNullOrEmpty(info.ValueEn) ? info.ValueEn : info.Value))
                        </p>
                    </div>
                </div>
            }
        </div>

        <div class="form-card">
            <h2 style="color: var(--primary-color); font-weight: 900; margin-bottom: 30px; font-size: 1.8rem;">
                <i class="fa-regular fa-paper-plane" style="color: var(--secondary-color);"></i> @(isRtl ? "أرسل استفسارك" : "Send Your Inquiry")
            </h2>
            <form>
                <div class="form-row">
                    <div class="form-group">
                        <label>@(isRtl ? "الاسم بالكامل" : "Full Name")</label>
                        <input type="text" class="form-control" placeholder="@(isRtl ? "أدخل اسمك الكريم..." : "Enter your full name...")" required>
                    </div>
                    <div class="form-group">
                        <label>@(isRtl ? "البريد الإلكتروني" : "Email Address")</label>
                        <input type="email" class="form-control" placeholder="name@example.com" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>@(isRtl ? "الرسالة / الاستفسار" : "Message / Inquiry")</label>
                    <textarea class="form-control" rows="6" placeholder="@(isRtl ? "اكتب تفاصيل استفسارك هنا وسنقوم بالرد عليك في أقرب وقت..." : "Write your inquiry details here and we will get back to you ASAP...")" required></textarea>
                </div>
                <button type="button" class="btn btn-primary" style="width: 100%; font-size: 1.2rem; padding: 18px;">
                    @(isRtl ? "إرسال الرسالة الآن" : "Send Message Now") <i class="fa-solid fa-paper-plane" style="margin-@(isRtl ? "right" : "left"): 8px;"></i>
                </button>
            </form>
        </div>
    </div>
</section>
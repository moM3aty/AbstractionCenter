@using Microsoft.AspNetCore.Localization
@inject AbstractionCenter.Data.ApplicationDbContext DbContext
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isRtl = requestCulture?.RequestCulture.UICulture.Name == "ar" || requestCulture?.RequestCulture.UICulture.Name == null;
    ViewData["Title"] = isRtl ? "من نحن" : "About Us";

    var allSettings = DbContext.SiteSettings.ToList();
    var settingsDict = allSettings.ToDictionary(s => s.Key, s => s);
    string GetSetting(string key, string fallbackAr, string fallbackEn)
    {
        if (settingsDict.ContainsKey(key))
        {
            var setting = settingsDict[key];
            if (isRtl) return setting.Value;
            return !string.IsNullOrEmpty(setting.ValueEn) ? setting.ValueEn : setting.Value;
        }
        return isRtl ? fallbackAr : fallbackEn;
    }
}

<style>
    .about-hero {
        background: url('@GetSetting("About_HeroImage", "https://images.unsplash.com/photo-1541339907198-e08756dedf3f?auto=format&fit=crop&w=1920&q=80", "https://images.unsplash.com/photo-1541339907198-e08756dedf3f?auto=format&fit=crop&w=1920&q=80")') center/cover no-repeat;
        position: relative;
        padding: 200px 0 120px;
        text-align: center;
        color: white;
    }

        .about-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(11,17,32,0.85), rgba(11,17,32,0.95));
        }

    .about-hero-content {
        position: relative;
        z-index: 10;
        max-width: 850px;
        margin: 0 auto;
    }

    .icon-top {
        width: 90px;
        height: 90px;
        background: rgba(212, 175, 55, 0.15);
        border: 1px solid rgba(212, 175, 55, 0.4);
        color: var(--secondary-color);
        border-radius: 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin: 0 auto 25px;
        transform: rotate(10deg);
        box-shadow: 0 10px 30px rgba(212,175,55,0.2);
    }

    .about-hero h1 {
        font-size: 3.5rem;
        font-weight: 900;
        margin-bottom: 20px;
        color: #ffffff;
    }

    .about-hero p {
        font-size: 1.25rem;
        color: #cbd5e1;
        line-height: 1.9;
    }

    .story-section {
        padding: 100px 0;
        background: var(--background-light);
    }

    .story-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .image-block {
        position: relative;
    }

        .image-block img {
            width: 100%;
            border-radius: 30px;
            box-shadow: var(--shadow-premium);
            position: relative;
            z-index: 2;
        }

        .image-block::before {
            content: '';
            position: absolute;
            top: -20px;
            right: @(isRtl ? "-20px" : "auto");
            left: @(isRtl ? "auto" : "-20px");
            width: 150px;
            height: 150px;
            background: var(--secondary-color);
            border-radius: 30px;
            z-index: 1;
            opacity: 0.3;
        }

    .text-block h2 {
        font-size: 2.8rem;
        font-weight: 900;
        color: var(--primary-color);
        margin-bottom: 20px;
    }

    .text-block .divider {
        width: 80px;
        height: 5px;
        background: var(--secondary-color);
        border-radius: 5px;
        margin-bottom: 30px;
    }

    .vm-card {
        background: white;
        padding: 30px;
        border-radius: 20px;
        margin-bottom: 20px;
        border: 1px solid #e2e8f0;
        border- @(isRtl ? "right" : "left") : 4px solid var(--secondary-color);
        box-shadow: var(--shadow-sm);
    }

        .vm-card h3 {
            color: var(--primary-color);
            font-size: 1.4rem;
            font-weight: 900;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .vm-card p {
            color: #64748b;
            font-size: 1.1rem;
            line-height: 1.8;
            margin: 0;
        }

    .values-section {
        background: var(--primary-color);
        padding: 100px 0;
        color: white;
        text-align: center;
    }

    .values-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        margin-top: 50px;
    }

    .value-box {
        background: rgba(255,255,255,0.05);
        padding: 50px 30px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.1);
        transition: 0.3s;
    }

        .value-box:hover {
            background: rgba(212,175,55,0.1);
            border-color: var(--secondary-color);
            transform: translateY(-10px);
        }

        .value-box i {
            font-size: 3rem;
            color: var(--secondary-color);
            margin-bottom: 20px;
        }

        .value-box h3 {
            color: white;
            font-size: 1.4rem;
            margin-bottom: 15px;
            font-weight: 800;
        }

        .value-box p {
            color: #cbd5e1;
            line-height: 1.7;
        }

    /* === Media Queries للموبايل === */
    @@media (max-width: 992px) {
        .story-grid {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .text-block .divider {
            margin: 0 auto 30px;
        }

        .vm-card {
            text-align: @(isRtl ? "right" : "left");
        }
    }

    @@media (max-width: 768px) {
        .about-hero {
            padding: 120px 0 60px;
        }

            .about-hero h1 {
                font-size: 2.2rem;
                padding: 0 15px;
            }

            .about-hero p {
                font-size: 1.1rem;
                padding: 0 15px;
            }

        .icon-top {
            width: 70px;
            height: 70px;
            font-size: 2rem;
            margin-bottom: 20px;
        }

        .story-section {
            padding: 60px 0;
        }

        .text-block h2 {
            font-size: 2rem;
        }

        .values-section {
            padding: 60px 0;
        }

            .values-section h2 {
                font-size: 2rem !important;
            }

        .value-box {
            padding: 30px 20px;
        }
    }
</style>

<section class="about-hero">
    <div class="container about-hero-content">
        <div class="icon-top"><i class="fa-solid fa-landmark-dome"></i></div>
        <h1>@GetSetting("About_HeroTitle", "قصتنا في أبستراكشن", "Our Story at Abstraction")</h1>
        <p>
            @GetSetting("About_HeroSubtitle", "نحن صرح تعليمي وُلد من رحم الحاجة لبناء عقول شابة قادرة على قيادة المستقبل ومواكبة التطورات.", "We are an educational institution born from the need to build young minds capable of leading the future.")
        </p>
    </div>
</section>

<section class="story-section">
    <div class="container story-grid">
        <div class="image-block">
            <img src="@GetSetting("About_TeamImage", "https://images.unsplash.com/photo-1531482615713-2afd69097998?auto=format&fit=crop&w=800&q=80", "https://images.unsplash.com/photo-1531482615713-2afd69097998?auto=format&fit=crop&w=800&q=80")" alt="Team" />
        </div>
        <div class="text-block">
            <h2>@(isRtl ? "رؤيتنا ورسالتنا" : "Our Vision & Mission")</h2>
            <div class="divider"></div>

            <div class="vm-card">
                <h3><i class="fa-solid fa-eye" style="color: var(--secondary-color);"></i> @(isRtl ? "الرؤية" : "Vision")</h3>
                <p>@GetSetting("About_Vision", "أن نكون المنصة الأولى الموثوقة في سد الفجوة بين التعليم الأكاديمي واحتياجات سوق العمل الحقيقية.", "To be the first trusted platform in bridging the gap between academic education and real market needs.")</p>
            </div>

            <div class="vm-card" style="border-@(isRtl ? "right" : "left")-color: #3b82f6;">
                <h3><i class="fa-solid fa-bullseye" style="color: #3b82f6;"></i> @(isRtl ? "الرسالة" : "Mission")</h3>
                <p>@GetSetting("About_Mission", "تقديم برامج تدريبية وتأهيلية مُبتكرة مبنية على أسس التطبيق العملي والمشاريع الحقيقية.", "Providing innovative training programs based on practical application and real-world projects.")</p>
            </div>
        </div>
    </div>
</section>

<section class="values-section">
    <div class="container">
        <h2 style="font-size: 2.8rem; font-weight: 900; color: white;">@GetSetting("About_ValuesTitle", "قيمنا المؤسسية", "Our Core Values")</h2>
        <div style="width: 60px; height: 4px; background: var(--secondary-color); margin: 20px auto 0; border-radius: 2px;"></div>

        <div class="values-grid">
            <div class="value-box">
                <i class="fa-solid fa-handshake-angle"></i>
                <h3>@GetSetting("About_Value1_Title", "الأمانة والنزاهة", "Integrity & Honesty")</h3>
                <p>@GetSetting("About_Value1_Desc", "نلتزم بتقديم محتوى علمي دقيق بشفافية تامة ومصداقية مطلقة.", "We are committed to providing accurate scientific content with complete transparency and absolute credibility.")</p>
            </div>
            <div class="value-box">
                <i class="fa-solid fa-lightbulb"></i>
                <h3>@GetSetting("About_Value2_Title", "التطور المستمر", "Continuous Improvement")</h3>
                <p>@GetSetting("About_Value2_Desc", "تحديث دائم لمساراتنا لمواكبة تسارع التكنولوجيا ومتطلبات العصر.", "Constantly updating our tracks to keep pace with accelerating technology.")</p>
            </div>
            <div class="value-box">
                <i class="fa-solid fa-people-group"></i>
                <h3>@GetSetting("About_Value3_Title", "المجتمع الواحد", "One Community")</h3>
                <p>@GetSetting("About_Value3_Desc", "نبني شبكة علاقات قوية وتفاعلية بين الطلاب والمدربين وسوق العمل.", "We build a strong and interactive network between students, trainers, and the job market.")</p>
            </div>
        </div>
    </div>
</section>
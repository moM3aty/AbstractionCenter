@using Microsoft.AspNetCore.Localization
@inject AbstractionCenter.Data.ApplicationDbContext DbContext
@model AbstractionCenter.Models.Entities.RegistrationRequest
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isRtl = requestCulture?.RequestCulture.UICulture.Name == "ar" || requestCulture?.RequestCulture.UICulture.Name == null;
    ViewData["Title"] = isRtl ? "إكمال إجراءات الدفع" : "Complete Payment";

    var paymentInstructions = DbContext.SiteSettings.FirstOrDefault(s => s.Key == "PaymentInstructions")?.Value
        ?? "يرجى تحويل رسوم الدورة إلى الحساب البنكي التالي، وإرسال صورة الإيصال عبر الواتساب للرقم المسجل، مع كتابة (اسمك الثلاثي، واسم الدورة) في التعليق.";

    // حساب السعر النهائي إذا كان هناك خصم
    decimal finalPrice = Model.Batch.Price;
    if (Model.Batch.ShowDiscount && Model.Batch.DiscountPercentage > 0)
    {
        finalPrice = Model.Batch.Price * (decimal)(1 - (Model.Batch.DiscountPercentage / 100.0));
    }
}

<style>
    .payment-wrapper {
        background: #f8fafc;
        min-height: 80vh;
        padding: 140px 20px 80px;
    }

    .payment-card {
        background: white;
        border-radius: 24px;
        padding: 50px;
        box-shadow: 0 25px 50px -12px rgba(11, 17, 32, 0.15);
        max-width: 800px;
        margin: 0 auto;
        border: 1px solid rgba(212, 175, 55, 0.2);
    }

    .instructions-box {
        background: rgba(212, 175, 55, 0.05);
        border: 1px dashed rgba(212, 175, 55, 0.4);
        padding: 30px;
        border-radius: 16px;
        margin-bottom: 30px;
        line-height: 1.8;
        color: #1e293b;
        font-size: 1.1rem;
    }

    .price-tag {
        text-align: center;
        font-size: 2.5rem;
        font-weight: 900;
        color: var(--primary-color);
        margin-bottom: 20px;
    }

    .file-upload-wrapper {
        position: relative;
        width: 100%;
        height: 200px;
        border: 2px dashed #cbd5e1;
        border-radius: 16px;
        background: #f8fafc;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
        margin-bottom: 30px;
        text-align: center;
        padding: 20px;
    }

        .file-upload-wrapper:hover {
            border-color: var(--secondary-color);
            background: white;
        }

        .file-upload-wrapper input[type="file"] {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

    .upload-icon {
        font-size: 3rem;
        color: #94a3b8;
        margin-bottom: 15px;
        transition: 0.3s;
    }

    .file-upload-wrapper:hover .upload-icon {
        color: var(--secondary-color);
        transform: translateY(-5px);
    }

    .btn-submit-payment {
        background: linear-gradient(135deg, var(--secondary-color), #b48a25);
        color: var(--primary-color);
        width: 100%;
        padding: 20px;
        font-size: 1.25rem;
        font-weight: 900;
        border-radius: 50px;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        box-shadow: 0 10px 25px rgba(212,175,55,0.3);
        transition: 0.3s;
        font-family: inherit;
    }

        .btn-submit-payment:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(212,175,55,0.5);
        }

    /* === Media Queries للموبايل === */
    @@media (max-width: 768px) {
        .payment-wrapper {
            padding: 100px 15px 60px;
        }

        .payment-card {
            padding: 30px 20px;
            border-radius: 20px;
        }

            .payment-card h1 {
                font-size: 1.6rem !important;
            }

        .price-tag {
            font-size: 2rem;
        }

        .instructions-box {
            padding: 20px 15px;
            font-size: 1rem;
        }

        .file-upload-wrapper {
            height: 160px;
        }

            .file-upload-wrapper h4 {
                font-size: 1rem;
            }

        .btn-submit-payment {
            padding: 16px;
            font-size: 1.1rem;
        }
    }
</style>

<div class="payment-wrapper">
    <div class="payment-card">
        <div style="text-align: center; margin-bottom: 30px;">
            <i class="fa-solid fa-file-invoice-dollar" style="font-size: 4rem; color: var(--secondary-color); margin-bottom: 15px;"></i>
            <h1 style="font-size: 2rem; font-weight: 900; color: var(--primary-color);">@(isRtl ? "الخطوة 2: إكمال إجراءات الدفع" : "Step 2: Complete Payment")</h1>
            <p style="color: #64748b; font-size: 1.1rem; margin-top: 10px;">@Model.Batch.Course.Title - @Model.Batch.BatchName</p>
        </div>

        @if (Model.Batch.ShowPrice)
        {
            <div class="price-tag">@finalPrice.ToString("0.##") $</div>
        }

        <div class="instructions-box">
            <h3 style="color: var(--primary-color); font-weight: 900; margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                <i class="fa-solid fa-circle-info" style="color: var(--secondary-color);"></i> @(isRtl ? "تعليمات الدفع:" : "Payment Instructions:")
            </h3>
            @Html.Raw(paymentInstructions.Replace("\n", "<br>"))
        </div>

        <form asp-action="SubmitPayment" method="post" enctype="multipart/form-data">
            <input type="hidden" name="requestId" value="@Model.Id" />

            <h4 style="color: var(--primary-color); font-weight: 800; margin-bottom: 15px;">@(isRtl ? "ارفق صورة إيصال التحويل لتأكيد طلبك:" : "Upload transfer receipt to confirm:")</h4>

            <div class="file-upload-wrapper">
                <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
                <h4 style="color: var(--primary-color); font-weight: 800; margin: 0;">@(isRtl ? "اضغط هنا لاختيار ملف الإيصال" : "Click here to upload receipt")</h4>
                <p style="color: #64748b; font-size: 0.9rem; margin-top: 5px;">(JPG, PNG, PDF)</p>
                <input type="file" name="receiptFile" accept=".jpg,.jpeg,.png,.pdf" required />
            </div>

            <button type="submit" class="btn-submit-payment">
                @(isRtl ? "تأكيد الطلب وإرسال الإيصال" : "Confirm Order & Submit Receipt") <i class="fa-solid fa-check-double"></i>
            </button>
        </form>
    </div>
</div>
@using Microsoft.AspNetCore.Localization
@model IEnumerable<AbstractionCenter.Models.Entities.Batch>
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isRtl = requestCulture?.RequestCulture.UICulture.Name == "ar" || requestCulture?.RequestCulture.UICulture.Name == null;
    ViewData["Title"] = isRtl ? "دليل البرامج التدريبية" : "Course Catalog";
}

<style>
    /* --- المتغيرات الأساسية --- */
    :root {
        --catalog-bg: #f4f7f6;
        --card-bg: #ffffff;
        --text-main: #0b1120;
        --text-muted: #64748b;
        --gold-main: #d4af37;
        --gold-light: #fef08a;
        --accent-green: #10b981;
        --accent-red: #ef4444;
        --shadow-soft: 0 10px 40px -10px rgba(11,17,32,0.08);
        --shadow-hover: 0 25px 50px -12px rgba(212,175,55,0.25);
    }

    .catalog-wrapper {
        background-color: var(--catalog-bg);
        min-height: 100vh;
        padding-bottom: 100px;
    }

    /* --- ترويسة الصفحة (Hero Section) --- */
    .pro-hero {
        background: linear-gradient(135deg, #0b1120 0%, #1e293b 100%);
        padding: 140px 0 100px;
        text-align: center;
        position: relative;
        overflow: hidden;
        border-bottom: 4px solid var(--gold-main);
    }

        .pro-hero::before {
            content: '';
            position: absolute;
            top: -100px;
            right: -100px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            filter: blur(40px);
        }

        .pro-hero::after {
            content: '';
            position: absolute;
            bottom: -100px;
            left: -100px;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            filter: blur(40px);
        }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(212, 175, 55, 0.1);
        border: 1px solid rgba(212, 175, 55, 0.3);
        color: var(--gold-main);
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1rem;
        margin-bottom: 25px;
        position: relative;
        z-index: 10;
        backdrop-filter: blur(5px);
    }

    .pro-hero h1 {
        font-size: 3.8rem;
        font-weight: 900;
        color: white;
        margin-bottom: 20px;
        position: relative;
        z-index: 10;
        line-height: 1.2;
    }

        .pro-hero h1 span {
            background: linear-gradient(to left, var(--gold-main), var(--gold-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .pro-hero p {
        font-size: 1.25rem;
        color: #cbd5e1;
        max-width: 750px;
        margin: 0 auto;
        line-height: 1.8;
        position: relative;
        z-index: 10;
    }

    /* --- شبكة الكروت (Grid) --- */
    .pro-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 40px;
        margin-top: -40px; /* لرفع الكروت قليلاً فوق الهيدر */
        position: relative;
        z-index: 20;
        padding: 0 20px;
        max-width: 1320px;
        margin-left: auto;
        margin-right: auto;
    }

    /* --- تصميم الكارت الاحترافي --- */
    .pro-card {
        background: var(--card-bg);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: var(--shadow-soft);
        border: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
    }

        .pro-card:hover {
            transform: translateY(-12px);
            box-shadow: var(--shadow-hover);
            border-color: var(--gold-main);
        }

    /* صورة الكارت */
    .pro-media {
        height: 240px;
        position: relative;
        overflow: hidden;
        background: #1e293b;
    }

        .pro-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s ease;
        }

    .pro-card:hover .pro-media img {
        transform: scale(1.08);
    }

    .status-pill {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(16, 185, 129, 0.95);
        color: white;
        padding: 8px 18px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 6px;
        backdrop-filter: blur(4px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        z-index: 2;
    }

    /* محتوى الكارت */
    .pro-body {
        padding: 30px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .pro-title {
        font-size: 1.45rem;
        font-weight: 900;
        color: var(--text-main);
        margin-bottom: 15px;
        line-height: 1.5;
    }

    .pro-desc {
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.7;
        margin-bottom: 25px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow-y: scroll;
        flex-grow: 1;
    }

    /* ملاحظة التنفيذ */
    .pro-execution {
        background: rgba(212, 175, 55, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.2);
        padding: 12px 15px;
        border-radius: 12px;
        color: #b48a25;
        font-weight: 800;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    /* البيانات الوصفية (الدفعة والموعد) */
    .pro-meta {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 15px;
        margin-bottom: 25px;
    }

    .meta-item {
        background: #f8fafc;
        padding: 12px;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        border: 1px solid #f1f5f9;
    }

        .meta-item span {
            font-size: 0.8rem;
            color: #94a3b8;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .meta-item strong {
            font-size: 0.95rem;
            color: var(--text-main);
            font-weight: 900;
        }

    /* التسعير */
    .pro-pricing {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 20px;
        border-top: 1px solid #f1f5f9;
        margin-bottom: 25px;
    }

    .price-block {
        display: flex;
        align-items: baseline;
        gap: 10px;
    }

    .price-current {
        font-size: 1.8rem;
        font-weight: 900;
        color: var(--text-main);
        line-height: 1;
    }

    .price-old {
        font-size: 1.1rem;
        color: #94a3b8;
        text-decoration: line-through;
        font-weight: 700;
    }

    .discount-tag {
        background: rgba(239, 68, 68, 0.1);
        color: var(--accent-red);
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 900;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .price-contact {
        font-size: 1.05rem;
        color: var(--gold-main);
        font-weight: 900;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* الزر */
    .pro-btn {
        background: var(--text-main);
        color: var(--gold-main);
        text-align: center;
        padding: 16px;
        border-radius: 14px;
        font-size: 1.1rem;
        font-weight: 900;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: 0.3s;
        border: 2px solid transparent;
    }

    .pro-card:hover .pro-btn {
        background: var(--gold-main);
        color: var(--text-main);
        box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
    }

    /* حالة الفراغ */
    .empty-catalog {
        grid-column: 1 / -1;
        text-align: center;
        padding: 80px 20px;
        background: white;
        border-radius: 30px;
        border: 2px dashed #e2e8f0;
        box-shadow: var(--shadow-soft);
    }

    /* === استعلامات الشاشة للموبايل (Media Queries) === */
    @@media (max-width: 1024px) {
        .pro-grid

    {
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    }

    @@media (max-width: 768px) {
        .pro-hero

    {
        padding: 100px 20px 80px;
    }

    .pro-hero h1 {
        font-size: 2.2rem;
        margin-bottom: 15px;
    }

    .pro-hero p {
        font-size: 1.05rem;
    }

    .pro-grid {
        grid-template-columns: 1fr;
        margin-top: -30px;
        gap: 25px;
    }

    .pro-card {
        border-radius: 20px;
    }

    .pro-media {
        height: 200px;
    }

    .pro-body {
        padding: 25px 20px;
    }

    .pro-title {
        font-size: 1.3rem;
    }

    .pro-meta {
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .pro-pricing {
        flex-direction: column;
        align-items: flex-start;
        gap: 15px;
    }

    .pro-btn {
        padding: 14px;
        font-size: 1.05rem;
    }

    }
</style>

<div class="catalog-wrapper">
    <!-- Hero Section -->
    <div class="pro-hero">
        <div class="hero-badge">
            <i class="fa-solid fa-crown"></i> @(isRtl ? "استكشف بوابتك للمستقبل" : "Explore Your Portal to Future")
        </div>
        <h1>@(isRtl ? "دليل البرامج" : "Learning") <span>@(isRtl ? "الأكاديمية" : "Catalog")</span></h1>
        <p>@(isRtl ? "اختر من بين مجموعتنا الواسعة من المسارات التدريبية المصممة بعناية فائقة لتتوافق مع معايير سوق العمل الدولية وتصنع منك خبيراً في مجالك." : "Choose from our wide range of carefully designed training tracks tailored to meet international job market standards.")</p>
    </div>

    <!-- Cards Grid -->
    <div class="pro-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var batch in Model)
            {
                <div class="pro-card">
                    <div class="pro-media">
                        <div class="status-pill"><i class="fa-solid fa-door-open"></i> @(isRtl ? "متاح للتسجيل" : "Open")</div>
                        @if (!string.IsNullOrEmpty(batch.Course?.ImageUrl))
                        {
                            <img src="@batch.Course.ImageUrl" alt="@batch.Course.Title" loading="lazy" />
                        }
                        else
                        {
                            <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#1e293b;">
                                <i class="fa-solid fa-layer-group" style="font-size:5rem; color:rgba(212,175,55,0.15);"></i>
                            </div>
                        }
                    </div>

                    <div class="pro-body">
                        <h2 class="pro-title">@batch.Course?.Title</h2>

                        @if (batch.ShowExecutionNote && !string.IsNullOrEmpty(batch.ExecutionNote))
                        {
                            <div class="pro-execution">
                                <i class="fa-solid fa-users-gear"></i>
                                <span>@batch.ExecutionNote</span>
                            </div>
                        }

                        <p class="pro-desc">@(batch.Course?.Description)</p>

                        <div class="pro-meta">
                            <div class="meta-item">
                                <span><i class="fa-solid fa-users-rectangle"></i> @(isRtl ? "الدفعة" : "Batch")</span>
                                <strong>@batch.BatchName</strong>
                            </div>
                            <div class="meta-item">
                                <span><i class="fa-regular fa-calendar-days"></i> @(isRtl ? "موعد البدء" : "Start Date")</span>
                                <strong>@batch.StartDate.ToString("dd MMMM yyyy")</strong>
                            </div>
                        </div>

                        <div class="pro-pricing">
                            @if (batch.ShowPrice)
                            {
                                <div class="price-block">
                                    @if (batch.ShowDiscount && batch.DiscountPercentage > 0)
                                    {
                                        decimal discountMultiplier = (decimal)(1 - (batch.DiscountPercentage / 100.0));
                                        decimal finalPrice = batch.Price * discountMultiplier;

                                        <span class="price-current">@finalPrice.ToString("0.##") $</span>
                                        <span class="price-old">@batch.Price.ToString("0.##") $</span>
                                    }
                                    else
                                    {
                                        <span class="price-current">@batch.Price.ToString("0.##") $</span>
                                    }
                                </div>
                                @if (batch.ShowDiscount && batch.DiscountPercentage > 0)
                                {
                                    <div class="discount-tag">@(isRtl ? "خصم" : "Save") @batch.DiscountPercentage%</div>
                                }
                            }
                            else
                            {
                                <div class="price-contact">
                                    <i class="fa-solid fa-tags"></i> @(isRtl ? "تواصل لمعرفة التكلفة" : "Contact for pricing")
                                </div>
                            }
                        </div>

                        <a href="/Courses/Register/@batch.Id" class="pro-btn">
                            @(isRtl ? "تقديم طلب انضمام" : "Enroll Now") <i class="fa-solid @(isRtl ? "fa-arrow-left" : "fa-arrow-right")"></i>
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-catalog">
                <i class="fa-solid fa-box-open" style="font-size: 5rem; color: #cbd5e1; margin-bottom: 25px;"></i>
                <h3 style="color: var(--primary-color); font-weight: 900; font-size: 2rem;">@(isRtl ? "لا توجد برامج متاحة حالياً" : "No Available Programs")</h3>
                <p style="color: #64748b; font-size: 1.15rem; margin-top: 10px;">@(isRtl ? "يتم تحديث الدفعات بشكل دوري. يرجى العودة لاحقاً أو متابعتنا على منصات التواصل." : "Batches are updated periodically. Please check back later or follow us on social media.")</p>
            </div>
        }
    </div>
</div>
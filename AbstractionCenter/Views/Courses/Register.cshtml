@using Microsoft.AspNetCore.Localization
@model AbstractionCenter.Models.Entities.Batch
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isRtl = requestCulture?.RequestCulture.UICulture.Name == "ar" || requestCulture?.RequestCulture.UICulture.Name == null;
    ViewData["Title"] = (isRtl ? "التسجيل في: " : "Register in: ") + Model.Course?.Title;
}

<style>
    .form-wrapper {
        background: #f8fafc;
        min-height: 80vh;
        padding: 140px 20px 80px;
    }

    .form-card {
        background: white;
        border-radius: 24px;
        padding: 60px;
        box-shadow: 0 25px 50px -12px rgba(11, 17, 32, 0.15);
        max-width: 900px;
        margin: 0 auto;
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-top: 8px solid var(--secondary-color);
        text-align: @(isRtl ? "right" : "left");
    }

    .course-header-card {
        background: linear-gradient(135deg, var(--primary-color), #1e293b);
        color: white;
        padding: 40px;
        border-radius: 20px;
        margin-bottom: 40px;
        text-align: center;
        box-shadow: 0 15px 30px rgba(11, 17, 32, 0.2);
    }

        .course-header-card h2 {
            color: var(--secondary-color);
            font-weight: 900;
            font-size: 2.2rem;
            margin-bottom: 10px;
        }

    .batch-badge {
        display: inline-block;
        background: rgba(255,255,255,0.1);
        padding: 8px 20px;
        border-radius: 30px;
        font-weight: 800;
        border: 1px solid rgba(255,255,255,0.2);
        margin-top: 15px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
    }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-weight: 800;
            color: var(--primary-color);
            font-size: 1.05rem;
        }

    .form-control {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        font-family: inherit;
        font-size: 1.05rem;
        background: #fcfcfd;
        transition: 0.3s;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--secondary-color);
            background: white;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        }

    .section-title {
        color: var(--primary-color);
        font-size: 1.5rem;
        font-weight: 900;
        margin: 40px 0 25px;
        border-bottom: 2px solid #e2e8f0;
        padding-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-title i {
            color: var(--secondary-color);
        }

    /* --- CAPTCHA Styles --- */
    .captcha-container {
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        padding: 20px;
        border-radius: 16px;
        margin-top: 30px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .captcha-box {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .captcha-canvas {
        background: white;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        letter-spacing: 5px;
        flex-shrink: 0; /* التعديل هنا لمنع الانضغاط */
        padding : 0px 20px;
        width: 210px;
    }

    .btn-refresh-captcha {
        background: var(--primary-color);
        color: var(--secondary-color);
        border: none;
        width: 50px;
        height: 50px;
        border-radius: 10px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: 0.3s;
        flex-shrink: 0; /* التعديل هنا لمنع الانضغاط */
    }

    .btn-submit-reg {
        background: linear-gradient(135deg, var(--secondary-color), #fef08a);
        color: var(--primary-color);
        border: none;
        padding: 20px;
        width: 100%;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.25rem;
        cursor: pointer;
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.3);
        transition: all 0.4s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 40px;
        font-family: inherit;
    }

        .btn-submit-reg:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(212, 175, 55, 0.5);
        }

    /* === Media Queries === */
    @@media (max-width: 768px) {
        .form-wrapper {
            padding: 100px 15px 60px;
        }

        .form-card {
            padding: 30px 20px;
            border-radius: 20px;
        }

        .course-header-card {
            padding: 25px 15px;
            border-radius: 16px;
        }

            .course-header-card h2 {
                font-size: 1.6rem;
            }

        .form-grid {
            grid-template-columns: 1fr;
            gap: 0;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 1.3rem;
            margin: 30px 0 20px;
        }

        .btn-submit-reg {
            padding: 16px;
            font-size: 1.1rem;
            margin-top: 20px;
        }

        .captcha-box {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="form-wrapper">
    <div class="form-card">
        <div class="course-header-card">
            <h2>@Model.Course?.Title</h2>
            <div class="batch-badge">@Model.BatchName</div>
            <p style="margin: 15px 0 0 0; color: #cbd5e1; font-size: 1.05rem;">@(isRtl ? "الخطوة 1: يرجى إدخال بياناتك الأساسية، سيتم توجيهك لصفحة الدفع بعد قليل." : "Step 1: Enter your details, you will be directed to payment next.")</p>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div style="background: rgba(239, 68, 68, 0.1); color: #dc2626; padding: 15px; border-radius: 12px; margin-bottom: 20px; font-weight: bold; text-align: center; border: 1px solid rgba(239, 68, 68, 0.2);">
                @TempData["ErrorMessage"]
            </div>
        }

        <form asp-controller="Courses" asp-action="SubmitRegistration" method="post" id="registrationForm">
            <input type="hidden" name="batchId" value="@Model.Id" />

            <h3 class="section-title"><i class="fa-solid fa-address-card"></i> @(isRtl ? "البيانات الأساسية" : "Basic Information")</h3>

            <div class="form-grid">
                <div class="form-group">
                    <label>@(isRtl ? "الاسم رباعي (باللغة العربية)" : "Full Name (In Arabic)") <span style="color: #ef4444;">*</span></label>
                    <input type="text" name="fullName" class="form-control" placeholder="أحمد محمد محمود..." required />
                </div>
                <div class="form-group">
                    <label>@(isRtl ? "الاسم رباعي (باللغة الإنجليزية للشهادة)" : "Full Name (In English for Certificate)") <span style="color: #ef4444;">*</span></label>
                    <input type="text" name="fullNameEn" class="form-control" placeholder="Ahmed Mohamed Mahmoud..." required dir="ltr" />
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label>@(isRtl ? "البريد الإلكتروني (أساسي لتسجيل الدخول لاحقاً)" : "Email Address")</label>
                    <input type="email" name="email" class="form-control" required dir="ltr" />
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label>@(isRtl ? "رقم الواتساب" : "WhatsApp Number") <i class="fa-brands fa-whatsapp" style="color:#25d366;"></i></label>
                    <input type="text" name="whatsAppNumber" class="form-control" placeholder="0100000000" required dir="ltr" />
                </div>
                <div class="form-group">
                    <label>@(isRtl ? "رقم تلغرام (اختياري)" : "Telegram Number (Optional)") <i class="fa-brands fa-telegram" style="color:#3b82f6;"></i></label>
                    <input type="text" name="telegramNumber" class="form-control" dir="ltr" />
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label>@(isRtl ? "التخصص (الدراسي أو المهني)" : "Specialization")</label>
                    <input type="text" name="specialization" class="form-control" required />
                </div>
                <div class="form-group">
                    <label>@(isRtl ? "مستواك الحالي" : "Current Level")</label>
                    <select name="level" class="form-control" required>
                        <option value="">-- @(isRtl ? "اختر مستواك" : "Select Level") --</option>
                        <option value="مبتدئ">@(isRtl ? "مبتدئ" : "Beginner")</option>
                        <option value="متوسط">@(isRtl ? "متوسط" : "Intermediate")</option>
                        <option value="متقدم">@(isRtl ? "متقدم" : "Advanced")</option>
                    </select>
                </div>
            </div>

            @if (Model.Course?.CustomQuestions != null && Model.Course.CustomQuestions.Any())
            {
                <h3 class="section-title"><i class="fa-solid fa-clipboard-question"></i> @(isRtl ? "تفاصيل إضافية للتقييم" : "Additional Evaluation Details")</h3>
                foreach (var q in Model.Course.CustomQuestions.OrderBy(q => q.Order))
                {
                    <div class="form-group">
                        <label>
                            @q.QuestionText
                            @if (q.IsRequired)
                            {
                                <span style="color: #ef4444; font-size: 0.9rem;">(@(isRtl ? "مطلوب" : "Required"))</span>
                            }
                        </label>
                        <textarea name="customAnswers[@q.Id]" class="form-control" rows="2" @(q.IsRequired ? "required" : "")></textarea>
                    </div>
                }
            }

            <!-- وحدة التحقق الأمني CAPTCHA -->
            <div class="captcha-container">
                <label style="font-weight: 800; color: var(--primary-color); margin: 0;">
                    <i class="fa-solid fa-shield-halved" style="color: var(--secondary-color);"></i> @(isRtl ? "تحقق أمني (للأمان)" : "Security Check")
                </label>
                <p style="font-size: 0.9rem; color: #64748b; margin: 0 0 10px 0;">@(isRtl ? "يرجى كتابة الحروف والأرقام الظاهرة في الصورة أدناه لتأكيد أنك لست روبوتاً." : "Please type the characters shown in the image below.")</p>

                <div class="captcha-box">
                    <!-- تم تكبير العرض والطول هنا -->
                    <canvas id="captchaCanvas" width="200" height="60" class="captcha-canvas"></canvas>
                    <button type="button" onclick="generateCaptcha()" class="btn-refresh-captcha" title="@(isRtl ? "تغيير الرمز" : "Refresh")">
                        <i class="fa-solid fa-arrows-rotate"></i>
                    </button>
                    <input type="text" id="captchaInput" class="form-control" placeholder="@(isRtl ? "أدخل الرمز هنا..." : "Enter code here...")" required style="max-width: 250px; text-transform: uppercase;" autocomplete="off" />
                </div>
                <span id="captchaError" style="display: none; color: #ef4444; font-weight: bold; font-size: 0.95rem;">
                    <i class="fa-solid fa-circle-exclamation"></i> @(isRtl ? "الرمز غير صحيح، يرجى المحاولة مرة أخرى." : "Incorrect code, please try again.")
                </span>
            </div>

            <button type="submit" class="btn-submit-reg">
                @(isRtl ? "المتابعة لإكمال الدفع" : "Continue to Payment") <i class="fa-solid fa-arrow-left"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let currentCaptchaCode = "";

        function generateCaptcha() {
            const canvas = document.getElementById('captchaCanvas');
            const ctx = canvas.getContext('2d');

            // تنظيف الخلفية
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // توليد النص العشوائي
            const chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
            currentCaptchaCode = "";
            for (let i = 0; i < 5; i++) {
                currentCaptchaCode += chars.charAt(Math.floor(Math.random() * chars.length));
            }

            // رسم خطوط تشويش لمنع البوتات
            for(let i = 0; i < 7; i++) {
                ctx.beginPath();
                ctx.moveTo(Math.random() * canvas.width, Math.random() * canvas.height);
                ctx.lineTo(Math.random() * canvas.width, Math.random() * canvas.height);
                ctx.strokeStyle = '#cbd5e1';
                ctx.lineWidth = 2;
                ctx.stroke();
            }

            // رسم النص بانحرافات بسيطة
            ctx.font = 'bold 30px "Courier New", monospace';
            ctx.fillStyle = '#0b1120';
            ctx.textBaseline = 'middle';

            for (let i = 0; i < currentCaptchaCode.length; i++) {
                ctx.save();
                // توسيع المسافات بين الحروف لتتناسب مع الحجم الجديد
                ctx.translate(30 + (i * 35), 30);
                ctx.rotate((Math.random() - 0.5) * 0.4);
                ctx.fillText(currentCaptchaCode[i], -10, 0);
                ctx.restore();
            }
        }

        // تشغيل توليد الكود عند تحميل الصفحة
        document.addEventListener("DOMContentLoaded", generateCaptcha);

        // التحقق من صحة الكود عند محاولة الإرسال
        document.getElementById('registrationForm').addEventListener('submit', function(e) {
            const inputVal = document.getElementById('captchaInput').value.toUpperCase();

            if (inputVal !== currentCaptchaCode) {
                e.preventDefault(); // منع إرسال النموذج
                document.getElementById('captchaError').style.display = 'block';
                document.getElementById('captchaInput').value = '';
                document.getElementById('captchaInput').focus();
                generateCaptcha(); // توليد كود جديد
            } else {
                document.getElementById('captchaError').style.display = 'none';
            }
        });
    </script>
}
@model IEnumerable<AbstractionCenter.Models.Entities.Course>
@{
    ViewData["Title"] = "لوحة تحكم المحاضر";
}

<style>
    /* --- الهوية الملكية للمحاضر --- */
    :root {
        --inst-bg: #f8fafc;
        --inst-surface: #ffffff;
        --inst-primary: #0b1120;
        --inst-primary-light: #1e293b;
        --inst-gold: #d4af37;
        --inst-gold-glow: rgba(212, 175, 55, 0.3);
        --inst-text: #0f172a;
        --inst-muted: #64748b;
        --inst-border: rgba(212, 175, 55, 0.2);
        --inst-radius: 24px;
        --inst-shadow: 0 15px 35px -10px rgba(11, 17, 32, 0.08);
        --inst-shadow-hover: 0 25px 50px -12px rgba(212, 175, 55, 0.15);
    }

    .dashboard-wrapper {
        padding-bottom: 60px;
    }

    /* --- الهيدر الفخم --- */
    .hero-dashboard {
        background: linear-gradient(135deg, var(--inst-primary), var(--inst-primary-light));
        border-radius: var(--inst-radius);
        padding: 50px;
        margin: 30px 0 50px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px -10px rgba(11, 17, 32, 0.4);
        border: 1px solid rgba(212, 175, 55, 0.15);
    }

        .hero-dashboard::before {
            content: '';
            position: absolute;
            top: -100px;
            right: -50px;
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, var(--inst-gold-glow) 0%, transparent 70%);
            border-radius: 50%;
        }

        .hero-dashboard::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url('data:image/svg+xml,%3Csvg width=\'40\' height=\'40\' viewBox=\'0 0 40 40\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M20 20.5V18H0v-2h20v-2H0v-2h20v-2H0V8h20V6H0V4h20V2H0V0h22v20h2V0h2v20h2V0h2v20h2V0h2v20h2V0h2v2H20v-1.5zM0 20h2v20H0V20zm4 0h2v20H4V20zm4 0h2v20H8V20zm4 0h2v20h-2V20zm4 0h2v20h-2V20zm4 4h20v2H20v-2zm0 4h20v2H20v-2zm0 4h20v2H20v-2zm0 4h20v2H20v-2z\' fill=\'%23d4af37\' fill-opacity=\'0.03\' fill-rule=\'evenodd\'/%3E%3C/svg%3E');
        }

    .hero-content {
        position: relative;
        z-index: 10;
        color: white;
    }

        .hero-content h1 {
            font-size: 2.6rem;
            font-weight: 900;
            margin-bottom: 10px;
            color: white;
        }

            .hero-content h1 span {
                color: var(--inst-gold);
                text-shadow: 0 0 20px rgba(212,175,55,0.4);
            }

        .hero-content p {
            font-size: 1.1rem;
            color: #cbd5e1;
            max-width: 500px;
            line-height: 1.7;
            margin: 0;
        }

    .hero-stats {
        position: relative;
        z-index: 10;
        display: flex;
        gap: 20px;
    }

    .stat-badge {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 20px 30px;
        border-radius: 20px;
        text-align: center;
        backdrop-filter: blur(10px);
    }

        .stat-badge h3 {
            color: var(--inst-gold);
            font-size: 2rem;
            font-weight: 900;
            margin: 0;
            line-height: 1;
        }

        .stat-badge p {
            color: #cbd5e1;
            font-size: 0.95rem;
            margin: 8px 0 0 0;
            font-weight: 700;
        }

    /* --- قسم الدورات --- */
    .section-title {
        color: var(--inst-primary);
        font-size: 1.6rem;
        font-weight: 900;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .section-title i {
            color: var(--inst-gold);
        }

    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 30px;
    }

    .luxury-card {
        background: var(--inst-surface);
        border-radius: var(--inst-radius);
        overflow: hidden;
        box-shadow: var(--inst-shadow);
        border: 1px solid #e2e8f0;
        transition: all 0.4s ease;
        display: flex;
        flex-direction: column;
        position: relative;
    }

        .luxury-card:hover {
            transform: translateY(-10px);
            box-shadow: var(--inst-shadow-hover);
            border-color: var(--inst-gold);
        }

    .luxury-card-img {
        height: 200px;
        position: relative;
        overflow: hidden;
        background: var(--inst-primary-light);
    }

        .luxury-card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.7s ease;
            opacity: 0.9;
        }

    .luxury-card:hover .luxury-card-img img {
        transform: scale(1.08);
        opacity: 1;
    }

    .luxury-card-img .overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(11,17,32,0.9) 0%, transparent 100%);
    }

    .card-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(11, 17, 32, 0.8);
        color: var(--inst-gold);
        padding: 6px 15px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 800;
        backdrop-filter: blur(5px);
        border: 1px solid rgba(212, 175, 55, 0.3);
        z-index: 2;
    }

    .luxury-card-content {
        padding: 25px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        z-index: 5;
    }

    .luxury-card-title {
        font-size: 1.3rem;
        font-weight: 900;
        color: var(--inst-primary);
        margin-bottom: 15px;
        line-height: 1.5;
    }

    .luxury-card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        color: var(--inst-muted);
        font-size: 0.9rem;
        font-weight: 700;
    }

        .luxury-card-meta i {
            color: var(--inst-gold);
            margin-left: 5px;
        }

    .luxury-btn {
        background: #f8fafc;
        color: var(--inst-primary);
        border: 2px solid #e2e8f0;
        padding: 12px 20px;
        border-radius: 14px;
        text-align: center;
        font-weight: 800;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: auto;
    }

    .luxury-card:hover .luxury-btn {
        background: var(--inst-primary);
        color: var(--inst-gold);
        border-color: var(--inst-primary);
    }

    @@media (max-width: 992px) {
        .hero-dashboard

    {
        flex-direction: column;
        text-align: center;
        gap: 30px;
        padding: 40px 20px;
    }

    .hero-stats {
        justify-content: center;
        flex-wrap: wrap;
    }

    }
</style>

<div class="dashboard-wrapper">
    <!-- الهيدر الفخم -->
    <div class="hero-dashboard">
        <div class="hero-content">
            <h1>مرحباً بك، <span>@ViewData["InstructorName"]</span></h1>
            <p>مساحتك الأكاديمية الملكية. أدر دوراتك، ارفع محتواك، وصمم رحلة تعليمية استثنائية لطلابك.</p>
        </div>
        <div class="hero-stats">
            <div class="stat-badge">
                <h3>@(Model?.Count() ?? 0)</h3>
                <p>دورات مسندة إليك</p>
            </div>
            <div class="stat-badge">
                <h3><i class="fa-solid fa-certificate" style="color: var(--inst-gold);"></i></h3>
                <p>محاضر معتمد</p>
            </div>
        </div>
    </div>

    <h2 class="section-title"><i class="fa-solid fa-laptop-code"></i> الأكاديمية (البرامج التدريبية)</h2>

    <div class="courses-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var course in Model)
            {
                <div class="luxury-card">
                    <div class="luxury-card-img">
                        <div class="card-badge">
                            @if (course.Status == AbstractionCenter.Models.Entities.CourseStatus.OpenForRegistration)
                            {
                                <span><i class="fa-solid fa-door-open"></i> متاحة للتسجيل</span>
                            }
                            else
                            {
                                <span style="color:#94a3b8;"><i class="fa-solid fa-lock"></i> مغلقة / قيد التنفيذ</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(course.ImageUrl))
                        {
                            <img src="@course.ImageUrl" alt="@course.Title" />
                        }
                        else
                        {
                            <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background: #1e293b;">
                                <i class="fa-solid fa-award" style="font-size: 5rem; color: rgba(212,175,55,0.2);"></i>
                            </div>
                        }
                        <div class="overlay"></div>
                    </div>

                    <div class="luxury-card-content">
                        <div class="luxury-card-title">@course.Title</div>
                        <div class="luxury-card-meta">
                            <span><i class="fa-regular fa-calendar-days"></i> @course.StartDate.ToString("dd MMM yyyy")</span>
                            <span>#@course.Id</span>
                        </div>
                        <a href="/Instructor/ManageCourse/@course.Id" class="luxury-btn">
                            إدارة المنهج والمحتوى <i class="fa-solid fa-arrow-left-long"></i>
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1 / -1; background: white; border-radius: var(--inst-radius); padding: 80px 20px; text-align: center; border: 2px dashed #e2e8f0; box-shadow: var(--inst-shadow);">
                <div style="width: 90px; height: 90px; background: rgba(212, 175, 55, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; border: 1px solid rgba(212, 175, 55, 0.3);">
                    <i class="fa-solid fa-folder-open" style="font-size: 2.5rem; color: var(--inst-gold);"></i>
                </div>
                <h3 style="color: var(--inst-primary); font-weight: 900; font-size: 1.6rem; margin-bottom: 10px;">لا توجد مسارات مسندة إليك</h3>
                <p style="color: var(--inst-muted); font-size: 1.05rem;">تواصل مع إدارة المركز لربط حسابك بالدورات لتتمكن من رفع المادة العلمية.</p>
            </div>
        }
    </div>
</div>
@{
    ViewData["Title"] = "لوحة تحكم المحاضر";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-grid {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 30px;
        min-height: 70vh;
        margin-top: 100px;
        margin-bottom: 50px;
    }

    .sidebar {
        background: white;
        border-radius: var(--radius-lg);
        padding: 30px 20px;
        box-shadow: var(--shadow-md);
        height: fit-content;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
    }

        .sidebar-menu li {
            margin-bottom: 10px;
        }

        .sidebar-menu a {
            display: block;
            padding: 12px 20px;
            border-radius: var(--radius-md);
            color: #475569;
            font-weight: 600;
            transition: all 0.3s;
        }

            .sidebar-menu a:hover, .sidebar-menu a.active {
                background: rgba(59, 130, 246, 0.1);
                color: var(--secondary-color);
            }

    .course-list-item {
        background: white;
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        padding: 20px;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--shadow-sm);
    }

    @@media (max-width: 992px) {
        .admin-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container admin-grid">
    <!-- القائمة الجانبية للمحاضر -->
    <aside class="sidebar">
        <div style="text-align: center; margin-bottom: 30px;">
            <div style="width: 80px; height: 80px; background: var(--secondary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 15px;">
                <i class="fa-solid fa-chalkboard-user"></i>
            </div>
            <h3 style="color: var(--primary-color);">لوحة المحاضر</h3>
            <p style="color: #64748b; font-size: 0.9rem;">إدارة المحتوى والواجبات</p>
        </div>

        <ul class="sidebar-menu">
            <li><a href="#" class="active"><i class="fa-solid fa-book" style="margin-left: 10px;"></i> دوراتي الحالية</a></li>
            <li><a href="#"><i class="fa-solid fa-tasks" style="margin-left: 10px;"></i> تقييم الواجبات</a></li>
            <li><a href="#"><i class="fa-solid fa-users" style="margin-left: 10px;"></i> متابعة الطلاب</a></li>
        </ul>
    </aside>

    <!-- مساحة العمل الرئيسية -->
    <main>
        <h2 style="color: var(--primary-color); margin-bottom: 25px;">الدورات المسندة إليك</h2>

        <div class="course-list-item">
            <div>
                <h3 style="color: var(--primary-color); margin-bottom: 5px;">دبلومة تطوير واجهات الويب (Front-End)</h3>
                <p style="color: #64748b; font-size: 0.9rem;"><i class="fa-solid fa-users"></i> عدد الطلاب المسجلين: 45 طالب</p>
            </div>
            <div style="display: flex; gap: 10px;">
                <button class="btn btn-outline" style="padding: 10px 15px; font-size: 0.9rem;"><i class="fa-solid fa-upload"></i> رفع محتوى</button>
                <button class="btn btn-primary" style="padding: 10px 15px; font-size: 0.9rem;"><i class="fa-solid fa-plus"></i> إضافة واجب</button>
            </div>
        </div>

        <div class="course-list-item">
            <div>
                <h3 style="color: var(--primary-color); margin-bottom: 5px;">دورة أساسيات البرمجة (C#)</h3>
                <p style="color: #64748b; font-size: 0.9rem;"><i class="fa-solid fa-users"></i> عدد الطلاب المسجلين: 12 طالب</p>
            </div>
            <div style="display: flex; gap: 10px;">
                <button class="btn btn-outline" style="padding: 10px 15px; font-size: 0.9rem;"><i class="fa-solid fa-upload"></i> رفع محتوى</button>
                <button class="btn btn-primary" style="padding: 10px 15px; font-size: 0.9rem;"><i class="fa-solid fa-plus"></i> إضافة واجب</button>
            </div>
        </div>
    </main>
</div>
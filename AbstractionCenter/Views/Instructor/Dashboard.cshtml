@model IEnumerable<AbstractionCenter.Models.Entities.Course>
@{
    ViewData["Title"] = "لوحة تحكم المحاضر";
}

<style>
    .instructor-wrapper {
        padding: 120px 0 60px;
        min-height: 80vh;
    }

    .course-list-item {
        background: white;
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-md);
        padding: 25px;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--shadow-sm);
        transition: transform 0.3s;
    }

        .course-list-item:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }

    @@media (max-width: 768px) {
        .course-list-item {
            flex-direction: column;
            align-items: flex-start;
            gap: 15px;
        }
    }
</style>

<div class="container instructor-wrapper">
    <div style="background: var(--primary-color); color: white; padding: 40px; border-radius: var(--radius-lg); margin-bottom: 40px; display: flex; align-items: center; gap: 20px;">
        <div style="width: 70px; height: 70px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem;">
            <i class="fa-solid fa-chalkboard-user" style="color: var(--secondary-color);"></i>
        </div>
        <div>
            <h2 style="margin: 0; font-size: 2rem;">أهلاً بك، @ViewData["InstructorName"]</h2>
            <p style="margin: 5px 0 0 0; color: #cbd5e1;">هنا يمكنك إدارة الدورات المسندة إليك ومتابعة تقدم طلابك.</p>
        </div>
    </div>

    <h3 style="color: var(--primary-color); margin-bottom: 20px;"><i class="fa-solid fa-layer-group"></i> الدورات الخاصة بك</h3>

    @if (Model != null && Model.Any())
    {
        foreach (var course in Model)
        {
            <div class="course-list-item">
                <div>
                    <h3 style="color: var(--primary-color); margin-bottom: 8px; font-size: 1.3rem;">@course.Title</h3>
                    <p style="color: #64748b; font-size: 0.95rem; margin: 0;"><i class="fa-regular fa-calendar"></i> تاريخ البدء: @course.StartDate.ToString("dd MMM yyyy")</p>
                </div>
                <div style="display: flex; gap: 10px;">
                    <a href="/Instructor/ManageCourse/@course.Id" class="btn btn-primary"><i class="fa-solid fa-folder-gear"></i> إدارة المحتوى والواجبات</a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="glass-card" style="text-align: center; padding: 50px;">
            <i class="fa-solid fa-box-open" style="font-size: 4rem; color: #cbd5e1; margin-bottom: 15px;"></i>
            <h3 style="color: #64748b;">لا يوجد دورات مسندة إليك حالياً.</h3>
            <p style="color: #94a3b8;">تواصل مع إدارة المركز لربط حسابك بالدورات المتاحة.</p>
        </div>
    }
</div>
@model AbstractionCenter.Models.Entities.Course
@{
    ViewData["Title"] = "إدارة محتوى الدورة";
}

<style>
    .manage-wrapper {
        padding: 120px 0 60px;
        min-height: 80vh;
    }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e2e8f0;
        border-radius: var(--radius-md);
        font-family: inherit;
        font-size: 1rem;
        margin-bottom: 15px;
        background: #f8fafc;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--secondary-color);
            background: white;
        }

    .section-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 30px;
        box-shadow: var(--shadow-sm);
        margin-bottom: 30px;
        border: 1px solid var(--glass-border);
    }
</style>

<div class="container manage-wrapper">
    <a href="/Instructor/Dashboard" style="color: var(--secondary-color); margin-bottom: 20px; display: inline-block; font-weight: bold;">
        <i class="fa-solid fa-arrow-right"></i> العودة لقائمة الدورات
    </a>

    <div style="margin-bottom: 30px;">
        <h1 style="color: var(--primary-color);">@(Model?.Title)</h1>
        <p style="color: #64748b; font-size: 1.1rem;">إضافة الواجبات للطلاب ورفع المحتوى التعليمي</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: #10b981; color: white; padding: 15px; border-radius: var(--radius-md); margin-bottom: 20px; font-weight: bold;">
            <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="grid-3" style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">

        <!-- قسم إضافة الواجبات -->
        <div class="section-card">
            <h3 style="color: var(--primary-color); margin-bottom: 20px;"><i class="fa-solid fa-tasks" style="color: var(--secondary-color);"></i> إضافة واجب (Assignment)</h3>

            <form asp-controller="Instructor" asp-action="AddAssignment" method="post">
                <input type="hidden" name="courseId" value="@(Model?.Id)" />

                <label style="font-weight: 600; margin-bottom: 5px; display: block; color: var(--text-dark);">عنوان الواجب</label>
                <input type="text" name="title" class="form-control" placeholder="مثال: إنشاء مشروع التخرج" required />

                <label style="font-weight: 600; margin-bottom: 5px; display: block; color: var(--text-dark);">وصف الواجب</label>
                <textarea name="description" class="form-control" rows="4" placeholder="اكتب تفاصيل المتطلبات هنا..." required></textarea>

                <label style="font-weight: 600; margin-bottom: 5px; display: block; color: var(--text-dark);">تاريخ التسليم (Deadline)</label>
                <input type="date" name="dueDate" class="form-control" required />

                <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px; padding: 12px;"><i class="fa-solid fa-plus"></i> حفظ ونشر للطلاب</button>
            </form>
        </div>

        <!-- قسم رفع المحتوى (UI فقط للتمثيل) -->
        <div class="section-card">
            <h3 style="color: var(--primary-color); margin-bottom: 20px;"><i class="fa-solid fa-cloud-arrow-up" style="color: var(--secondary-color);"></i> رفع محتوى تعليمي</h3>
            <p style="color: #64748b; margin-bottom: 20px;">قم برفع ملفات الـ PDF أو مقاطع الفيديو الخاصة بالدورة ليتمكن الطلاب من مشاهدتها.</p>

            <div style="border: 2px dashed #cbd5e1; padding: 50px 20px; text-align: center; border-radius: var(--radius-md); background: #f8fafc; cursor: pointer; transition: all 0.3s;" onmouseover="this.style.borderColor='var(--secondary-color)'" onmouseout="this.style.borderColor='#cbd5e1'">
                <i class="fa-solid fa-file-arrow-up" style="font-size: 3.5rem; color: #94a3b8; margin-bottom: 15px;"></i>
                <h4 style="color: var(--text-dark); margin-bottom: 5px;">اسحب وأفلت الملفات هنا</h4>
                <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 20px;">أو اضغط لاختيار ملف (PDF, MP4, ZIP)</p>
                <button class="btn btn-outline">تصفح الجهاز</button>
            </div>
        </div>

    </div>
</div>
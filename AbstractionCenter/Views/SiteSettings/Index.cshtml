@model IEnumerable<AbstractionCenter.Models.Entities.SiteSetting>
@{
    ViewData["Title"] = "إعدادات وتصميم الموقع";
    var settingsDict = Model.ToDictionary(s => s.Key, s => s);

    string GetVal(string key) => settingsDict.ContainsKey(key) ? settingsDict[key].Value : "";
    string GetValEn(string key) => settingsDict.ContainsKey(key) ? settingsDict[key].ValueEn ?? "" : "";

    // قائمة الأيقونات الجاهزة للاختيار
    var commonIcons = new[] {
        "fa-solid fa-star", "fa-solid fa-laptop-code", "fa-solid fa-briefcase", "fa-solid fa-chart-line",
        "fa-solid fa-child", "fa-solid fa-language", "fa-solid fa-paintbrush", "fa-solid fa-calculator",
        "fa-solid fa-microchip", "fa-solid fa-network-wired", "fa-solid fa-robot", "fa-solid fa-scale-balanced",
        "fa-solid fa-heart-pulse", "fa-solid fa-users", "fa-solid fa-globe", "fa-solid fa-camera",
        "fa-solid fa-bullhorn", "fa-solid fa-book-open", "fa-solid fa-brain", "fa-solid fa-building-columns"
    };
}

<style>
    .settings-layout {
        display: flex;
        gap: 30px;
        align-items: flex-start;
    }

    /* --- Sidebar (اليمين) --- */
    .settings-sidebar {
        width: 300px;
        background: white;
        border-radius: 24px;
        padding: 30px 20px;
        box-shadow: 0 15px 35px -10px rgba(11, 17, 32, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.15);
        position: sticky;
        top: 100px;
        flex-shrink: 0;
    }

    .sidebar-title {
        color: #0b1120;
        font-size: 1.3rem;
        font-weight: 900;
        margin-bottom: 25px;
        text-align: center;
        border-bottom: 2px solid #f1f5f9;
        padding-bottom: 15px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

        .sidebar-title i {
            color: #d4af37;
        }

    .tab-btn {
        width: 100%;
        text-align: right;
        background: transparent;
        border: none;
        padding: 15px 20px;
        border-radius: 12px;
        font-size: 1.05rem;
        font-weight: 800;
        color: #64748b;
        cursor: pointer;
        transition: 0.3s;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: inherit;
    }

        .tab-btn:hover {
            background: #f8fafc;
            color: #0b1120;
        }

        .tab-btn.active {
            background: #0b1120;
            color: #d4af37;
            box-shadow: 0 5px 15px rgba(11, 17, 32, 0.2);
        }

    .btn-save-publish {
        width: 100%;
        background: linear-gradient(135deg, #d4af37, #fef08a);
        color: #0b1120;
        border: none;
        padding: 18px;
        border-radius: 16px;
        font-weight: 900;
        font-size: 1.15rem;
        cursor: pointer;
        transition: 0.3s;
        margin-top: 20px;
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
        font-family: inherit;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

        .btn-save-publish:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(212, 175, 55, 0.5);
        }

    /* --- Content Area (اليسار) --- */
    .settings-content {
        flex-grow: 1;
    }

    .tab-pane {
        display: none;
        animation: fadeIn 0.4s ease;
    }

        .tab-pane.active {
            display: block;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .setting-card {
        background: white;
        border-radius: 20px;
        padding: 35px;
        margin-bottom: 30px;
        box-shadow: 0 10px 25px rgba(11, 17, 32, 0.05);
        border: 1px solid #e2e8f0;
    }

    .setting-card-title {
        color: #0b1120;
        font-size: 1.25rem;
        font-weight: 900;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .setting-card-title i {
            color: #d4af37;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

    .form-control {
        width: 100%;
        padding: 14px 18px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        font-family: inherit;
        font-size: 1rem;
        background: #f8fafc;
        transition: 0.3s;
    }

        .form-control:focus {
            outline: none;
            border-color: #d4af37;
            background: white;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        }

    .form-row-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .track-box {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 20px;
        position: relative;
        border-right: 4px solid #d4af37;
    }

    .btn-add-track {
        background: rgba(59, 130, 246, 0.1);
        color: #2563eb;
        border: 2px dashed rgba(59, 130, 246, 0.3);
        padding: 20px;
        width: 100%;
        border-radius: 16px;
        font-weight: 900;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        font-family: inherit;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

        .btn-add-track:hover {
            background: #2563eb;
            color: white;
            border-style: solid;
        }

    /* --- Icon Picker Styles --- */
    .icon-picker-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 10px;
    }

    .icon-option {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        background: #ffffff;
        border: 2px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        color: #64748b;
        cursor: pointer;
        transition: 0.3s;
    }

        .icon-option:hover {
            background: rgba(212, 175, 55, 0.1);
            border-color: #d4af37;
            color: #d4af37;
        }

        .icon-option.selected {
            background: #0b1120;
            border-color: #0b1120;
            color: #d4af37;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            transform: scale(1.1);
        }

    /* === Media Queries للموبايل === */
    @@media(max-width: 992px) {
        .settings-layout {
            flex-direction: column;
        }

        .settings-sidebar {
            width: 100%;
            position: static;
            padding: 20px;
        }
    }

    @@media(max-width: 768px) {
        .setting-card {
            padding: 25px 20px;
            border-radius: 16px;
        }

        .form-row-grid {
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .track-box {
            padding: 20px 15px;
        }

        .icon-picker-grid {
            justify-content: center;
        }
    }
</style>

<div>
    <div style="margin-bottom: 30px;">
        <h1 style="color: #0b1120; font-weight: 900; font-size: 2rem;">إعدادات وتصميم الموقع</h1>
        <p style="color: #64748b; font-size: 1.1rem;">تحكم في جميع نصوص وصور الواجهة الرئيسية للمنصة.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: rgba(16, 185, 129, 0.1); color: #059669; padding: 15px 25px; border-radius: 16px; margin-bottom: 30px; font-weight: 800; border: 1px solid #10b981; display: flex; align-items: center; gap: 10px;">
            <i class="fa-solid fa-circle-check" style="font-size: 1.4rem;"></i> @TempData["SuccessMessage"]
        </div>
    }

    <form asp-action="UpdateSettings" method="post" id="settingsForm">
        @Html.AntiForgeryToken()

        <div class="settings-layout">
            <!-- Sidebar -->
            <aside class="settings-sidebar">
                <div class="sidebar-title"><i class="fa-solid fa-crown"></i> لوحة التحكم الملكية</div>
                <button type="button" class="tab-btn active" data-target="tab-general"><i class="fa-solid fa-globe"></i> إعدادات عامة</button>
                <button type="button" class="tab-btn" data-target="tab-home"><i class="fa-solid fa-house"></i> الصفحة الرئيسية</button>
                <button type="button" class="tab-btn" data-target="tab-about"><i class="fa-solid fa-building"></i> صفحة من نحن</button>
                <button type="button" class="tab-btn" data-target="tab-tracks"><i class="fa-solid fa-layer-group"></i> المسارات التعرفية</button>
                <button type="button" class="tab-btn" data-target="tab-contact"><i class="fa-solid fa-address-book"></i> التواصل والسوشيال</button>

                <hr style="border: 0; border-top: 1px solid #e2e8f0; margin: 20px 0;" />
                <button type="submit" class="btn-save-publish"><i class="fa-solid fa-cloud-arrow-up"></i> حفظ ونشر</button>
            </aside>

            <!-- Content Area -->
            <div class="settings-content">

                <!-- تبويب إعدادات عامة -->
                <div id="tab-general" class="tab-pane active">
                    <div class="setting-card">
                        <h3 class="setting-card-title"><i class="fa-solid fa-globe"></i> إعدادات الهوية الأساسية</h3>
                        <div class="form-group">
                            <label>اسم الموقع (عربي)</label>
                            <input type="text" name="settings[SiteName]" value="@GetVal("SiteName")" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>اسم الموقع (إنجليزي)</label>
                            <input type="text" name="settingsEn[SiteName]" value="@GetValEn("SiteName")" class="form-control" dir="ltr" />
                        </div>
                        <div class="form-group">
                            <label>وصف الفوتر (عربي)</label>
                            <textarea name="settings[FooterDesc]" class="form-control" rows="3">@GetVal("FooterDesc")</textarea>
                        </div>
                        <div class="form-group">
                            <label>وصف الفوتر (إنجليزي)</label>
                            <textarea name="settingsEn[FooterDesc]" class="form-control" rows="3" dir="ltr">@GetValEn("FooterDesc")</textarea>
                        </div>
                    </div>
                </div>

                <!-- تبويب الصفحة الرئيسية -->
                <div id="tab-home" class="tab-pane">
                    <div class="setting-card">
                        <h3 class="setting-card-title"><i class="fa-solid fa-house"></i> بانر الصفحة الرئيسية (Hero)</h3>
                        <div class="form-group">
                            <label>العنوان الرئيسي (عربي)</label>
                            <input type="text" name="settings[HeroTitle]" value="@GetVal("HeroTitle")" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>العنوان الرئيسي (إنجليزي)</label>
                            <input type="text" name="settingsEn[HeroTitle]" value="@GetValEn("HeroTitle")" class="form-control" dir="ltr" />
                        </div>
                        <div class="form-group">
                            <label>النبذة المختصرة (عربي)</label>
                            <textarea name="settings[HeroSubtitle]" class="form-control" rows="3">@GetVal("HeroSubtitle")</textarea>
                        </div>
                        <div class="form-group">
                            <label>النبذة المختصرة (إنجليزي)</label>
                            <textarea name="settingsEn[HeroSubtitle]" class="form-control" rows="3" dir="ltr">@GetValEn("HeroSubtitle")</textarea>
                        </div>
                        <div class="form-group">
                            <label>رابط صورة البانر</label>
                            <input type="url" name="settings[HeroImage]" value="@GetVal("HeroImage")" class="form-control" dir="ltr" />
                        </div>
                    </div>
                </div>

                <!-- تبويب من نحن -->
                <div id="tab-about" class="tab-pane">
                    <div class="setting-card">
                        <h3 class="setting-card-title"><i class="fa-solid fa-building"></i> الرؤية والرسالة</h3>
                        <div class="form-group">
                            <label>الرؤية (عربي)</label>
                            <textarea name="settings[About_Vision]" class="form-control" rows="3">@GetVal("About_Vision")</textarea>
                        </div>
                        <div class="form-group">
                            <label>الرؤية (إنجليزي)</label>
                            <textarea name="settingsEn[About_Vision]" class="form-control" rows="3" dir="ltr">@GetValEn("About_Vision")</textarea>
                        </div>
                        <div class="form-group">
                            <label>الرسالة (عربي)</label>
                            <textarea name="settings[About_Mission]" class="form-control" rows="3">@GetVal("About_Mission")</textarea>
                        </div>
                        <div class="form-group">
                            <label>الرسالة (إنجليزي)</label>
                            <textarea name="settingsEn[About_Mission]" class="form-control" rows="3" dir="ltr">@GetValEn("About_Mission")</textarea>
                        </div>
                    </div>
                </div>

                <!-- === تبويب المسارات === -->
                <div id="tab-tracks" class="tab-pane">
                    <div class="setting-card">
                        <h3 class="setting-card-title"><i class="fa-solid fa-layer-group"></i> المسارات المعروضة في الصفحة التعريفية</h3>

                        <!-- إضافة الترويسة لصفحة المسارات كما طلبت -->
                        <div style="background: #f8fafc; padding: 25px; border-radius: 16px; margin-bottom: 30px; border: 1px solid #e2e8f0;">
                            <h4 style="color: #0b1120; font-weight: 900; margin-bottom: 15px;"><i class="fa-solid fa-heading" style="color: #d4af37;"></i> ترويسة صفحة المسارات (Hero Section)</h4>
                            <div class="form-group">
                                <label>العنوان الرئيسي (عربي)</label>
                                <input type="text" name="settings[Tracks_HeroTitle]" value="@GetVal("Tracks_HeroTitle")" class="form-control" />
                            </div>
                            <div class="form-group">
                                <label>العنوان الرئيسي (إنجليزي)</label>
                                <input type="text" name="settingsEn[Tracks_HeroTitle]" value="@GetValEn("Tracks_HeroTitle")" class="form-control" dir="ltr" />
                            </div>
                            <div class="form-group">
                                <label>الوصف (عربي)</label>
                                <textarea name="settings[Tracks_HeroSubtitle]" class="form-control" rows="2">@GetVal("Tracks_HeroSubtitle")</textarea>
                            </div>
                            <div class="form-group">
                                <label>الوصف (إنجليزي)</label>
                                <textarea name="settingsEn[Tracks_HeroSubtitle]" class="form-control" rows="2" dir="ltr">@GetValEn("Tracks_HeroSubtitle")</textarea>
                            </div>
                        </div>

                        <p style="color: #64748b; margin-bottom: 25px;">قم بإضافة مسارات جديدة لتظهر ككروت في صفحة المسارات. اختر الأيقونة المناسبة بنقرة واحدة.</p>

                        <div id="dynamic-tracks-container">
                            @{
                                var trackKeys = settingsDict.Keys.Where(k => k.StartsWith("Track") && k.EndsWith("_Title")).ToList();
                                int maxIndex = 0;

                                foreach (var key in trackKeys)
                                {
                                    string indexStr = key.Replace("Track", "").Replace("_Title", "");
                                    if (int.TryParse(indexStr, out int index))
                                    {
                                        if (index > maxIndex) maxIndex = index;

                                        var currentIcon = GetVal($"Track{index}_Icon");
                                        if (string.IsNullOrEmpty(currentIcon)) currentIcon = "fa-solid fa-star";

                                        <div class="track-box" data-index="@index">
                                            <h4 style="color: #0b1120; font-weight: 900; margin-bottom: 15px;"><i class="fa-solid fa-pen-nib" style="color: #d4af37;"></i> مسار التدريب رقم @index</h4>

                                            <div class="form-row-grid">
                                                <div class="form-group">
                                                    <label>عنوان المسار (عربي)</label>
                                                    <input type="text" name="settings[Track@(index)_Title]" value="@GetVal($"Track{index}_Title")" class="form-control" placeholder="مثال: مسار تطوير الأطفال" />
                                                </div>
                                                <div class="form-group">
                                                    <label>عنوان المسار (إنجليزي)</label>
                                                    <input type="text" name="settingsEn[Track@(index)_Title]" value="@GetValEn($"Track{index}_Title")" class="form-control" dir="ltr" />
                                                </div>
                                            </div>

                                            <div class="form-group">
                                                <label>وصف المسار (عربي)</label>
                                                <textarea name="settings[Track@(index)_Desc]" class="form-control" rows="2">@GetVal($"Track{index}_Desc")</textarea>
                                            </div>
                                            <div class="form-group">
                                                <label>وصف المسار (إنجليزي)</label>
                                                <textarea name="settingsEn[Track@(index)_Desc]" class="form-control" rows="2" dir="ltr">@GetValEn($"Track{index}_Desc")</textarea>
                                            </div>

                                            <div class="form-group">
                                                <label>اختر أيقونة المسار</label>
                                                <!-- الحقل المخفي الذي يحمل قيمة الأيقونة ليتم حفظها -->
                                                <input type="hidden" name="settings[Track@(index)_Icon]" id="icon_input_@index" value="@currentIcon" />
                                                <div class="icon-picker-grid">
                                                    @foreach (var icon in commonIcons)
                                                    {
                                                        <div class="icon-option @(currentIcon == icon ? "selected" : "")" onclick="selectIcon(this, 'icon_input_@index', '@icon')">
                                                            <i class="@icon"></i>
                                                        </div>
                                                    }
                                                </div>
                                            </div>

                                            <small style="color: #ef4444; font-weight: bold;"><i class="fa-solid fa-trash-can"></i> لحذف هذا المسار من الموقع، فقط امسح عنوانه (العربي والإنجليزي) واحفظ التعديلات.</small>
                                        </div>
                                    }
                                }
                            }
                        </div>

                        <button type="button" class="btn-add-track" onclick="addNewTrackForm()">
                            <i class="fa-solid fa-plus-circle"></i> إضافة مسار تدريبي جديد
                        </button>
                    </div>
                </div>

                <!-- تبويب التواصل -->
                <div id="tab-contact" class="tab-pane">
                    <div class="setting-card">
                        <h3 class="setting-card-title"><i class="fa-solid fa-address-book"></i> بيانات التواصل والسوشيال ميديا</h3>
                        <div class="form-row-grid">
                            <div class="form-group">
                                <label><i class="fa-solid fa-phone" style="color: #d4af37;"></i> رقم الهاتف</label>
                                <input type="text" name="settings[ContactPhone]" value="@GetVal("ContactPhone")" class="form-control" dir="ltr" />
                            </div>
                            <div class="form-group">
                                <label><i class="fa-solid fa-envelope" style="color: #d4af37;"></i> البريد الإلكتروني</label>
                                <input type="text" name="settings[ContactEmail]" value="@GetVal("ContactEmail")" class="form-control" dir="ltr" />
                            </div>
                            <div class="form-group">
                                <label><i class="fa-brands fa-facebook" style="color: #3b82f6;"></i> رابط فيسبوك</label>
                                <input type="url" name="settings[Social_Facebook]" value="@GetVal("Social_Facebook")" class="form-control" dir="ltr" />
                            </div>
                            <div class="form-group">
                                <label><i class="fa-brands fa-whatsapp" style="color: #25d366;"></i> رابط الواتساب</label>
                                <input type="url" name="settings[Social_WhatsApp]" value="@GetVal("Social_WhatsApp")" class="form-control" dir="ltr" />
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // نظام التبويبات
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));

                this.classList.add('active');
                document.getElementById(this.getAttribute('data-target')).classList.add('active');
            });
        });

        // دالة اختيار الأيقونة
        function selectIcon(element, inputId, iconClass) {
            let parent = element.parentElement;
            parent.querySelectorAll('.icon-option').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            document.getElementById(inputId).value = iconClass;
        }

        // نظام إضافة المسارات الديناميكي (بما في ذلك منتقي الأيقونات)
        function addNewTrackForm() {
            let maxIndex = 0;
            document.querySelectorAll('.track-box').forEach(el => {
                let index = parseInt(el.getAttribute('data-index'));
                if (index > maxIndex) maxIndex = index;
            });

            if(maxIndex === 0) maxIndex = 3;
            let newIndex = maxIndex + 1;

            // نفس الأيقونات المستخدمة في النموذج أعلاه
            const icons = [
                "fa-solid fa-star", "fa-solid fa-laptop-code", "fa-solid fa-briefcase", "fa-solid fa-chart-line",
                "fa-solid fa-child", "fa-solid fa-language", "fa-solid fa-paintbrush", "fa-solid fa-calculator",
                "fa-solid fa-microchip", "fa-solid fa-network-wired", "fa-solid fa-robot", "fa-solid fa-scale-balanced",
                "fa-solid fa-heart-pulse", "fa-solid fa-users", "fa-solid fa-globe", "fa-solid fa-camera",
                "fa-solid fa-bullhorn", "fa-solid fa-book-open", "fa-solid fa-brain", "fa-solid fa-building-columns"
            ];

            let iconsHtml = icons.map(icon =>
                `<div class="icon-option ${icon === 'fa-solid fa-star' ? 'selected' : ''}" onclick="selectIcon(this, 'icon_input_${newIndex}', '${icon}')">
                    <i class="${icon}"></i>
                </div>`
            ).join('');

            let newHtml = `
                <div class="track-box" data-index="${newIndex}">
                    <h4 style="color: #0b1120; font-weight: 900; margin-bottom: 15px;"><i class="fa-solid fa-pen-nib" style="color: #d4af37;"></i> مسار إضافي جديد</h4>
                    <div class="form-row-grid">
                        <div class="form-group">
                            <label>عنوان المسار (عربي)</label>
                            <input type="text" name="settings[Track${newIndex}_Title]" class="form-control" placeholder="مثال: مسار تطوير الأطفال" required />
                        </div>
                        <div class="form-group">
                            <label>عنوان المسار (إنجليزي)</label>
                            <input type="text" name="settingsEn[Track${newIndex}_Title]" class="form-control" dir="ltr" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>وصف المسار (عربي)</label>
                        <textarea name="settings[Track${newIndex}_Desc]" class="form-control" rows="2" required></textarea>
                    </div>
                    <div class="form-group">
                        <label>وصف المسار (إنجليزي)</label>
                        <textarea name="settingsEn[Track${newIndex}_Desc]" class="form-control" rows="2" dir="ltr"></textarea>
                    </div>
                    <div class="form-group">
                        <label>اختر أيقونة المسار</label>
                        <input type="hidden" name="settings[Track${newIndex}_Icon]" id="icon_input_${newIndex}" value="fa-solid fa-star" />
                        <div class="icon-picker-grid">
                            ${iconsHtml}
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('dynamic-tracks-container').insertAdjacentHTML('beforeend', newHtml);
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
        }
    </script>
}
@model AbstractionCenter.Models.ErrorViewModel
@{
    ViewData["Title"] = "حدث خطأ";
}

<div class="container" style="padding: 150px 0 80px; text-align: center; min-height: 60vh;">
    <i class="fa-solid fa-triangle-exclamation" style="font-size: 5rem; color: var(--accent-color); margin-bottom: 20px;"></i>
    <h1 style="color: var(--primary-color);">عذراً، حدث خطأ غير متوقع!</h1>
    <p style="color: #64748b; font-size: 1.2rem; margin-top: 10px;">نحن نعمل على إصلاح المشكلة في أسرع وقت ممكن.</p>

    @if (Model.ShowRequestId)
    {
        <p style="margin-top: 20px; color: #94a3b8;">
            <strong>رقم الطلب (Request ID):</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a href="/" class="btn btn-primary" style="margin-top: 30px;">العودة للرئيسية</a>
</div>
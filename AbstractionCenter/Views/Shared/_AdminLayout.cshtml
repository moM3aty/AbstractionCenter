<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام إدارة أبستراكشن</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        /* Modern Enterprise Dashboard UI */
        :root {
            --bg-body: #f4f7fe;
            --bg-sidebar: #ffffff;
            --sidebar-text: #a3aed1;
            --sidebar-active-bg: #4318ff;
            --sidebar-active-text: #ffffff;
            --sidebar-hover: #f4f7fe;
            --card-bg: #ffffff;
            --text-main: #2b3674;
            --text-muted: #a3aed1;
            --border-color: #e2e8f0;
            --shadow-card: 0px 18px 40px rgba(112, 144, 176, 0.12);
            --radius-box: 20px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Cairo', sans-serif;
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            overflow-x: hidden;
            min-height: 100vh;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* Sidebar Styling */
        .sidebar {
            width: 280px;
            background-color: var(--bg-sidebar);
            height: 100vh;
            position: fixed;
            right: 0;
            top: 0;
            z-index: 1000;
            box-shadow: 14px 17px 40px 4px rgba(112, 144, 176, 0.08);
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
        }

        .sidebar-header {
            padding: 40px 0 30px 0;
            text-align: center;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 20px;
        }

            .sidebar-header h2 {
                font-weight: 800;
                font-size: 1.8rem;
                color: var(--text-main);
                letter-spacing: -0.5px;
            }

                .sidebar-header h2 span {
                    color: var(--sidebar-active-bg);
                }

        .menu-category {
            padding: 10px 30px;
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-top: 10px;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0 15px;
            flex-grow: 1;
            overflow-y: auto;
        }

            .sidebar-menu li {
                margin-bottom: 5px;
            }

            .sidebar-menu a {
                display: flex;
                align-items: center;
                gap: 15px;
                padding: 14px 20px;
                border-radius: 15px;
                font-weight: 600;
                font-size: 1rem;
                color: #64748b;
                transition: all 0.3s ease;
            }

                .sidebar-menu a i {
                    font-size: 1.2rem;
                    width: 25px;
                    text-align: center;
                }

                .sidebar-menu a:hover {
                    background-color: var(--sidebar-hover);
                    color: var(--sidebar-active-bg);
                    transform: translateX(-5px);
                }

                .sidebar-menu a.active {
                    background-color: var(--sidebar-active-bg);
                    color: var(--sidebar-active-text);
                    box-shadow: 0 10px 20px rgba(67, 24, 255, 0.2);
                }

        /* Main Content Wrapper */
        .main-wrapper {
            margin-right: 280px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            width: calc(100% - 280px);
            transition: all 0.3s ease;
        }

        /* Top Navbar */
        .top-navbar {
            height: 90px;
            padding: 0 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(244, 247, 254, 0.9);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-main);
        }

        .page-breadcrumb {
            font-size: 0.9rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .top-actions {
            display: flex;
            align-items: center;
            gap: 20px;
            background: white;
            padding: 10px 20px;
            border-radius: 30px;
            box-shadow: var(--shadow-card);
        }

        .search-bar {
            display: flex;
            align-items: center;
            background: var(--bg-body);
            border-radius: 20px;
            padding: 8px 20px;
        }

            .search-bar input {
                border: none;
                background: transparent;
                outline: none;
                padding-right: 10px;
                font-family: inherit;
                width: 200px;
            }

            .search-bar i {
                color: var(--text-main);
            }

        .icon-btn {
            color: var(--text-muted);
            font-size: 1.2rem;
            cursor: pointer;
            transition: 0.3s;
        }

            .icon-btn:hover {
                color: var(--sidebar-active-bg);
            }

        .user-profile {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--sidebar-active-bg);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            cursor: pointer;
        }

        /* Content Area */
        .content-area {
            padding: 30px 40px 60px;
            flex-grow: 1;
        }

        /* Common Card Style for Admin Pages */
        .admin-card {
            background: var(--card-bg);
            border-radius: var(--radius-box);
            padding: 30px;
            box-shadow: var(--shadow-card);
            border: none;
            margin-bottom: 30px;
        }

        @@media (max-width: 1024px) {
            .sidebar

        {
            transform: translateX(100%);
        }

        .main-wrapper {
            margin-right: 0;
            width: 100%;
        }

        .top-navbar {
            padding: 0 20px;
        }

        .content-area {
            padding: 20px;
        }

        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2>أبستراكشن <span>.</span></h2>
        </div>

        <ul class="sidebar-menu">
            @if (User.IsInRole("Admin"))
            {
                <div class="menu-category">النظرة العامة</div>
                <li><a href="/Admin/Index" class="active"><i class="fa-solid fa-house"></i> لوحة القيادة</a></li>

                <div class="menu-category">العمليات التعليمية</div>
                <li><a href="/Admin/ManageCourses"><i class="fa-solid fa-layer-group"></i> المسارات والدورات</a></li>
                <li><a href="/Admin/RegistrationRequests"><i class="fa-solid fa-inbox"></i> طلبات الانضمام</a></li>
                <li><a href="/Admin/Certificates"><i class="fa-solid fa-certificate"></i> إدارة الشهادات</a></li>

                <div class="menu-category">إدارة النظام</div>
                <li><a href="/Admin/ManageUsers"><i class="fa-solid fa-users-gear"></i> المستخدمين والصلاحيات</a></li>

                <li><a href="/SiteSettings/Index"><i class="fa-solid fa-palette"></i> تصميم ومحتوى الموقع</a></li>
            }
            else if (User.IsInRole("Instructor"))
            {
                <div class="menu-category">إدارة التدريب</div>
                <li><a href="/Instructor/Dashboard" class="active"><i class="fa-solid fa-chalkboard-user"></i> دوراتي المسندة</a></li>
            }
        </ul>

        <div style="padding: 20px;">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" style="width: 100%; background: rgba(255, 59, 48, 0.1); color: #ff3b30; border: none; padding: 15px; border-radius: 15px; font-weight: bold; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; font-family: inherit; font-size: 1rem; transition: 0.3s;">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i> تسجيل الخروج
                </button>
            </form>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
        <!-- Top Navbar -->
        

        <!-- Dynamic Content (هذا هو السطر الذي كان مفقوداً ويسبب الخطأ) -->
        <div class="content-area">
            @RenderBody()
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
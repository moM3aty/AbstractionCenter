@using Microsoft.AspNetCore.Localization
@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isRtl = requestCulture?.RequestCulture.UICulture.Name == "ar" || requestCulture?.RequestCulture.UICulture.Name == null;
    ViewData["Title"] = isRtl ? "تسجيل الدخول" : "Login";
}

<style>
    .auth-bg {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        padding: 120px 20px 60px;
        position: relative;
    }

        .auth-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23d4af37\' fill-opacity=\'0.05\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
        }

    .auth-card {
        display: flex;
        max-width: 1000px;
        width: 100%;
        background: white;
        border-radius: 30px;
        box-shadow: 0 25px 50px -12px rgba(11, 17, 32, 0.25);
        overflow: hidden;
        border: 1px solid rgba(212, 175, 55, 0.2);
        position: relative;
        z-index: 10;
        flex-direction: @(isRtl ? "row" : "row-reverse");
    }

    .auth-form-section {
        flex: 1.2;
        padding: 60px 50px;
        text-align: @(isRtl ? "right" : "left");
    }

    .auth-image-section {
        flex: 0.8;
        background: linear-gradient(135deg, var(--primary-color), #1e293b);
        color: white;
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        text-align: center;
        position: relative;
    }

        .auth-image-section::after {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            @(isRtl ? "left" : "right"): 0;
            width: 6px;
            background: var(--secondary-color);
        }

        .auth-image-section i {
            font-size: 6rem;
            color: var(--secondary-color);
            margin-bottom: 30px;
            filter: drop-shadow(0 10px 15px rgba(212, 175, 55, 0.3));
        }

        .auth-image-section h3 {
            color: white;
            font-size: 2.2rem;
            font-weight: 900;
            margin-bottom: 15px;
        }

        .auth-image-section p {
            color: #cbd5e1;
            font-size: 1.15rem;
            line-height: 1.8;
        }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-weight: 800;
            color: var(--primary-color);
            font-size: 1.05rem;
        }

    .form-control {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        font-family: inherit;
        font-size: 1.05rem;
        background: #f8fafc;
        transition: 0.3s;
        text-align: @(isRtl ? "right" : "left");
    }

        .form-control:focus {
            outline: none;
            border-color: var(--secondary-color);
            background: white;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        }

    .btn-login {
        background: linear-gradient(135deg, var(--secondary-color), #fef08a);
        color: var(--primary-color);
        border: none;
        padding: 18px;
        width: 100%;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.2rem;
        cursor: pointer;
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.3);
        transition: all 0.4s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 15px;
        font-family: inherit;
    }

        .btn-login:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(212, 175, 55, 0.5);
        }

    @@media (max-width: 992px) {
        .auth-card {
            flex-direction: column-reverse;
        }

        .auth-image-section {
            padding: 40px 20px;
        }

            .auth-image-section::after {
                width: 100%;
                height: 6px;
                top: auto;
                left: 0;
                bottom: 0;
            }

        .auth-form-section {
            padding: 40px 30px;
        }
    }
</style>

<div class="auth-bg">
    <div class="auth-card">
        <div class="auth-form-section">
            <h2 style="font-size: 2.5rem; color: var(--primary-color); margin-bottom: 10px; font-weight: 900;">@(isRtl ? "مرحباً بعودتك!" : "Welcome Back!")</h2>
            <p style="color: #64748b; margin-bottom: 40px; font-size: 1.15rem;">@(isRtl ? "سجل دخولك للوصول إلى مساحتك الأكاديمية الملكية." : "Sign in to access your premium academic space.")</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background: rgba(239, 68, 68, 0.1); color: #dc2626; padding: 20px; border-radius: 16px; margin-bottom: 30px; font-weight: 800; border: 1px solid rgba(239, 68, 68, 0.2);">
                    @Html.ValidationSummary(false, "", new { @style = "list-style-type: none; margin: 0; padding: 0;" })
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label for="email">@(isRtl ? "البريد الإلكتروني" : "Email Address")</label>
                    <input type="email" id="email" name="email" class="form-control" placeholder="name@example.com" required dir="ltr" style="text-align: left;" />
                </div>

                <div class="form-group">
                    <label for="password">@(isRtl ? "كلمة المرور" : "Password")</label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required dir="ltr" style="text-align: left;" />
                </div>

                <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
                    <input type="checkbox" id="rememberMe" name="rememberMe" style="width: 20px; height: 20px; accent-color: var(--secondary-color); cursor: pointer;" />
                    <label for="rememberMe" style="margin: 0; font-weight: 700; cursor: pointer; color: #475569;">@(isRtl ? "تذكر بيانات الدخول" : "Remember me")</label>
                </div>

                <button type="submit" class="btn-login">
                    @(isRtl ? "تسجيل الدخول" : "Login") <i class="fa-solid @(isRtl ? "fa-arrow-left-to-bracket" : "fa-arrow-right-to-bracket")" style="margin-@(isRtl ? "right" : "left"): 8px;"></i>
                </button>

                <p style="text-align: center; margin-top: 30px; color: #64748b; font-weight: 700; font-size: 1.05rem;">
                    <i class="fa-solid fa-lock" style="color: var(--secondary-color);"></i> @(isRtl ? "منصة مغلقة: الحسابات تُمنح للمسجلين رسمياً فقط." : "Closed Platform: Accounts are granted to officially registered users only.")
                </p>
            </form>
        </div>

        <div class="auth-image-section">
            <i class="fa-solid fa-crown"></i>
            <h3>@(isRtl ? "ابستراكشن سنتر" : "Abstraction Center")</h3>
            <p>@(isRtl ? "بوابتك نحو التميز الأكاديمي والمهني. تابع تقدمك وتفاعل مع دوراتك في بيئة تعليمية راقية ومتطورة." : "Your gateway to academic and professional excellence. Track your progress and interact with your courses in a refined educational environment.")</p>
        </div>
    </div>
</div>
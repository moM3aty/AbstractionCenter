@{
    ViewData["Title"] = "صلاحيات غير كافية";
}

<style>
    .denied-bg {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8fafc, #e2e8f0);
        padding: 40px 20px;
    }

    .denied-card {
        background: white;
        padding: 60px 50px;
        border-radius: 30px;
        box-shadow: 0 25px 50px -12px rgba(11, 17, 32, 0.2);
        max-width: 600px;
        width: 100%;
        text-align: center;
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-top: 8px solid #ef4444;
    }

    .denied-icon {
        width: 120px;
        height: 120px;
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        margin: 0 auto 30px;
        box-shadow: 0 15px 30px rgba(239, 68, 68, 0.2);
    }

    .denied-card h1 {
        color: #0b1120;
        font-size: 2.2rem;
        font-weight: 900;
        margin-bottom: 15px;
    }

    .denied-card p {
        color: #64748b;
        font-size: 1.15rem;
        line-height: 1.8;
        margin-bottom: 40px;
    }

    .btn-actions {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-home {
        background: linear-gradient(135deg, #0b1120, #1e293b);
        color: #d4af37;
        padding: 16px 35px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.1rem;
        text-decoration: none;
        transition: 0.3s;
        box-shadow: 0 10px 25px rgba(11, 17, 32, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-home:hover {
            transform: translateY(-3px);
            color: white;
            box-shadow: 0 15px 35px rgba(11, 17, 32, 0.5);
        }

    .btn-logout {
        background: white;
        color: #ef4444;
        border: 2px solid #ef4444;
        padding: 14px 35px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.1rem;
        cursor: pointer;
        transition: 0.3s;
        font-family: inherit;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-logout:hover {
            background: #ef4444;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(239, 68, 68, 0.3);
        }

    /* === Media Queries للموبايل والشاشات الصغيرة === */
    @@media (max-width: 768px) {
        .denied-card {
            padding: 40px 25px;
            border-radius: 20px;
        }

        .denied-icon {
            width: 90px;
            height: 90px;
            font-size: 3rem;
            margin-bottom: 20px;
        }

        .denied-card h1 {
            font-size: 1.8rem;
        }

        .denied-card p {
            font-size: 1rem;
            margin-bottom: 30px;
        }

        .btn-actions {
            flex-direction: column;
            gap: 12px;
        }

        .btn-home, .btn-logout {
            width: 100%;
            padding: 14px 20px;
        }
    }
</style>

<div class="denied-bg">
    <div class="denied-card">
        <div class="denied-icon">
            <i class="fa-solid fa-lock"></i>
        </div>
        <h1>الوصول مرفوض!</h1>
        <p>عذراً، الحساب الذي تستخدمه حالياً لا يمتلك الصلاحيات الأمنية اللازمة لعرض هذه الصفحة أو تنفيذ هذا الإجراء.</p>

        <div class="btn-actions">
            <a href="/" class="btn-home"><i class="fa-solid fa-house"></i> العودة للرئيسية</a>

            <form asp-controller="Account" asp-action="Logout" method="post" style="margin: 0; width: 100%;">
                <button type="submit" class="btn-logout" style="width: 100%;"><i class="fa-solid fa-arrow-right-from-bracket"></i> تسجيل خروج</button>
            </form>
        </div>
    </div>
</div>
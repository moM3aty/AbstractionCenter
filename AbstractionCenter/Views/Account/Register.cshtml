@{
    ViewData["Title"] = "إنشاء حساب جديد";
}

<style>
    /* نستخدم نفس تصميم الـ Container الخاص بصفحة تسجيل الدخول لتوحيد الهوية */
    .auth-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 20px 60px;
        background: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23cda434\' fill-opacity=\'0.05\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E') #f8fafc;
    }

    .auth-card {
        display: flex;
        max-width: 1000px;
        width: 100%;
        background: white;
        border-radius: 30px;
        box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.25);
        overflow: hidden;
        border: 1px solid var(--glass-border);
    }

    .auth-form-section {
        flex: 1.3;
        padding: 50px 50px;
    }

    .auth-image-section {
        flex: 0.7;
        background: linear-gradient(135deg, var(--primary-color), #0f172a);
        color: white;
        padding: 50px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        text-align: center;
        position: relative;
    }

        .auth-image-section::after {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 0;
            width: 5px;
            background: var(--secondary-color);
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 700;
            color: var(--text-dark);
        }

    .form-control {
        width: 100%;
        padding: 14px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 15px;
        font-family: inherit;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #f8fafc;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--secondary-color);
            background: white;
            box-shadow: 0 0 0 4px rgba(205, 164, 52, 0.15);
        }

    .auth-btn {
        width: 100%;
        padding: 15px;
        font-size: 1.1rem;
        margin-top: 15px;
    }

    @@media (max-width: 992px) {
        .auth-card {
            flex-direction: column-reverse;
        }

        .auth-image-section {
            padding: 40px;
        }

            .auth-image-section::after {
                width: 100%;
                height: 5px;
                top: auto;
                left: 0;
            }
    }
</style>

<div class="auth-container">
    <div class="auth-card">

        <div class="auth-form-section">
            <h2 style="font-size: 2.2rem; color: var(--primary-color); margin-bottom: 10px; font-weight: 900;">عضوية جديدة</h2>
            <p style="color: #64748b; margin-bottom: 30px; font-size: 1.05rem;">انضم إلى صرحنا التعليمي وابدأ رحلتك نحو القمة.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 15px; border-radius: 12px; margin-bottom: 25px; font-weight: 700; border: 1px solid rgba(239, 68, 68, 0.2);">
                    @Html.ValidationSummary(false, "", new { @style = "list-style-type: none; margin: 0; padding: 0;" })
                </div>
            }

            <form asp-controller="Account" asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label for="fullName">الاسم بالكامل</label>
                    <input type="text" id="fullName" name="fullName" class="form-control" placeholder="أدخل اسمك الثلاثي أو الرباعي..." required />
                </div>

                <div class="form-group">
                    <label for="email">البريد الإلكتروني</label>
                    <input type="email" id="email" name="email" class="form-control" placeholder="name@example.com" required />
                </div>

                <div class="form-group" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label for="password">كلمة المرور</label>
                        <input type="password" id="password" name="password" class="form-control" placeholder="********" required />
                    </div>
                    <div>
                        <label for="confirmPassword">تأكيد كلمة المرور</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="********" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary auth-btn">تأكيد العضوية <i class="fa-solid fa-user-plus" style="margin-right: 8px;"></i></button>

                <p style="text-align: center; margin-top: 25px; color: #64748b; font-weight: 600;">
                    لديك حساب بالفعل؟ <a href="/Account/Login" style="color: var(--primary-color); border-bottom: 2px solid var(--secondary-color); padding-bottom: 2px;">سجل دخولك من هنا</a>
                </p>
            </form>
        </div>

        <div class="auth-image-section">
            <i class="fa-solid fa-graduation-cap" style="font-size: 5rem; margin-bottom: 20px; color: var(--secondary-color);"></i>
            <h3 style="font-size: 1.8rem; margin-bottom: 15px; font-weight: 900;">استثمر في ذاتك</h3>
            <p style="font-size: 1.1rem; color: #cbd5e1; line-height: 1.8;">
                خطوة واحدة تفصلك عن الوصول لمحتوى تدريبي احترافي، يضعك على الطريق الصحيح للتميز في سوق العمل.
            </p>
        </div>

    </div>
</div>
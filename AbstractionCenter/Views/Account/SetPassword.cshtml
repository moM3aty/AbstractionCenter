@model string // The Token Code
@{
    ViewData["Title"] = "إعداد كلمة المرور";
    string userId = Context.Request.Query["userId"];
    string code = Context.Request.Query["code"];
}

<style>
    .setpass-bg {
        background: #f8fafc;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .setpass-card {
        background: white;
        border-radius: 24px;
        padding: 50px;
        box-shadow: 0 25px 50px -12px rgba(11, 17, 32, 0.15);
        max-width: 500px;
        width: 100%;
        border: 1px solid rgba(212, 175, 55, 0.2);
    }

    .setpass-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .setpass-header i {
            font-size: 3.5rem;
            color: #d4af37;
            margin-bottom: 15px;
        }

        .setpass-header h2 {
            font-size: 2rem;
            font-weight: 900;
            color: #0b1120;
            margin-bottom: 10px;
        }

        .setpass-header p {
            color: #64748b;
            font-size: 1.05rem;
            line-height: 1.6;
        }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 800;
            color: #0b1120;
            font-size: 1rem;
        }

    .form-control {
        width: 100%;
        padding: 16px 20px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: #f8fafc;
        font-family: inherit;
        font-size: 1rem;
        transition: 0.3s;
    }

        .form-control:focus {
            outline: none;
            border-color: #d4af37;
            background: white;
            box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        }

    .btn-submit {
        width: 100%;
        background: linear-gradient(135deg, #0b1120, #1e293b);
        color: #d4af37;
        border: none;
        padding: 18px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.15rem;
        cursor: pointer;
        box-shadow: 0 10px 25px -5px rgba(11, 17, 32, 0.4);
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-family: inherit;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px -5px rgba(11, 17, 32, 0.6);
            color: white;
        }

    .alert-error {
        background: rgba(239, 68, 68, 0.1);
        color: #dc2626;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-weight: bold;
        text-align: center;
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

    /* === Media Queries للموبايل === */
    @@media (max-width: 576px) {
        .setpass-card {
            padding: 35px 25px;
            border-radius: 20px;
        }

        .setpass-header i {
            font-size: 3rem;
        }

        .setpass-header h2 {
            font-size: 1.7rem;
        }

        .setpass-header p {
            font-size: 0.95rem;
        }

        .form-control {
            padding: 14px 16px;
        }

        .btn-submit {
            font-size: 1.05rem;
            padding: 16px;
        }
    }
</style>

<div class="setpass-bg">
    <div class="setpass-card">

        <div class="setpass-header">
            <i class="fa-solid fa-lock"></i>
            <h2>إعداد كلمة المرور الخاصة بك</h2>
            <p>أهلاً بك في منصتنا! يرجى اختيار كلمة مرور قوية لتفعيل حسابك والوصول لدوراتك.</p>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-error">@TempData["ErrorMessage"]</div>
        }

        <form asp-controller="Account" asp-action="SetPassword" method="post">
            <input type="hidden" name="userId" value="@userId" />
            <input type="hidden" name="code" value="@code" />

            <div class="form-group">
                <label>كلمة المرور الجديدة</label>
                <input type="password" name="password" class="form-control" required minlength="6" dir="ltr" />
            </div>

            <div class="form-group" style="margin-bottom: 30px;">
                <label>تأكيد كلمة المرور</label>
                <input type="password" name="confirmPassword" class="form-control" required minlength="6" dir="ltr" />
            </div>

            <button type="submit" class="btn-submit">
                حفظ ودخول المنصة <i class="fa-solid fa-arrow-right-to-bracket"></i>
            </button>
        </form>
    </div>
</div>
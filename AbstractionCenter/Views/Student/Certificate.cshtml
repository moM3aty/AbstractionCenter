@using Microsoft.AspNetCore.Localization
@model AbstractionCenter.Models.Entities.Certificate
@{
    Layout = null;

    // اكتشاف اللغة الحالية
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "ar";
    bool isRtl = currentCulture == "ar";
}

<!DOCTYPE html>
<html lang="@currentCulture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(isRtl ? "شهادة إتمام" : "Certificate of Completion") - @Model.Student.FullName</title>

    <!-- خطوط عربية وإنجليزية فاخرة -->
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@400;600;700;900&family=Playfair+Display:wght@600;700;900&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --royal-navy: #0b1120;
            --royal-gold: #c5a059;
            --royal-gold-dark: #8e6d2f;
            --cert-bg: #ffffff;
        }

        /* إعدادات الطباعة الدقيقة A4 Landscape */
        @@page {
            size: A4 landscape;
            margin: 0;
        }

        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        body {
            margin: 0;
            padding: 0;
            background: #1a1a1a;
            font-family: @(isRtl ? "'Cairo', sans-serif" : "'Outfit', sans-serif");
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        /* حاوية التمرير للهواتف الذكية */
        .cert-scroll-wrapper {
            width: 100%;
            overflow-x: auto;
            display: flex;
            justify-content: center;
            padding: 20px;
        }

        /* الحاوية الرئيسية بمقاسات A4 دقيقة (297mm x 210mm) */
        .certificate-canvas {
            width: 297mm;
            height: 210mm;
            background: var(--cert-bg);
            position: relative;
            overflow: hidden;
            display: flex;
            padding: 10mm;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
            page-break-after: avoid;
            page-break-inside: avoid;
            flex-shrink: 0; /* منع الانضغاط داخل الـ flex */
        }

        /* الخلفية الزخرفية */
        .cert-bg-overlay {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 50% 50%, rgba(197, 160, 89, 0.02) 0%, transparent 80%), url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cpath d="M30 30l15 15m-30 0l15-15" stroke="%23c5a059" stroke-opacity="0.03" stroke-width="1" fill="none"/%3E%3C/svg%3E');
            pointer-events: none;
            z-index: 1;
        }

        /* إطارات الحماية والزخرفة */
        .cert-border-outer {
            position: absolute;
            inset: 5mm;
            border: 1px solid var(--royal-gold);
            pointer-events: none;
            z-index: 2;
        }

        .cert-border-inner {
            position: absolute;
            inset: 8mm;
            border: 5px double var(--royal-navy);
            pointer-events: none;
            z-index: 2;
        }

        /* الأركان الكلاسيكية */
        .corner {
            position: absolute;
            width: 80px;
            height: 80px;
            z-index: 10;
            border: 4px solid var(--royal-gold);
        }

        .corner-tr { top: 0; right: 0; border-left: none; border-bottom: none; }
        .corner-tl { top: 0; left: 0; border-right: none; border-bottom: none; }
        .corner-br { bottom: 0; right: 0; border-left: none; border-top: none; }
        .corner-bl { bottom: 0; left: 0; border-right: none; border-top: none; }

        /* المحتوى المركزي */
        .cert-main-wrapper {
            flex: 1;
            z-index: 5;
            display: flex;
            flex-direction: column;
            padding: 15px 40px;
            border: 1px solid rgba(197, 160, 89, 0.3);
            background: rgba(255, 255, 255, 0.85);
        }

        /* ترويسة الشهادة */
        .cert-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 5px;
        }

        .brand-box {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .brand-logo-icon {
            font-size: 2.8rem;
            color: var(--royal-gold);
        }

        .brand-text h2 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 900;
            color: var(--royal-navy);
        }

        .brand-text span {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--royal-gold);
            letter-spacing: 2px;
            display: block;
            margin-top: -3px;
        }

        .serial-tag {
            background: var(--royal-navy);
            color: white;
            padding: 8px 18px;
            border-radius: 4px;
            text-align: center;
            box-shadow: @(isRtl ? "-3px" : "3px") 3px 0px var(--royal-gold);
        }

        .serial-tag small {
            display: block;
            font-size: 0.55rem;
            color: var(--royal-gold);
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 2px;
        }

        .serial-tag strong {
            font-family: 'Courier New', monospace;
            font-size: 1rem;
        }

        /* جسم الشهادة */
        .cert-body {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .title-group {
            margin-bottom: 10px;
        }

        .main-title {
            font-size: 3rem;
            font-weight: 900;
            color: var(--royal-navy);
            margin: 0;
            line-height: 1;
            text-transform: uppercase;
        }

        .sub-title {
            font-size: 0.85rem;
            color: var(--royal-gold);
            font-weight: 800;
            letter-spacing: @(isRtl ? "10px" : "8px");
            text-transform: uppercase;
            margin-top: 5px;
        }

        .intro-phrase {
            font-size: 1.1rem;
            color: #555;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .recipient-name {
            font-size: 2.8rem;
            font-weight: 900;
            color: var(--royal-navy);
            margin: 5px 0 10px;
            font-family: @(isRtl ? "'Amiri', serif" : "'Playfair Display', serif");
            position: relative;
            padding-bottom: 5px;
            text-transform: capitalize;
        }

        .recipient-name::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 15%;
            width: 70%;
            height: 2px;
            background: linear-gradient(to left, transparent, var(--royal-gold), transparent);
        }

        .statement-text {
            font-size: 1rem;
            color: #444;
            max-width: 800px;
            line-height: 1.6;
            margin-top: 5px;
            font-weight: 600;
        }

        .statement-text strong {
            color: var(--royal-navy);
            font-weight: 900;
            border-bottom: 2px solid rgba(197, 160, 89, 0.3);
            padding: 0 4px;
        }

        /* تذييل الشهادة - الإجبار على البقاء في الأسفل */
        .cert-footer {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: auto;
            padding-top: 10px;
        }

        .signature-box {
            text-align: center;
            width: 180px;
        }

        .sig-line {
            width: 100%;
            height: 1.5px;
            background: var(--royal-navy);
            margin-bottom: 5px;
        }

        .sig-name {
            font-weight: 900;
            color: var(--royal-navy);
            font-size: 0.95rem;
        }

        .sig-rank {
            font-size: 0.7rem;
            color: var(--royal-gold);
            font-weight: 800;
        }

        .qr-seal {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .qr-frame {
            padding: 4px;
            background: white;
            border: 1.5px solid var(--royal-gold);
            border-radius: 8px;
            margin-bottom: 4px;
        }

        .qr-frame img {
            width: 60px;
            height: 60px;
            display: block;
        }

        .qr-text {
            font-size: 0.6rem;
            font-weight: 900;
            color: #999;
        }

        /* أزرار التحكم */
        .controls-overlay {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 15px;
            z-index: 1000;
        }

        .btn-royal {
            padding: 12px 30px;
            border-radius: 50px;
            border: none;
            font-family: inherit;
            font-weight: 900;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            transition: 0.3s;
            font-size: 0.95rem;
            white-space: nowrap;
        }

        .btn-gold-action { background: var(--royal-gold); color: white; }
        .btn-white-action { background: white; color: var(--royal-navy); text-decoration: none; }
        .btn-royal:hover { transform: translateY(-3px); }

        /* استعلامات الشاشة للموبايل */
        @@media screen and (max-width: 1100px) {
            .cert-scroll-wrapper {
                justify-content: flex-start;
                align-items: flex-start;
            }
            body {
                align-items: flex-start;
            }
        }

        @@media screen and (max-width: 768px) {
            .controls-overlay {
                position: static;
                transform: none;
                flex-direction: column;
                width: 100%;
                padding: 0 20px;
                margin-top: 20px;
            }

            .btn-royal {
                width: 100%;
                padding: 15px;
            }
            
            body {
                flex-direction: column;
            }
        }

        /* تنظيف إعدادات الطباعة للحصول على دقة 100% */
        @@media print {
            html, body {
                width: 297mm;
                height: 210mm;
                background: white;
                margin: 0;
                padding: 0;
                overflow: hidden;
            }
            
            .cert-scroll-wrapper { padding: 0; overflow: visible; display: block; }
            .controls-overlay { display: none !important; }
            
            .certificate-canvas {
                box-shadow: none !important;
                margin: 0 !important;
                padding: 10mm !important;
                border: none !important;
                transform: scale(1) !important;
            }
        }
    </style>
</head>
<body>

    <div class="cert-scroll-wrapper">
        <div class="certificate-canvas">
            <div class="cert-bg-overlay"></div>

            <!-- Frames -->
            <div class="cert-border-outer"></div>
            <div class="cert-border-inner"></div>

            <!-- Royal Corners -->
            <div class="corner corner-tr"></div>
            <div class="corner corner-tl"></div>
            <div class="corner corner-br"></div>
            <div class="corner corner-bl"></div>

            <div class="cert-main-wrapper">
                <!-- Header Section -->
                <header class="cert-header">
                    <div class="brand-box">
                        <i class="fa-solid fa-crown brand-logo-icon"></i>
                        <div class="brand-text">
                            <h2>@(isRtl ? "أبستراكشن" : "Abstraction")</h2>
                            <span>ABSTRACTION CENTER</span>
                        </div>
                    </div>
                    <div class="serial-tag">
                        <small>@(isRtl ? "الرقم المرجعي" : "Serial Number")</small>
                        <strong>@Model.UniqueSerialNumber</strong>
                    </div>
                </header>

                <!-- Body Section -->
                <div class="cert-body">
                    <div class="title-group">
                        <h1 class="main-title">@(isRtl ? "شهادة إتمام" : "Certificate of Completion")</h1>
                        <div class="sub-title">@(isRtl ? "Certificate of Completion" : "شهادة إتمام")</div>
                    </div>

                    <p class="intro-phrase">
                        @(isRtl ? "يشهد مركز أبستراكشن للتدريب والاستشارات بأن الفاضل/ـة:" : "Abstraction Center for Training & Consulting certifies that:")
                    </p>

                    <div class="recipient-name">@Model.Student.FullName</div>

                    <p class="statement-text">
                        @(isRtl ? "قد اجتاز/ت بنجاح كافة متطلبات المسار التدريبي التخصصي المكثف بعنوان:" : "Has successfully completed all requirements of the intensive specialized training track titled:")<br>

                        <strong>@Model.Batch.Course.Title</strong><br>

                        @(isRtl ? "بمعدل ساعات تدريبية معتمدة، مع إتمام كافة المشاريع العملية والتقييمات المقررة بنجاح،" : "with accredited training hours, successfully completing all practical projects and scheduled assessments,")<br>

                        @(isRtl ? "وذلك في تاريخ" : "on the date of") <strong>@Model.IssueDate.ToString("dd MMMM yyyy")</strong>.
                    </p>
                </div>

                <!-- Footer Section -->
                <footer class="cert-footer">
                    <div class="signature-box">
                        <div class="sig-line"></div>
                        <div class="sig-name">@Model.Batch.Instructor.FullName</div>
                        <div class="sig-rank">@(isRtl ? "محاضر المسار المعتمد" : "Certified Track Instructor")</div>
                    </div>

                    <div class="qr-seal">
                        <div class="qr-frame">
                            <img src="@ViewBag.QRCodeBase64" alt="Verify QR" />
                        </div>
                        <div class="qr-text">@(isRtl ? "امسح للتحقق من الموثوقية" : "Scan to Verify")</div>
                    </div>

                    <div class="signature-box">
                        <div class="sig-line"></div>
                        <div class="sig-name">@(isRtl ? "إدارة الأكاديمية" : "Academy Administration")</div>
                        <div class="sig-rank">@(isRtl ? "مركز أبستراكشن للتدريب" : "Abstraction Training Center")</div>
                    </div>
                </footer>
            </div>
        </div>
    </div>

    <!-- UI Controls -->
    <div class="controls-overlay">
        <button class="btn-royal btn-gold-action" onclick="window.print()">
            <i class="fa-solid fa-file-pdf"></i> @(isRtl ? "حفظ الشهادة (PDF)" : "Save Certificate (PDF)")
        </button>
        <a href="/Student/Dashboard" class="btn-royal btn-white-action">
            <i class="fa-solid fa-arrow-right"></i> @(isRtl ? "العودة للوحة التحكم" : "Back to Dashboard")
        </a>
    </div>

</body>
</html>
@model AbstractionCenter.Models.Entities.Certificate
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>شهادة إتمام - @Model.Student.FullName</title>
    <!-- خطوط عربية فاخرة -->
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --royal-navy: #0b1120;
            --royal-gold: #c5a059;
            --royal-gold-dark: #8e6d2f;
            --cert-bg: #ffffff;
        }

        /* إعدادات الطباعة الدقيقة A4 */
        @@page {
            size: A4 landscape;
            margin: 0;
        }

        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        body {
            margin: 0;
            padding: 0;
            background: #1a1a1a;
            font-family: 'Cairo', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        /* الحاوية الرئيسية بمقاسات A4 دقيقة */
        .certificate-canvas {
            width: 297mm;
            height: 250mm;
            background: var(--cert-bg);
            position: relative;
            overflow: hidden;
            display: flex;
            padding: 12mm;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
        }

        /* الخلفية الزخرفية */
        .cert-bg-overlay {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 50% 50%, rgba(197, 160, 89, 0.02) 0%, transparent 80%), url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cpath d="M30 30l15 15m-30 0l15-15" stroke="%23c5a059" stroke-opacity="0.03" stroke-width="1" fill="none"/%3E%3C/svg%3E');
            pointer-events: none;
        }

        /* إطارات الحماية والزخرفة */
        .cert-border-outer {
            position: absolute;
            inset: 6mm;
            border: 1px solid var(--royal-gold);
            pointer-events: none;
        }

        .cert-border-inner {
            position: absolute;
            inset: 9mm;
            border: 6px double var(--royal-navy);
            pointer-events: none;
        }

        /* الأركان الكلاسيكية */
        .corner {
            position: absolute;
            width: 100px;
            height: 100px;
            z-index: 10;
            border: 4px solid var(--royal-gold);
        }

        .corner-tr {
            top: 0;
            left: 0;
            border-right: none;
            border-bottom: none;
        }

        .corner-tl {
            top: 0;
            right: 0;
            border-left: none;
            border-bottom: none;
        }

        .corner-br {
            bottom: 0;
            left: 0;
            border-right: none;
            border-top: none;
        }

        .corner-bl {
            bottom: 0;
            right: 0;
            border-left: none;
            border-top: none;
        }

        /* المحتوى المركزي */
        .cert-main-wrapper {
            flex: 1;
            z-index: 5;
            display: flex;
            flex-direction: column;
            padding: 30px 60px;
            border: 1px solid rgba(197, 160, 89, 0.3);
            background: rgba(255, 255, 255, 0.7);
        }

        /* ترويسة الشهادة */
        .cert-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .brand-box {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .brand-logo-icon {
            font-size: 3.5rem;
            color: var(--royal-gold);
        }

        .brand-text h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--royal-navy);
        }

        .brand-text span {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--royal-gold);
            letter-spacing: 2px;
            display: block;
            margin-top: -5px;
        }

        .serial-tag {
            background: var(--royal-navy);
            color: white;
            padding: 12px 25px;
            border-radius: 4px;
            text-align: center;
            box-shadow: 4px 4px 0px var(--royal-gold);
        }

            .serial-tag small {
                display: block;
                font-size: 0.65rem;
                color: var(--royal-gold);
                font-weight: 800;
                text-transform: uppercase;
                margin-bottom: 2px;
            }

            .serial-tag strong {
                font-family: 'Courier New', monospace;
                font-size: 1.2rem;
            }

        /* جسم الشهادة - معالجة تباعد الأبعاد */
        .cert-body {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .title-group {
            margin-bottom: 30px;
        }

        .main-title {
            font-size: 4.2rem;
            font-weight: 900;
            color: var(--royal-navy);
            margin: 0;
            line-height: 1;
        }

        .sub-title {
            font-size: 1rem;
            color: var(--royal-gold);
            font-weight: 800;
            letter-spacing: 12px;
            text-transform: uppercase;
            margin-top: 20px;
        }

        .intro-phrase {
            font-size: 1.3rem;
            color: #666;
            font-weight: 600;
            margin-bottom: -10px;
        }

        .recipient-name {
            font-size: 3.8rem;
            font-weight: 900;
            color: var(--royal-navy);
            margin: 15px 0;
            font-family: 'Amiri', serif; /* خط عربي كلاسيكي للاسم */
            position: relative;
            padding-bottom: 10px;
        }

            .recipient-name::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 10%;
                width: 80%;
                height: 2px;
                background: linear-gradient(to left, transparent, var(--royal-gold), transparent);
            }

        .statement-text {
            font-size: 1.25rem;
            color: #444;
            max-width: 800px;
            line-height: 1.8;
            margin-top: 10px;
            font-weight: 600;
        }

            .statement-text strong {
                color: var(--royal-navy);
                font-weight: 900;
                border-bottom: 2px solid rgba(197, 160, 89, 0.4);
                padding: 0 5px;
            }

        /* تذييل الشهادة */
        .cert-footer {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: 30px;
        }

        .signature-box {
            text-align: center;
            width: 200px;
        }

        .sig-line {
            width: 100%;
            height: 1.5px;
            background: var(--royal-navy);
            margin-bottom: 10px;
        }

        .sig-name {
            font-weight: 900;
            color: var(--royal-navy);
            font-size: 1.1rem;
        }

        .sig-rank {
            font-size: 0.8rem;
            color: var(--royal-gold);
            font-weight: 800;
        }

        .qr-seal {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            bottom: -10px;
        }

        .qr-frame {
            padding: 8px;
            background: white;
            border: 2px solid var(--royal-gold);
            border-radius: 10px;
            margin-bottom: 5px;
        }

            .qr-frame img {
                width: 85px;
                height: 85px;
                display: block;
            }

        .qr-text {
            font-size: 0.7rem;
            font-weight: 900;
            color: #999;
        }

        /* أزرار التحكم في المتصفح */
        .controls-overlay {
            position: fixed;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 15px;
            z-index: 1000;
        }

        .btn-royal {
            padding: 14px 35px;
            border-radius: 50px;
            border: none;
            font-family: 'Cairo';
            font-weight: 900;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            transition: 0.3s;
            font-size: 1rem;
        }

        .btn-gold-action {
            background: var(--royal-gold);
            color: white;
        }

        .btn-white-action {
            background: white;
            color: var(--royal-navy);
            text-decoration: none;
        }

        .btn-royal:hover {
            transform: translateY(-5px);
        }

        @@media print {
            body {
                background: white;
                height: max-content;
            }

            .controls-overlay {
                display: none;
            }

            .certificate-canvas {
                box-shadow: none;
                margin: 0;
            }
        }
    </style>
</head>
<body>

    <div class="certificate-canvas">
        <div class="cert-bg-overlay"></div>

        <!-- Frames -->
        <div class="cert-border-outer"></div>
        <div class="cert-border-inner"></div>

        <!-- Royal Corners -->
        <div class="corner corner-tr"></div>
        <div class="corner corner-tl"></div>
        <div class="corner corner-br"></div>
        <div class="corner corner-bl"></div>

        <div class="cert-main-wrapper">
            <!-- Header Section -->
            <header class="cert-header">
                <div class="brand-box">
                    <i class="fa-solid fa-crown brand-logo-icon"></i>
                    <div class="brand-text">
                        <h2>أبستراكشن</h2>
                        <span>ABSTRACTION CENTER</span>
                    </div>
                </div>
                <div class="serial-tag">
                    <small>الرقم المرجعي</small>
                    <strong>@Model.UniqueSerialNumber</strong>
                </div>
            </header>

            <!-- Body Section -->
            <div class="cert-body">
                <div class="title-group">
                    <h1 class="main-title">شهادة إتمام</h1>
                    <div class="sub-title">Certificate of Completion</div>
                </div>

                <p class="intro-phrase">يشهد مركز أبستراكشن للتدريب والاستشارات بأن الفاضل/ـة:</p>
                <div class="recipient-name">@Model.Student.FullName</div>

                <p class="statement-text">
                    قد اجتاز/ت بنجاح كافة متطلبات المسار التدريبي التخصصي المكثف بعنوان:<br>
                    <strong>@Model.Batch.Course.Title</strong><br>
                    بمعدل ساعات تدريبية معتمدة، مع إتمام كافة المشاريع العملية والتقييمات المقررة بنجاح،<br>
                    وذلك في تاريخ <strong>@Model.IssueDate.ToString("dd MMMM yyyy")</strong>.
                </p>
            </div>

            <!-- Footer Section -->
            <footer class="cert-footer">
                <div class="signature-box">
                    <div class="sig-line"></div>
                    <div class="sig-name">@Model.Batch.Instructor.FullName</div>
                    <div class="sig-rank">محاضر المسار المعتمد</div>
                </div>

                <div class="qr-seal">
                    <div class="qr-frame">
                        <img src="@ViewBag.QRCodeBase64" alt="Verify QR" />
                    </div>
                    <div class="qr-text">امسح للتحقق من الموثوقية</div>
                </div>

                <div class="signature-box">
                    <div class="sig-line"></div>
                    <div class="sig-name">إدارة الأكاديمية</div>
                    <div class="sig-rank">مركز أبستراكشن للتدريب</div>
                </div>
            </footer>
        </div>
    </div>

    <!-- UI Controls -->
    <div class="controls-overlay">
        <button class="btn-royal btn-gold-action" onclick="window.print()">
            <i class="fa-solid fa-file-pdf"></i> حفظ الشهادة (PDF)
        </button>
        <a href="/Student/Dashboard" class="btn-royal btn-white-action">
            <i class="fa-solid fa-arrow-right"></i> لوحة التحكم
        </a>
    </div>

</body>
</html>
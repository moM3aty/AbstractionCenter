@model AbstractionCenter.Models.Entities.Batch
@{
    ViewData["Title"] = Model?.Course?.Title;
}

<style>
    :root {
        --royal-navy: #0b1120;
        --royal-gold: #d4af37;
        --royal-gold-light: #fef08a;
        --royal-bg: #f8fafc;
        --royal-surface: #ffffff;
        --royal-border: rgba(212, 175, 55, 0.2);
        --royal-shadow: 0 20px 40px -10px rgba(11, 17, 32, 0.1);
    }

    body {
        background: var(--royal-bg);
    }

    /* --- الهيكل الرئيسي للقاعة --- */
    .classroom-wrapper {
        display: grid;
        grid-template-columns: 380px 1fr;
        height: calc(100vh - 80px);
        margin-top: 80px;
        overflow: hidden;
    }

    /* --- القائمة الجانبية (Syllabus Sidebar) --- */
    .syllabus-sidebar {
        background: var(--royal-navy);
        color: white;
        overflow-y: auto;
        border-left: 1px solid var(--royal-border);
        display: flex;
        flex-direction: column;
        z-index: 10;
    }

    .sidebar-header {
        padding: 40px 30px;
        background: rgba(255,255,255,0.02);
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

        .sidebar-header h2 {
            color: white;
            font-size: 1.3rem;
            font-weight: 900;
            margin-bottom: 8px;
            line-height: 1.4;
        }

        .sidebar-header .batch-tag {
            color: var(--royal-gold);
            font-weight: 800;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 6px;
        }

    .curriculum-list {
        padding: 20px;
        flex-grow: 1;
    }

    .module-header {
        color: var(--royal-gold);
        font-weight: 900;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 25px 0 15px 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .content-item-link {
        padding: 16px 20px;
        border-radius: 16px;
        margin-bottom: 8px;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 15px;
        color: #94a3b8;
        font-weight: 700;
        font-size: 0.95rem;
        border: 1px solid transparent;
    }

        .content-item-link:hover {
            background: rgba(255,255,255,0.05);
            color: white;
        }

        .content-item-link.active {
            background: linear-gradient(135deg, var(--royal-gold), #b48a25);
            color: var(--royal-navy);
            border-color: var(--royal-gold-light);
            box-shadow: 0 10px 20px rgba(212, 175, 55, 0.2);
        }

        .content-item-link i {
            font-size: 1.1rem;
        }

    /* --- منطقة المحتوى (Main Viewport) --- */
    .content-viewport {
        padding: 50px;
        overflow-y: auto;
        background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23d4af37" fill-opacity="0.03"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
    }

    .unit-container {
        max-width: 1000px;
        margin: 0 auto;
        display: none;
        animation: fadeIn 0.5s ease;
    }

        .unit-container.active {
            display: block;
        }
    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(15px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .content-card-premium {
        background: white;
        border-radius: 32px;
        padding: 50px;
        box-shadow: var(--royal-shadow);
        border: 1px solid #e2e8f0;
        position: relative;
    }

    .unit-title {
        font-size: 2.2rem;
        font-weight: 900;
        color: var(--royal-navy);
        margin-bottom: 30px;
        border-right: 6px solid var(--royal-gold);
        padding-right: 20px;
    }

    /* --- الميديا (فيديو) --- */
    .video-frame-wrapper {
        border-radius: 24px;
        overflow: hidden;
        aspect-ratio: 16/9;
        background: #000;
        box-shadow: 0 30px 60px -15px rgba(0,0,0,0.3);
        margin-bottom: 40px;
        border: 1px solid var(--royal-border);
    }

        .video-frame-wrapper iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

    /* --- الملفات (PDF) --- */
    .pdf-preview-container {
        width: 100%;
        height: 700px;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        overflow: hidden;
        margin-bottom: 30px;
        background: #f1f5f9;
        box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
    }

    /* --- التكليفات (Assignments) --- */
    .mission-box {
        background: rgba(16, 185, 129, 0.03);
        border: 2px dashed #10b981;
        padding: 40px;
        border-radius: 28px;
        margin-top: 20px;
    }

    .mission-header {
        display: flex;
        align-items: center;
        gap: 15px;
        color: #065f46;
        font-weight: 900;
        font-size: 1.4rem;
        margin-bottom: 15px;
    }

    .mission-desc {
        color: #374151;
        font-size: 1.15rem;
        line-height: 1.8;
        margin-bottom: 30px;
    }

    /* نموذج الرفع */
    .royal-upload-form {
        background: white;
        padding: 30px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.02);
    }

    .file-drop-zone {
        flex-grow: 1;
        border: 2px solid #f1f5f9;
        padding: 15px;
        border-radius: 15px;
        background: #f8fafc;
        cursor: pointer;
        transition: 0.3s;
    }

        .file-drop-zone:hover {
            border-color: var(--royal-gold);
        }

        .file-drop-zone input {
            width: 100%;
            font-family: inherit;
            font-weight: 700;
            color: var(--royal-navy);
        }

    .btn-royal-submit {
        background: linear-gradient(135deg, var(--royal-navy), #1e293b);
        color: var(--royal-gold);
        border: none;
        padding: 18px 35px;
        border-radius: 15px;
        font-weight: 900;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: inherit;
    }

        .btn-royal-submit:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(11,17,32,0.2);
        }

    /* حالة التسليم */
    .submission-status {
        background: #ffffff;
        padding: 25px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .status-badge {
        padding: 8px 18px;
        border-radius: 10px;
        font-weight: 800;
        font-size: 0.9rem;
    }

    .status-success {
        background: rgba(16, 185, 129, 0.1);
        color: #059669;
    }

    .grade-panel {
        margin-top: 20px;
        padding: 20px;
        background: #fffbeb;
        border: 1px solid #fef3c7;
        border-radius: 15px;
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .grade-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: var(--royal-gold);
        color: var(--royal-navy);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        font-size: 1.4rem;
        box-shadow: 0 5px 15px rgba(212,175,55,0.3);
    }

    /* أزرار التحميل */
    .btn-luxury-action {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 18px 35px;
        border-radius: 50px;
        font-weight: 900;
        text-decoration: none;
        transition: 0.3s;
        font-size: 1.05rem;
    }

    .btn-gold {
        background: linear-gradient(135deg, var(--royal-gold), #b48a25);
        color: var(--royal-navy);
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.2);
    }

        .btn-gold:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(212, 175, 55, 0.4);
        }

    @@media (max-width: 1024px) {
        .classroom-wrapper

    {
        grid-template-columns: 1fr;
        height: auto;
    }

    .syllabus-sidebar {
        height: 400px;
        border-left: none;
        border-bottom: 1px solid var(--royal-border);
    }

    .content-viewport {
        padding: 25px;
    }

    }
</style>

<div class="classroom-wrapper">
    <!-- Syllabus Sidebar -->
    <aside class="syllabus-sidebar">
        <div class="sidebar-header">
            <h2>@Model.Course.Title</h2>
            <div class="batch-tag"><i class="fa-solid fa-crown"></i> @Model.BatchName</div>
        </div>

        <div class="curriculum-list">
            @if (Model.Lessons != null)
            {
                foreach (var lesson in Model.Lessons.OrderBy(l => l.Order))
                {
                    <div class="module-header">
                        <i class="fa-solid fa-layer-group"></i> @lesson.Title
                    </div>
                    @if (lesson.Contents != null)
                    {
                        foreach (var content in lesson.Contents.OrderBy(c => c.Order))
                        {
                            <div class="content-item-link" onclick="showContent('@content.Id', this)">
                                @if (content.Type == AbstractionCenter.Models.Entities.ContentType.Video)
                                {
                                    <i class="fa-solid fa-circle-play"></i>
                                }
                                else if (content.Type == AbstractionCenter.Models.Entities.ContentType.Pdf)
                                {

                                    <i class="fa-solid fa-file-pdf"></i>
                                }
                                else if (content.Type == AbstractionCenter.Models.Entities.ContentType.Assignment)
                                {

                                    <i class="fa-solid fa-thumbtack"></i>
                                }
                                else
                                {

                                    <i class="fa-solid fa-link"></i>
                                }
                                <span>@content.Title</span>
                            </div>
                        }
                    }
                }
            }

            <!-- زر الاختبار النهائي -->
            <div style="margin-top: 40px; padding: 0 10px;">
                <a href="/Student/TakeExam/@Model.Id" class="btn-luxury-action btn-gold" style="width: 100%; justify-content: center;">
                    <i class="fa-solid fa-medal"></i> تقديم الاختبار النهائي
                </a>
            </div>
        </div>
    </aside>

    <!-- Main Content Viewport -->
    <main class="content-viewport">
        @if (Model.Lessons != null && Model.Lessons.Any())
        {
            @foreach (var lesson in Model.Lessons)
            {
                @foreach (var item in lesson.Contents)
                {
                    <div class="unit-container" id="unit-@item.Id">
                        <div class="content-card-premium">
                            <h1 class="unit-title">@item.Title</h1>

                            @if (item.Type == AbstractionCenter.Models.Entities.ContentType.Video && !string.IsNullOrEmpty(item.VideoUrl))
                            {
                                <div class="video-frame-wrapper" oncontextmenu="return false;">
                                    @{
                                        string embedUrl = item.VideoUrl;
                                        if (embedUrl.Contains("youtube.com/watch?v=")) embedUrl = embedUrl.Replace("watch?v=", "embed/");
                                        else if (embedUrl.Contains("youtu.be/")) embedUrl = embedUrl.Replace("youtu.be/", "youtube.com/embed/");
                                    }
                                    <iframe src="@embedUrl?rel=0&modestbranding=1" allowfullscreen></iframe>
                                </div>
                            }

                            @if (item.Type == AbstractionCenter.Models.Entities.ContentType.Pdf && !string.IsNullOrEmpty(item.FilePath))
                            {
                                <div class="pdf-preview-container">
                                    <iframe src="@item.FilePath#toolbar=0" width="100%" height="100%"></iframe>
                                </div>
                                <div style="text-align: center; margin-top: 20px;">
                                    <a href="@item.FilePath" download="@item.Title" class="btn-luxury-action btn-gold">
                                        <i class="fa-solid fa-cloud-arrow-down"></i> تحميل المادة العلمية المرفقة (PDF)
                                    </a>
                                </div>
                            }

                            @if (item.Type == AbstractionCenter.Models.Entities.ContentType.ExternalQuiz && !string.IsNullOrEmpty(item.QuizUrl))
                            {
                                <div style="text-align: center; padding: 60px 20px;">
                                    <i class="fa-solid fa-clipboard-question" style="font-size: 5rem; color: var(--royal-gold); margin-bottom: 25px;"></i>
                                    <h3 style="color: var(--royal-navy); font-weight: 900; margin-bottom: 25px;">اختبار مرحلي لتقييم الاستيعاب</h3>
                                    <a href="@item.QuizUrl" target="_blank" class="btn-luxury-action btn-gold">
                                        الانتقال لمنصة الاختبار <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                    </a>
                                </div>
                            }

                            @if (item.Type == AbstractionCenter.Models.Entities.ContentType.Assignment)
                            {
                                <div class="mission-box">
                                    <div class="mission-header"><i class="fa-solid fa-thumbtack"></i> المهمة المطلوبة منك</div>
                                    <p class="mission-desc">@item.Description</p>

                                    <div style="border-top: 1px solid rgba(16, 185, 129, 0.2); padding-top: 30px;">
                                        @{
                                            var mySub = ((IEnumerable<AbstractionCenter.Models.Entities.AssignmentSubmission>)ViewBag.MySubmissions)?.FirstOrDefault(s => s.LessonContentId == item.Id);
                                        }

                                        @if (mySub != null)
                                        {
                                            <div class="submission-status">
                                                <div>
                                                    <h4 style="color: #10b981; font-weight: 900; margin-bottom: 5px;"><i class="fa-solid fa-circle-check"></i> تم تسليم الحل بنجاح</h4>
                                                    <span style="color: #64748b; font-size: 0.9rem;">بتاريخ: @mySub.SubmissionDate.ToString("dd MMMM yyyy, hh:mm tt")</span>
                                                </div>
                                                <span class="status-badge status-success">قيد المراجعة</span>
                                            </div>

                                            @if (mySub.IsGraded)
                                            {
                                                <div class="grade-panel">
                                                    <div class="grade-circle">@mySub.Grade</div>
                                                    <div>
                                                        <strong style="color: #b45309; display: block; font-size: 1.1rem;">تقييم المحاضر النهائي</strong>
                                                        <p style="margin: 5px 0 0 0; color: #92400e; font-weight: 700;"><b>ملاحظات:</b> @(mySub.InstructorFeedback ?? "لا توجد ملاحظات إضافية")</p>
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <h4 style="color: var(--royal-navy); font-weight: 900; margin-bottom: 20px;">رفع ملف الحل النهائي:</h4>
                                            <form asp-action="SubmitAssignment" method="post" enctype="multipart/form-data" class="royal-upload-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="lessonContentId" value="@item.Id" />
                                                <input type="hidden" name="batchId" value="@Model.Id" />

                                                <div class="file-drop-zone">
                                                    <input type="file" name="solutionFile" required accept=".pdf,.zip,.rar,.doc,.docx" />
                                                </div>
                                                <button type="submit" class="btn-royal-submit">
                                                    <i class="fa-solid fa-cloud-arrow-up"></i> إرسال الحل للمحاضر
                                                </button>
                                            </form>
                                            <p style="margin-top: 15px; color: #94a3b8; font-size: 0.85rem; font-weight: 700;">
                                                <i class="fa-solid fa-info-circle"></i> الصيغ المدعومة: PDF, ZIP, DOC (الحد الأقصى 10 ميجابايت)
                                            </p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        }
        else
        {
            <div class="content-card-premium" style="text-align: center; padding: 100px 20px;">
                <i class="fa-solid fa-couch" style="font-size: 5rem; color: #cbd5e1; margin-bottom: 25px;"></i>
                <h2 style="color: var(--royal-navy); font-weight: 900;">هذه القاعة فارغة حالياً</h2>
                <p style="color: #64748b; font-size: 1.2rem;">يرجى انتظار رفع المادة العلمية من قبل المحاضر المسئول.</p>
            </div>
        }
    </main>
</div>

@section Scripts {
    <script>
        function showContent(id, element) {
            // إخفاء كل الوحدات
            document.querySelectorAll('.unit-container').forEach(u => u.classList.remove('active'));
            // إزالة حالة النشط من القائمة
            document.querySelectorAll('.content-item-link').forEach(i => i.classList.remove('active'));

            // إظهار الوحدة المطلوبة
            const target = document.getElementById('unit-' + id);
            if(target) {
                target.classList.add('active');
                // تحديث حالة القائمة الجانبية
                element.classList.add('active');

                // التمرير للأعلى في منطقة المحتوى
                document.querySelector('.content-viewport').scrollTop = 0;
            }
        }

        // تشغيل أول درس تلقائياً عند التحميل
        document.addEventListener('DOMContentLoaded', function() {
            const firstItem = document.querySelector('.content-item-link');
            if(firstItem) firstItem.click();
        });
    </script>
}
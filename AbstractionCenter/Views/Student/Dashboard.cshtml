@model IEnumerable<AbstractionCenter.Models.Entities.StudentBatch>
@{
    ViewData["Title"] = "بوابة التميز الأكاديمي";
}

<style>
    :root {
        --stu-primary: #0b1120;
        --stu-gold: #d4af37;
        --stu-surface: #ffffff;
        --stu-bg: #f8fafc;
        --stu-radius: 24px;
        --stu-shadow: 0 20px 40px -10px rgba(11, 17, 32, 0.08);
    }

    body {
        background-color: var(--stu-bg);
    }

    .dashboard-container {
        padding: 120px 0 80px;
    }

    /* --- Hero Section --- */
    .premium-hero {
        background: linear-gradient(135deg, var(--stu-primary) 0%, #1e293b 100%);
        border-radius: 32px;
        padding: 60px;
        color: white;
        margin-bottom: 50px;
        box-shadow: 0 25px 50px -12px rgba(11, 17, 32, 0.4);
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(212,175,55,0.2);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .premium-hero::before {
            content: '';
            position: absolute;
            top: -100px;
            right: -50px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(212,175,55,0.15) 0%, transparent 70%);
            border-radius: 50%;
        }

    .hero-content h1 {
        font-size: 3rem;
        font-weight: 900;
        color: white;
        margin-bottom: 15px;
    }

        .hero-content h1 span {
            background: linear-gradient(to left, #d4af37, #fef08a);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        font-size: 1.2rem;
        color: #cbd5e1;
        max-width: 550px;
        line-height: 1.8;
    }

    .quick-stats {
        display: flex;
        gap: 20px;
        margin-top: 30px;
    }

    .stat-pill {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 12px 25px;
        border-radius: 15px;
        backdrop-filter: blur(10px);
        text-align: center;
    }

        .stat-pill strong {
            display: block;
            font-size: 1.5rem;
            color: var(--stu-gold);
        }

        .stat-pill span {
            font-size: 0.85rem;
            color: #94a3b8;
            font-weight: 700;
        }

    /* --- زر تسجيل الخروج الفاخر --- */
    .btn-logout-premium {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
        padding: 12px 24px;
        border-radius: 14px;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: inherit;
        font-size: 1rem;
        backdrop-filter: blur(5px);
    }

        .btn-logout-premium:hover {
            background: #ef4444;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(239, 68, 68, 0.3);
        }

    /* --- Layout Grid --- */
    .dashboard-grid {
        display: grid;
        grid-template-columns: 2.2fr 1fr;
        gap: 40px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

        .section-header h2 {
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--stu-primary);
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .section-header h2 i {
                color: var(--stu-gold);
            }

    /* --- Course Cards --- */
    .course-card-premium {
        background: white;
        border-radius: var(--stu-radius);
        padding: 35px;
        margin-bottom: 25px;
        border: 1px solid #e2e8f0;
        box-shadow: var(--stu-shadow);
        transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        display: grid;
        grid-template-columns: 80px 1fr auto;
        align-items: center;
        gap: 30px;
        position: relative;
        overflow: hidden;
    }

        .course-card-premium:hover {
            transform: translateY(-8px);
            border-color: var(--stu-gold);
            box-shadow: 0 30px 60px -12px rgba(11, 17, 32, 0.15);
        }

        .course-card-premium::before {
            content: '';
            position: absolute;
            right: 0;
            top: 0;
            bottom: 0;
            width: 6px;
            background: var(--stu-gold);
            transform: scaleY(0);
            transition: 0.3s;
        }

        .course-card-premium:hover::before {
            transform: scaleY(1);
        }

    .course-icon-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        color: var(--stu-primary);
        transition: 0.3s;
    }

    .course-card-premium:hover .course-icon-wrapper {
        background: var(--stu-primary);
        color: var(--stu-gold);
        border-color: var(--stu-primary);
        transform: rotate(5deg);
    }

    .course-info h3 {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--stu-primary);
        margin-bottom: 8px;
    }

    .course-info .instructor {
        color: #64748b;
        font-weight: 700;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .course-progress {
        width: 100%;
        height: 8px;
        background: #f1f5f9;
        border-radius: 10px;
        margin-top: 15px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(to left, var(--stu-gold), #fef08a);
        border-radius: 10px;
    }

    .btn-action-premium {
        background: #0b1120;
        color: #d4af37;
        padding: 14px 28px;
        border-radius: 14px;
        font-weight: 800;
        text-decoration: none;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        border: none;
        cursor: pointer;
    }

        .btn-action-premium:hover {
            background: var(--stu-gold);
            color: white;
            transform: scale(1.05);
        }

    .btn-cert {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        margin-right: 10px;
    }

    /* --- Notifications Panel --- */
    .side-panel-premium {
        background: white;
        border-radius: var(--stu-radius);
        padding: 35px;
        box-shadow: var(--stu-shadow);
        border: 1px solid #e2e8f0;
        position: sticky;
        top: 100px;
    }

    .notif-item {
        padding: 20px 0;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        gap: 15px;
        transition: 0.3s;
    }

        .notif-item:last-child {
            border-bottom: none;
        }

        .notif-item.unread {
            background: rgba(212,175,55,0.03);
            padding: 20px;
            border-radius: 16px;
            margin: 5px -10px;
        }

    .notif-dot {
        width: 10px;
        height: 10px;
        background: #ef4444;
        border-radius: 50%;
        margin-top: 5px;
        flex-shrink: 0;
    }

    .notif-content h4 {
        font-size: 1rem;
        font-weight: 800;
        color: var(--stu-primary);
        margin-bottom: 5px;
    }

    .notif-content p {
        font-size: 0.9rem;
        color: #64748b;
        line-height: 1.5;
        margin-bottom: 8px;
    }

    .notif-time {
        font-size: 0.75rem;
        color: #94a3b8;
        font-weight: 700;
    }

    @@media (max-width: 1024px) {
        .dashboard-grid {
            grid-template-columns: 1fr;
        }

        .course-card-premium {
            grid-template-columns: 1fr;
            text-align: center;
            justify-items: center;
        }

        .course-icon-wrapper {
            margin: 0 auto;
        }

        .premium-hero {
            flex-direction: column;
            text-align: center;
            padding: 40px 20px;
        }

        .quick-stats {
            justify-content: center;
        }
    }
</style>

<div class="container dashboard-container">
    <!-- Royal Welcome -->
    <div class="premium-hero">
        <div class="hero-content" style="width: 100%;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 20px;">
                <div>
                    <h1>مرحباً بك، <span>@ViewData["StudentName"]</span></h1>
                    <p>أنت الآن في مساحتك الخاصة للنمو والتطوير. تابع تقدمك في المسارات التدريبية، وتفاعل مع المحاضرين، وحقق التميز المهني الذي تطمح إليه.</p>
                </div>
                <!-- زر تسجيل الخروج المضاف -->
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout-premium">
                        <i class="fa-solid fa-arrow-right-from-bracket"></i> تسجيل الخروج
                    </button>
                </form>
            </div>

            <div class="quick-stats">
                <div class="stat-pill"><strong>@(Model?.Count() ?? 0)</strong><span>المسارات</span></div>
                <div class="stat-pill"><strong>@(ViewBag.MyCertificates?.Count ?? 0)</strong><span>الشهادات</span></div>
                <div class="stat-pill"><strong>@(((IEnumerable<AbstractionCenter.Models.Entities.Notification>)ViewBag.Notifications).Count(n => !n.IsRead))</strong><span>تنبيهات</span></div>
            </div>
        </div>
        <div style="font-size: 8rem; color: rgba(212,175,55,0.1); position: absolute; left: 40px; bottom: 10px; z-index: 1;">
            <i class="fa-solid fa-user-graduate"></i>
        </div>
    </div>

    <div class="dashboard-grid">
        <!-- Main Section: Courses -->
        <div>
            <div class="section-header">
                <h2><i class="fa-solid fa-graduation-cap"></i> رحلتك التعليمية</h2>
                <a href="/Courses/Open" class="btn-action-premium" style="background: white; border: 2px solid #e2e8f0; color: var(--stu-primary);"><i class="fa-solid fa-plus"></i> انضم لدفعة جديدة</a>
            </div>

            @if (Model != null && Model.Any())
            {
                foreach (var enrollment in Model)
                {
                    <div class="course-card-premium">
                        <div class="course-icon-wrapper">
                            <i class="fa-solid fa-laptop-code"></i>
                        </div>
                        <div class="course-info">
                            <h3>@enrollment.Batch.Course.Title</h3>
                            <div class="instructor">
                                <i class="fa-solid fa-chalkboard-user"></i>
                                <span>إشراف: @(enrollment.Batch.Instructor?.FullName ?? "إدارة المركز")</span>
                                <span style="margin: 0 10px; color: #cbd5e1;">|</span>
                                <span style="color: var(--stu-gold);">@enrollment.Batch.BatchName</span>
                            </div>
                            <!-- Progress Simulation -->
                            <div style="margin-top: 15px; display: flex; justify-content: space-between; font-size: 0.85rem; font-weight: 800; color: #64748b;">
                                <span>التقدم في المنهج</span>
                                <span>@(enrollment.Status == AbstractionCenter.Models.Entities.StudentAcademicStatus.Completed ? "100%" : "قيد الدراسة")</span>
                            </div>
                            <div class="course-progress">
                                <div class="progress-fill" style="width: @(enrollment.Status == AbstractionCenter.Models.Entities.StudentAcademicStatus.Completed ? "100%" : "35%")"></div>
                            </div>
                        </div>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            @if (ViewBag.MyCertificates != null)
                            {
                                var myCert = ((IEnumerable<AbstractionCenter.Models.Entities.Certificate>)ViewBag.MyCertificates).FirstOrDefault(c => c.BatchId == enrollment.BatchId);
                                if (myCert != null)
                                {
                                    <a href="/Student/Certificate/@enrollment.BatchId" target="_blank" class="btn-action-premium btn-cert" title="تحميل الشهادة الموثقة">
                                        <i class="fa-solid fa-award"></i>
                                    </a>
                                }
                            }
                            <a href="/Student/BatchDetails/@enrollment.BatchId" class="btn-action-premium">
                                دخول القاعة <i class="fa-solid fa-arrow-left"></i>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 80px; background: white; border-radius: 32px; border: 2px dashed #e2e8f0;">
                    <i class="fa-solid fa-box-open" style="font-size: 4rem; color: #cbd5e1; margin-bottom: 20px;"></i>
                    <h3 style="color: var(--stu-primary); font-weight: 900; margin-bottom: 10px;">لا توجد مسارات مسجلة</h3>
                    <p style="color: #64748b; margin-bottom: 30px;">ابدأ رحلتك الآن وانضم لآلاف المتدربين في مساراتنا المتميزة.</p>
                    <a href="/Courses/Open" class="btn-action-premium">استكشف البرامج المتاحة</a>
                </div>
            }
        </div>

        <!-- Sidebar: Notifications -->
        <div class="side-panel-premium">
            <h2 class="section-title" style="font-size: 1.4rem; margin-bottom: 25px;"><i class="fa-solid fa-bell"></i> آخر التحديثات</h2>

            <div id="notifications-list">
                @if (ViewBag.Notifications != null)
                {
                    var notifs = (IEnumerable<AbstractionCenter.Models.Entities.Notification>)ViewBag.Notifications;
                    if (notifs.Any())
                    {
                        foreach (var n in notifs)
                        {
                            <div class="notif-item @(!n.IsRead ? "unread" : "")">
                                @if (!n.IsRead)
                                {
                                    <div class="notif-dot"></div>
                                }
                                <div class="notif-content">
                                    <h4>@n.Title</h4>
                                    <p>@n.Message</p>
                                    <div class="notif-time"><i class="fa-regular fa-clock"></i> @n.CreatedAt.ToString("dd MMM, hh:mm tt")</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div style="text-align: center; padding: 40px 0;">
                            <i class="fa-solid fa-comment-slash" style="font-size: 2.5rem; color: #f1f5f9; margin-bottom: 10px;"></i>
                            <p style="color: #94a3b8; font-weight: 600;">لا توجد إشعارات حالياً</p>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
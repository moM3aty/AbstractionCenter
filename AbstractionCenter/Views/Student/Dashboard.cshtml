@model IEnumerable<AbstractionCenter.Models.Entities.StudentCourse>
@{
    ViewData["Title"] = "بوابة الطالب الأكاديمية";
}

<style>
    :root {
        --stu-primary: #0b1120;
        --stu-gold: #d4af37;
        --stu-surface: #ffffff;
        --stu-bg: #f8fafc;
        --stu-radius: 24px;
        --stu-shadow: 0 15px 35px -10px rgba(11, 17, 32, 0.08);
    }

    .dashboard-header {
        background: linear-gradient(135deg, var(--stu-primary) 0%, #1e293b 100%);
        color: white;
        padding: 60px;
        border-radius: var(--stu-radius);
        margin: 40px auto 50px;
        max-width: 1280px;
        box-shadow: 0 20px 40px -10px rgba(11, 17, 32, 0.4);
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(212,175,55,0.2);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .dashboard-header::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(212,175,55,0.2) 0%, transparent 70%);
            border-radius: 50%;
        }

    .greeting h1 {
        font-size: 2.8rem;
        font-weight: 900;
        margin-bottom: 10px;
        color: white;
    }

        .greeting h1 span {
            color: var(--stu-gold);
        }

    .greeting p {
        color: #cbd5e1;
        font-size: 1.15rem;
        max-width: 500px;
        line-height: 1.7;
        margin: 0;
    }

    .header-action .btn-explore {
        background: linear-gradient(135deg, var(--stu-gold), #fef08a);
        color: var(--stu-primary);
        padding: 16px 35px;
        border-radius: 50px;
        font-weight: 900;
        font-size: 1.1rem;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        box-shadow: 0 10px 25px rgba(212,175,55,0.4);
        transition: 0.3s;
    }

        .header-action .btn-explore:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(212,175,55,0.6);
        }

    .section-title {
        color: var(--stu-primary);
        font-size: 1.8rem;
        font-weight: 900;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 12px;
        max-width: 1280px;
        margin-left: auto;
        margin-right: auto;
    }

        .section-title i {
            color: var(--stu-gold);
        }

    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 35px;
        max-width: 1280px;
        margin: 0 auto 80px;
    }

    .course-card {
        background: var(--stu-surface);
        border-radius: var(--stu-radius);
        padding: 35px;
        box-shadow: var(--stu-shadow);
        border: 1px solid #e2e8f0;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
    }

        .course-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 25px 50px -12px rgba(11, 17, 32, 0.15);
            border-color: var(--stu-gold);
        }

        .course-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            right: 0;
            width: 100%;
            height: 4px;
            background: var(--stu-gold);
            transform: scaleX(0);
            transition: transform 0.4s;
            transform-origin: right;
        }

        .course-card:hover::after {
            transform: scaleX(1);
        }

    .course-icon-bg {
        width: 65px;
        height: 65px;
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 25px;
    }

    .course-card h3 {
        font-size: 1.4rem;
        color: var(--stu-primary);
        font-weight: 900;
        margin-bottom: 15px;
        line-height: 1.4;
        min-height: 60px;
    }

    .course-meta {
        color: #64748b;
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .course-meta i {
            color: var(--stu-gold);
        }

    .status-badge {
        padding: 8px 15px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        position: absolute;
        top: 35px;
        left: 35px;
    }

    .status-inprogress {
        background: rgba(59, 130, 246, 0.1);
        color: #2563eb;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .status-completed {
        background: rgba(16, 185, 129, 0.1);
        color: #059669;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .btn-enter {
        background: var(--stu-bg);
        color: var(--stu-primary);
        border: 2px solid #e2e8f0;
        padding: 14px 20px;
        border-radius: 14px;
        text-align: center;
        font-weight: 900;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        transition: 0.3s;
        width: 100%;
        text-decoration: none;
    }

    .course-card:hover .btn-enter {
        background: var(--stu-primary);
        color: var(--stu-gold);
        border-color: var(--stu-primary);
    }

    @@media (max-width: 768px) {
        .dashboard-header

    {
        flex-direction: column;
        text-align: center;
        gap: 30px;
        padding: 40px 20px;
        border-radius: 20px;
        margin: 20px;
    }

    .status-badge {
        position: relative;
        top: 0;
        left: 0;
        margin-bottom: 20px;
    }

    }
</style>

<div>
    <div class="dashboard-header">
        <div class="greeting">
            <h1>مرحباً بك، <span>@ViewData["StudentName"]</span></h1>
            <p>جاهز لتطوير مهاراتك اليوم؟ استكمل رحلتك التعليمية وحقق أهدافك المهنية بثقة.</p>
        </div>
        <div class="header-action">
            <a href="/Courses/Open" class="btn-explore">
                تصفح دورات جديدة <i class="fa-solid fa-compass"></i>
            </a>
        </div>
    </div>

    <h2 class="section-title"><i class="fa-solid fa-book-open-reader"></i> مكتبتي الأكاديمية</h2>

    <div class="courses-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var enrollment in Model)
            {
                <div class="course-card">
                    @if (enrollment.Status == AbstractionCenter.Models.Entities.EnrollmentStatus.InProgress)
                    {
                        <div class="status-badge status-inprogress"><i class="fa-solid fa-spinner"></i> قيد الدراسة</div>
                    }
                    else
                    {
                        <div class="status-badge status-completed"><i class="fa-solid fa-check-double"></i> مكتملة</div>
                    }

                    <div class="course-icon-bg"><i class="fa-solid fa-laptop-code"></i></div>
                    <h3>@enrollment.Course.Title</h3>
                    <div class="course-meta">
                        <i class="fa-regular fa-calendar-check"></i> تاريخ التسجيل: @enrollment.EnrollmentDate.ToString("dd MMM yyyy")
                    </div>

                    <a href="/Student/CourseDetails/@enrollment.Course.Id" class="btn-enter">
                        دخول القاعة الافتراضية <i class="fa-solid fa-door-open"></i>
                    </a>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1 / -1; background: white; border-radius: var(--stu-radius); padding: 80px 20px; text-align: center; border: 2px dashed #e2e8f0;">
                <i class="fa-solid fa-graduation-cap" style="font-size: 4rem; color: #cbd5e1; margin-bottom: 20px;"></i>
                <h3 style="color: var(--stu-primary); font-weight: 900; font-size: 1.6rem; margin-bottom: 10px;">لست مسجلاً في أي برنامج حالياً</h3>
                <p style="color: #64748b; margin-bottom: 25px; font-size: 1.1rem;">انطلق الآن واختر المسار الذي يناسب طموحك.</p>
                <a href="/Courses/Open" style="background: var(--stu-primary); color: var(--stu-gold); padding: 14px 30px; border-radius: 12px; font-weight: bold; text-decoration: none; display: inline-block;">استعراض البرامج المتاحة</a>
            </div>
        }
    </div>
</div>
@model IEnumerable<AbstractionCenter.Models.Entities.Notification>
@{
    ViewData["Title"] = "صندوق الإشعارات";
}

<style>
    .notif-header {
        background: linear-gradient(135deg, var(--primary-color) 0%, #1e293b 100%);
        border-radius: var(--radius-lg);
        padding: 40px;
        color: white;
        margin-bottom: 30px;
        box-shadow: var(--shadow-md);
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid rgba(212,175,55,0.2);
    }

        .notif-header h1 {
            color: var(--secondary-color);
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 5px;
        }

    .notif-container {
        background: white;
        border-radius: var(--radius-lg);
        padding: 30px;
        box-shadow: var(--shadow-sm);
        border: 1px solid #e2e8f0;
    }

    .notif-card {
        padding: 20px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        margin-bottom: 15px;
        display: flex;
        gap: 20px;
        transition: 0.3s;
        background: #fcfcfd;
        position: relative;
    }

        .notif-card:hover {
            background: white;
            border-color: var(--secondary-color);
            box-shadow: 0 5px 15px rgba(212,175,55,0.1);
        }

    .notif-icon {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        background: rgba(212, 175, 55, 0.1);
        color: var(--secondary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .notif-card.success .notif-icon {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
    }

    .notif-card.alert .notif-icon {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .notif-body h4 {
        color: var(--primary-color);
        font-weight: 900;
        font-size: 1.15rem;
        margin-bottom: 5px;
    }

    .notif-body p {
        color: #475569;
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 10px;
    }

    .notif-time {
        color: #94a3b8;
        font-size: 0.85rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .btn-back-dashboard {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        padding: 10px 20px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 800;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back-dashboard:hover {
            background: var(--secondary-color);
            color: var(--primary-color);
        }

    /* === Media Queries للموبايل === */
    @media (max-width: 768px) {
        .notif-header

    {
        flex-direction: column;
        text-align: center;
        padding: 30px 20px;
        gap: 20px;
        margin-top: 100px !important; /* لضمان عدم اختفائها خلف الهيدر */
    }

    .notif-header h1 {
        font-size: 1.6rem;
    }

    .btn-back-dashboard {
        width: 100%;
        justify-content: center;
        padding: 12px;
    }

    .notif-container {
        padding: 20px 15px;
    }

    .notif-card {
        flex-direction: column;
        gap: 15px;
        padding: 15px;
    }

    .notif-icon {
        width: 50px;
        height: 50px;
        font-size: 1.2rem;
    }

    .notif-body h4 {
        font-size: 1.05rem;
    }

    .notif-body p {
        font-size: 0.95rem;
    }

    }
</style>

<div class="notif-header" style="margin-top:130px;">
    <div>
        <h1><i class="fa-solid fa-bell"></i> صندوق الإشعارات</h1>
        <p style="color: #cbd5e1; margin: 0;">تابع أحدث التحديثات الخاصة بمساراتك التدريبية ونتائجك.</p>
    </div>
    <a href="/Student/Dashboard" class="btn-back-dashboard"><i class="fa-solid fa-arrow-right"></i> العودة للوحة التحكم</a>
</div>

<div class="notif-container">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            string cardClass = "";
            string iconClass = "fa-envelope-open-text";

            if (item.Title.Contains("نجاح") || item.Title.Contains("اعتماد")) { cardClass = "success"; iconClass = "fa-circle-check"; }
            else if (item.Title.Contains("إخفاق") || item.Title.Contains("للأسف")) { cardClass = "alert"; iconClass = "fa-triangle-exclamation"; }

            <div class="notif-card @cardClass">
                <div class="notif-icon"><i class="fa-solid @iconClass"></i></div>
                <div class="notif-body">
                    <h4>@item.Title</h4>
                    <p>@item.Message</p>
                    <div class="notif-time"><i class="fa-regular fa-clock"></i> @item.CreatedAt.ToString("dd MMMM yyyy - hh:mm tt")</div>
                </div>
            </div>
        }
    }
    else
    {
        <div style="text-align: center; padding: 60px 20px;">
            <i class="fa-regular fa-bell-slash" style="font-size: 4rem; color: #cbd5e1; margin-bottom: 20px;"></i>
            <h3 style="color: var(--primary-color); font-weight: 900; margin-bottom: 10px;">لا توجد إشعارات حالياً</h3>
            <p style="color: #64748b;">ستظهر جميع التنبيهات الخاصة بك هنا فور وصولها.</p>
        </div>
    }
</div>
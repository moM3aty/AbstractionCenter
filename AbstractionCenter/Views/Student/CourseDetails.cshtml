@model AbstractionCenter.Models.Entities.Course
@{
    ViewData["Title"] = Model?.Title ?? "القاعة الافتراضية";
}

<style>
    :root {
        --cd-primary: #0b1120;
        --cd-gold: #d4af37;
        --cd-surface: #ffffff;
        --cd-bg: #f8fafc;
        --cd-radius: 20px;
        --cd-shadow: 0 15px 35px -10px rgba(11, 17, 32, 0.08);
    }

    body {
        background: var(--cd-bg);
    }

    .course-header-banner {
        background: linear-gradient(135deg, var(--cd-primary) 0%, #1e293b 100%);
        padding: 60px 40px;
        border-radius: var(--cd-radius);
        margin: 30px auto;
        color: white;
        box-shadow: 0 20px 40px -10px rgba(11, 17, 32, 0.4);
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        flex-wrap: wrap;
        gap: 30px;
        border: 1px solid rgba(212, 175, 55, 0.2);
        max-width: 1320px;
    }

        .course-header-banner h1 {
            font-size: 2.4rem;
            font-weight: 900;
            color: var(--cd-gold);
            margin-bottom: 10px;
        }

    .instructor-name {
        font-size: 1.1rem;
        color: #cbd5e1;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .instructor-name i {
            color: var(--cd-gold);
        }

    .btn-exam {
        background: linear-gradient(135deg, var(--cd-gold), #fef08a);
        color: var(--cd-primary);
        padding: 16px 35px;
        border-radius: 14px;
        font-weight: 900;
        font-size: 1.1rem;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
        transition: 0.3s;
    }

        .btn-exam:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(212, 175, 55, 0.5);
        }

    .container-layout {
        max-width: 1320px;
        margin: 0 auto 80px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px;
        padding: 0 20px;
    }

    /* --- الوحدات الدراسية --- */
    .module-card {
        background: var(--cd-surface);
        border-radius: var(--cd-radius);
        padding: 35px;
        box-shadow: var(--cd-shadow);
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
        border-right: 5px solid var(--cd-primary);
        transition: 0.3s;
    }

        .module-card:hover {
            box-shadow: 0 20px 40px -10px rgba(11, 17, 32, 0.12);
        }

    .module-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--cd-primary);
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .module-title i {
            color: var(--cd-gold);
        }

    /* --- المحتويات --- */
    .content-item {
        background: #fcfcfd;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        transition: 0.3s;
    }

        .content-item:hover {
            background: white;
            border-color: rgba(212,175,55,0.4);
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        }

    .content-header {
        display: flex;
        align-items: center;
        gap: 15px;
        font-weight: 800;
        color: var(--cd-primary);
        font-size: 1.15rem;
        margin-bottom: 15px;
    }

    .icon-box {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.2rem;
    }

    .icon-video {
        background: linear-gradient(135deg, #ef4444, #b91c1c);
    }

    .icon-pdf {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    }

    .icon-task {
        background: linear-gradient(135deg, #10b981, #047857);
    }

    .video-container {
        border-radius: 16px;
        overflow: hidden;
        aspect-ratio: 16/9;
        background: #000;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

        .video-container iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

    .btn-download {
        background: rgba(59, 130, 246, 0.1);
        color: #2563eb;
        padding: 12px 25px;
        border-radius: 12px;
        font-weight: 800;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

        .btn-download:hover {
            background: #2563eb;
            color: white;
        }

    .task-box {
        background: rgba(16, 185, 129, 0.05);
        padding: 20px;
        border-radius: 12px;
        border: 1px dashed #10b981;
        color: #0b1120;
        font-weight: 600;
        line-height: 1.7;
    }

    /* Alert Messages */
    .alert-msg {
        padding: 20px 25px;
        border-radius: 16px;
        font-weight: 800;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 30px;
    }

    .alert-info {
        background: rgba(245, 158, 11, 0.1);
        color: #d97706;
        border-left: 5px solid #f59e0b;
    }

    .alert-success {
        background: rgba(16, 185, 129, 0.1);
        color: #059669;
        border-left: 5px solid #10b981;
    }

    .alert-error {
        background: rgba(239, 68, 68, 0.1);
        color: #dc2626;
        border-left: 5px solid #ef4444;
    }

    @@media (max-width: 768px) {
        .course-header-banner

    {
        flex-direction: column;
        text-align: center;
        align-items: center;
        padding: 30px 20px;
    }

    }
</style>

<div class="course-header-banner">
    <div>
        <a href="/Student/Dashboard" style="color: #cbd5e1; text-decoration: none; font-weight: bold; margin-bottom: 15px; display: inline-block;"><i class="fa-solid fa-arrow-right"></i> العودة للوحة</a>
        <h1>@Model?.Title</h1>
        <div class="instructor-name"><i class="fa-solid fa-chalkboard-user"></i> إشراف المحاضر: @(Model?.RegistrarName ?? "غير محدد")</div>
    </div>

    <div>
        <a href="/Student/TakeExam/@Model?.Id" class="btn-exam">
            <i class="fa-solid fa-medal"></i> تقديم الاختبار النهائي
        </a>
    </div>
</div>

<div class="container-layout">
    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert-msg alert-info"><i class="fa-solid fa-circle-info" style="font-size: 1.5rem;"></i> @TempData["InfoMessage"]</div>
    }

    @if (TempData["ExamResult"] != null)
    {
        bool isSuccess = (bool)TempData["IsSuccess"];
        <div class="alert-msg @(isSuccess ? "alert-success" : "alert-error")">
            <i class="fa-solid @(isSuccess ? "fa-trophy" : "fa-triangle-exclamation")" style="font-size: 1.8rem;"></i> @TempData["ExamResult"]
        </div>
    }

    @if (Model?.Lessons != null && Model.Lessons.Any())
    {
        foreach (var lesson in Model.Lessons.OrderBy(l => l.Order))
        {
            <div class="module-card">
                <h2 class="module-title"><i class="fa-solid fa-layer-group"></i> الوحدة @lesson.Order: @lesson.Title</h2>

                @if (lesson.Contents != null && lesson.Contents.Any())
                {
                    foreach (var content in lesson.Contents.OrderBy(c => c.Order))
                    {
                        <div class="content-item">
                            <div class="content-header">
                                @if (content.Type == AbstractionCenter.Models.Entities.ContentType.Video)
                                {
                                    <div class="icon-box icon-video"><i class="fa-solid fa-play"></i></div>
                                    <span>@content.Title</span>
                                }
                                else if (content.Type == AbstractionCenter.Models.Entities.ContentType.Pdf)
                                {
                                    <div class="icon-box icon-pdf"><i class="fa-solid fa-file-pdf"></i></div>
                                    <span>@content.Title</span>
                                }
                                else
                                {
                                    <div class="icon-box icon-task"><i class="fa-solid fa-list-check"></i></div>
                                    <span>مهمة وتكليف تطبيقي</span>
                                }
                            </div>

                            @if (content.Type == AbstractionCenter.Models.Entities.ContentType.Video && !string.IsNullOrEmpty(content.VideoUrl))
                            {
                                <div class="video-container">
                                    <!-- تحويل روابط يوتيوب إلى Embed -->
                                    @{
                                        string embedUrl = content.VideoUrl;
                                        if (embedUrl.Contains("youtube.com/watch?v="))
                                        {
                                            embedUrl = embedUrl.Replace("watch?v=", "embed/");
                                        }
                                        else if (embedUrl.Contains("youtu.be/"))
                                        {
                                            embedUrl = embedUrl.Replace("youtu.be/", "youtube.com/embed/");
                                        }
                                    }
                                    <iframe src="@embedUrl" allowfullscreen></iframe>
                                </div>
                            }

                            @if (content.Type == AbstractionCenter.Models.Entities.ContentType.Pdf && !string.IsNullOrEmpty(content.FilePath))
                            {
                                <a href="@content.FilePath" target="_blank" class="btn-download">
                                    <i class="fa-solid fa-cloud-arrow-down"></i> تحميل المرفق وتصفحه
                                </a>
                            }

                            @if (content.Type == AbstractionCenter.Models.Entities.ContentType.Assignment && !string.IsNullOrEmpty(content.Description))
                            {
                                <div class="task-box">
                                    <strong><i class="fa-solid fa-thumbtack"></i> المطلوب تنفيذه:</strong> @content.Description
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <p style="color: #94a3b8; text-align: center; margin: 0; font-weight: 600;"><i class="fa-solid fa-hourglass-half"></i> لم يتم إدراج محتوى لهذه الوحدة بعد.</p>
                }
            </div>
        }
    }
    else
    {
        <div style="background: white; border-radius: var(--cd-radius); padding: 80px 20px; text-align: center; box-shadow: var(--cd-shadow);">
            <i class="fa-solid fa-photo-film" style="font-size: 4.5rem; color: #cbd5e1; margin-bottom: 20px;"></i>
            <h3 style="color: var(--cd-primary); font-weight: 900; font-size: 1.8rem; margin-bottom: 10px;">لا يوجد محتوى دراسي حالياً</h3>
            <p style="color: #64748b; font-size: 1.1rem;">يرجى الانتظار حتى يقوم المحاضر برفع المنهج الخاص بهذه الدورة.</p>
        </div>
    }
</div>